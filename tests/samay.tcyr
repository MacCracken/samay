# --- M4: JSON Serialize/Deserialize roundtrip (leaf types via #derive) ---
#
# Each derive emits Type_to_json(ptr, sb) + Type_from_json(bayan_json_parse(js)).
# samay structs are heap pointers, so the *_to_json first arg is the pointer
# directly (not its address). f64 fields must round-trip BIT-EXACT (guaranteed
# by the 6.4.69 Grisu2 codec) — compared as raw i64 slots.

fn test_json_resource_req() {
    test_group("json_resource_req");
    var r = resource_req_new(f64_div(f64_from(1), f64_from(3)), 4096, REQ_GPU, 4, 1, 10000);
    var sb = str_builder_new();
    ResourceReq_to_json(r, sb);
    var r2 = ResourceReq_from_json(bayan_json_parse(str_builder_build(sb)));
    assert_eq(r2 != 0, 1, "rr parsed");
    assert_eq(ResourceReq_cpu_cores(r2) == ResourceReq_cpu_cores(r), 1, "rr cpu_cores bit-exact");
    assert_eq(ResourceReq_memory_mb(r2), 4096, "rr memory_mb");
    assert_eq(ResourceReq_accel_req(r2), REQ_GPU, "rr accel_req");
    assert_eq(ResourceReq_accel_min_chips(r2), 4, "rr accel_min_chips");
    assert_eq(ResourceReq_network(r2), 1, "rr network");
    assert_eq(ResourceReq_disk_mb(r2), 10000, "rr disk_mb");
    return 0;
}

fn test_json_resource_req_default() {
    test_group("json_rr_default");
    var r = resource_req_default();
    var sb = str_builder_new();
    ResourceReq_to_json(r, sb);
    var r2 = ResourceReq_from_json(bayan_json_parse(str_builder_build(sb)));
    assert_eq(ResourceReq_cpu_cores(r2) == ResourceReq_cpu_cores(r), 1, "default cpu (1.0) bit-exact");
    assert_eq(ResourceReq_memory_mb(r2), 256, "default mem 256");
    assert_eq(ResourceReq_accel_req(r2), REQ_NONE, "default accel none");
    return 0;
}

fn test_json_scheduling_decision() {
    test_group("json_sched_decision");
    var d = scheduling_decision_new(str_from("task-abc"), str_from("node-1"),
        str_from("best-fit selection"), f64_div(f64_from(2), f64_from(3)));
    var sb = str_builder_new();
    SchedulingDecision_to_json(d, sb);
    var d2 = SchedulingDecision_from_json(bayan_json_parse(str_builder_build(sb)));
    assert_eq(d2 != 0, 1, "decision parsed");
    assert_eq(str_eq(SchedulingDecision_task_id(d2), SchedulingDecision_task_id(d)), 1, "sd task_id");
    assert_eq(str_eq(SchedulingDecision_assigned_node(d2), SchedulingDecision_assigned_node(d)), 1, "sd assigned_node");
    assert_eq(str_eq(SchedulingDecision_reason(d2), SchedulingDecision_reason(d)), 1, "sd reason");
    assert_eq(SchedulingDecision_score(d2) == SchedulingDecision_score(d), 1, "sd score bit-exact");
    return 0;
}


fn test_json_cron_expr() {
    test_group("json_cron_expr");
    var r = cron_expr_parse(str_from("*/15 9 * * 1"));
    assert_eq(is_err_result(r), 0, "expr parsed");
    var e = result_unwrap(r);
    var sb = str_builder_new();
    CronExpr_to_json(e, sb);
    var e2 = CronExpr_from_json(bayan_json_parse(str_builder_build(sb)));
    assert_eq(e2 != 0, 1, "cronexpr json parsed");
    assert_eq(CronExpr_minute_mask(e2), CronExpr_minute_mask(e), "ce minute_mask");
    assert_eq(CronExpr_hour_mask(e2), CronExpr_hour_mask(e), "ce hour_mask");
    assert_eq(CronExpr_dom_mask(e2), CronExpr_dom_mask(e), "ce dom_mask");
    assert_eq(CronExpr_month_mask(e2), CronExpr_month_mask(e), "ce month_mask");
    assert_eq(CronExpr_dow_mask(e2), CronExpr_dow_mask(e), "ce dow_mask");
    assert_eq(CronExpr_dom_star(e2), CronExpr_dom_star(e), "ce dom_star");
    assert_eq(CronExpr_dow_star(e2), CronExpr_dow_star(e), "ce dow_star");
    return 0;
}

# A deserialized CronExpr must still match the same instants as the original.
fn test_json_cron_expr_semantic() {
    test_group("json_cron_semantic");
    var e = result_unwrap(cron_expr_parse(str_from("*/15 9 * * 1")));
    var sb = str_builder_new();
    CronExpr_to_json(e, sb);
    var e2 = CronExpr_from_json(bayan_json_parse(str_builder_build(sb)));
    # 2026-01-05 is a Monday; 09:15 matches, 09:16 does not.
    var t_match = _chrono_ymd_to_epoch_secs(2026, 1, 5, 9, 15, 0);
    var t_miss = _chrono_ymd_to_epoch_secs(2026, 1, 5, 9, 16, 0);
    assert_eq(cron_expr_matches(e2, t_match), cron_expr_matches(e, t_match), "match parity 09:15");
    assert_eq(cron_expr_matches(e2, t_miss), cron_expr_matches(e, t_miss), "miss parity 09:16");
    assert_eq(cron_expr_matches(e2, t_match), 1, "09:15 matches");
    return 0;
}

# --- M4: JSON codec for container types (pointer/vec/map fields, via json_v) ---


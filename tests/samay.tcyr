fn test_json_node_capacity() {
    test_group("json_node_capacity");
    var node = node_capacity_add_accel(
        node_capacity_new(str_from("tpu-node"), f64_from(8), 16384, 102400, 0),
        profile_tpu(0, 8, TPU_V5P));
    node_capacity_reserve(node, resource_req_new(f64_from(2), 2048, REQ_NONE, 0, 0, 1024));
    var n2 = node_capacity_from_json_str(node_capacity_to_json_str(node));
    assert_eq(str_eq(NodeCapacity_node_id(n2), str_from("tpu-node")), 1, "nc node_id");
    assert_eq(NodeCapacity_total_cpu(n2) == NodeCapacity_total_cpu(node), 1, "nc total_cpu bit-exact");
    assert_eq(NodeCapacity_available_cpu(n2) == NodeCapacity_available_cpu(node), 1, "nc avail_cpu bit-exact");
    assert_eq(NodeCapacity_available_memory_mb(n2), NodeCapacity_available_memory_mb(node), "nc avail_mem");
    assert_eq(NodeCapacity_running_tasks(n2), 1, "nc running_tasks");
    assert_eq(vec_len(NodeCapacity_accel_profiles(n2)), 1, "nc 1 profile");
    # The M3 placement property must survive the round-trip.
    var tpu_req = resource_req_new(f64_from(1), 128, REQ_TPU, 4, 0, 0);
    assert_eq(node_capacity_can_fit(n2, tpu_req), 1, "rebuilt node fits REQ_TPU(4)");
    var tpu_big = resource_req_new(f64_from(1), 128, REQ_TPU, 16, 0, 0);
    assert_eq(node_capacity_can_fit(n2, tpu_big), 0, "rebuilt node rejects REQ_TPU(16)");
    return 0;
}

fn test_json_cron_entry() {
    test_group("json_cron_entry");
    var req = make_req(f64_from(1), 128);
    var tmpl = cron_task_template_new(str_from("job"), str_from("recurring"), str_from("agent-1"), 5, req);
    var expr = result_unwrap(cron_expr_parse(str_from("0 2 * * *")));
    var e = cron_entry_new(str_from("backup"), expr, tmpl, 1, CRON_SKIP);
    CronEntry_set_last_fired(e, 1700000000);
    var e2 = cron_entry_from_json_str(cron_entry_to_json_str(e));
    assert_eq(str_eq(CronEntry_name(e2), str_from("backup")), 1, "ce name");
    assert_eq(CronEntry_enabled(e2), 1, "ce enabled");
    assert_eq(CronEntry_missed_policy(e2), CRON_SKIP, "ce policy");
    assert_eq(CronEntry_last_fired(e2), 1700000000, "ce last_fired");
    # nested expr still matches the right instant (02:00 daily)
    var at_2am = _chrono_ymd_to_epoch_secs(2026, 3, 10, 2, 0, 0);
    assert_eq(cron_expr_matches(CronEntry_expr(e2), at_2am), 1, "ce nested expr matches 02:00");
    # nested template
    assert_eq(str_eq(CronTaskTemplate_name(CronEntry_task_template(e2)), str_from("job")), 1, "ce nested tmpl name");
    return 0;
}

fn test_json_cron_scheduler_deterministic() {
    test_group("json_cron_sched");
    var c = cron_scheduler_new();
    cron_scheduler_add(c, str_from("zebra"), str_from("0 1 * * *"), make_template(), 1, CRON_CATCHUP);
    cron_scheduler_add(c, str_from("alpha"), str_from("*/5 * * * *"), make_template(), 1, CRON_SKIP);
    cron_scheduler_add(c, str_from("mid"), str_from("0 12 * * *"), make_template(), 0, CRON_CATCHUP);
    var s1 = cron_scheduler_to_json_str(c);
    var s2 = cron_scheduler_to_json_str(c);
    assert_eq(str_eq(s1, s2), 1, "deterministic output (2 serializations equal)");
    # entries emitted in sorted key order: alpha, mid, zebra
    assert_eq(str_index_of_cstr(s1, "alpha") < str_index_of_cstr(s1, "mid"), 1, "alpha before mid");
    assert_eq(str_index_of_cstr(s1, "mid") < str_index_of_cstr(s1, "zebra"), 1, "mid before zebra");
    var c2 = cron_scheduler_from_json_str(s1);
    assert_eq(map_size(CronScheduler_entries(c2)), 3, "3 entries restored");
    assert_eq(str_eq(cron_scheduler_to_json_str(c2), s1), 1, "re-serialize matches");
    return 0;
}

fn test_json_task_scheduler_snapshot() {
    test_group("json_scheduler_snapshot");
    var s = task_scheduler_new();
    task_scheduler_register_node(s, node_capacity_add_accel(
        node_capacity_new(str_from("tpu-a"), f64_from(8), 16384, 102400, 0), profile_tpu(0, 4, TPU_V4)));
    task_scheduler_register_node(s, node_capacity_new(str_from("cpu-b"), f64_from(16), 32768, 204800, 0));
    task_scheduler_submit_task(s, make_task("t-alpha", 5));
    task_scheduler_submit_task(s, make_task("t-beta", 9));
    task_scheduler_schedule_pending(s);
    var snap1 = task_scheduler_to_json_str(s);
    var snap2 = task_scheduler_to_json_str(s);
    assert_eq(str_eq(snap1, snap2), 1, "snapshot deterministic");
    var s2 = task_scheduler_from_json_str(snap1);
    assert_eq(map_size(TaskScheduler_tasks(s2)), 2, "2 tasks restored");
    assert_eq(map_size(TaskScheduler_nodes(s2)), 2, "2 nodes restored");
    # restored scheduler re-serializes identically (full-fidelity snapshot)
    assert_eq(str_eq(task_scheduler_to_json_str(s2), snap1), 1, "snapshot round-trip identical");
    # stats over the restored scheduler match the original
    assert_eq(SchedulerStats_total_tasks(task_scheduler_stats(s2)),
        SchedulerStats_total_tasks(task_scheduler_stats(s)), "restored stats total match");
    return 0;
}

# --- M4 adversarial regression guards (from the container-codec verify pass) ---

# A Str with bytes: "  \  LF  TAB  c a f  0xC3 0xA9  (café) — exercises every
# JSON escape plus a multibyte UTF-8 char, built independent of source escaping.
fn _nasty_str() {
    var sb = str_builder_new();
    str_builder_add_byte(sb, 34);
    str_builder_add_byte(sb, 92);
    str_builder_add_byte(sb, 10);
    str_builder_add_byte(sb, 9);
    str_builder_add_byte(sb, 99);
    str_builder_add_byte(sb, 97);
    str_builder_add_byte(sb, 102);
    str_builder_add_byte(sb, 195);
    str_builder_add_byte(sb, 169);
    return str_builder_build(sb);
}

# GUARD 1 — string fidelity through the container DOM path (escape + UTF-8).
fn test_json_string_fidelity() {
    test_group("json_str_fidelity");
    var nasty = _nasty_str();
    var node = node_capacity_new(nasty, f64_from(1), 128, 256, 0);
    var njs = node_capacity_to_json_str(node);
    # emitted JSON must be valid (re-parseable as an object)
    assert_eq(json_v_is_obj(json_v_parse_str(str_data(njs), str_len(njs))), 1, "node json valid");
    var n2 = node_capacity_from_json_str(njs);
    assert_eq(str_eq(NodeCapacity_node_id(n2), nasty), 1, "node_id byte-identical");
    var t = scheduled_task_new(str_from("t"), str_from("d"), str_from("a"), 5, resource_req_default());
    ScheduledTask_set_fail_reason(t, nasty);
    var t2 = scheduled_task_from_json_str(scheduled_task_to_json_str(t));
    assert_eq(str_eq(ScheduledTask_fail_reason(t2), nasty), 1, "fail_reason byte-identical");
    return 0;
}

# GUARD 2 — determinism independent of insertion order (not just repeated calls).
# Fixed task_id + pinned created_at, so the determinism check isolates ordering
# from clock-derived data (dt_now() would otherwise differ between the two builds).
fn _mk_task_id(id, prio) {
    var t = make_task(id, prio);
    ScheduledTask_set_task_id(t, str_from(id));
    ScheduledTask_set_created_at(t, 1000);
    return t;
}
fn test_json_determinism_reorder() {
    test_group("json_determinism");
    var a = task_scheduler_new();
    task_scheduler_submit_task(a, _mk_task_id("zebra", 5));
    task_scheduler_submit_task(a, _mk_task_id("alpha", 5));
    task_scheduler_submit_task(a, _mk_task_id("mid", 5));
    var b = task_scheduler_new();
    task_scheduler_submit_task(b, _mk_task_id("mid", 5));
    task_scheduler_submit_task(b, _mk_task_id("zebra", 5));
    task_scheduler_submit_task(b, _mk_task_id("alpha", 5));
    assert_eq(str_eq(task_scheduler_to_json_str(a), task_scheduler_to_json_str(b)), 1,
        "same tasks, different insert order -> identical JSON");
    return 0;
}

# GUARD 3 — empty / minimal collections serialize as [] and restore to size 0.
fn test_json_empty_collections() {
    test_group("json_empty");
    var s2 = task_scheduler_from_json_str(task_scheduler_to_json_str(task_scheduler_new()));
    assert_eq(map_size(TaskScheduler_tasks(s2)), 0, "empty tasks -> 0");
    assert_eq(map_size(TaskScheduler_nodes(s2)), 0, "empty nodes -> 0");
    var c2 = cron_scheduler_from_json_str(cron_scheduler_to_json_str(cron_scheduler_new()));
    assert_eq(map_size(CronScheduler_entries(c2)), 0, "empty entries -> 0");
    var cpu = node_capacity_new(str_from("cpu"), f64_from(4), 1024, 2048, 0);
    var cpu2 = node_capacity_from_json_str(node_capacity_to_json_str(cpu));
    assert_eq(vec_len(NodeCapacity_accel_profiles(cpu2)), 0, "zero profiles -> 0");
    return 0;
}

# GUARD 4 — malformed / partial input: non-object -> 0, empty object -> defaults, no crash.
fn test_json_malformed_input() {
    test_group("json_malformed");
    assert_eq(scheduled_task_from_json_str(str_from("[1,2,3]")), 0, "array root -> 0");
    assert_eq(scheduled_task_from_json_str(str_from("42")), 0, "int root -> 0");
    assert_eq(node_capacity_from_json_str(str_from("null")), 0, "null root -> 0");
    assert_eq(task_scheduler_from_json_str(str_from("{")), 0, "unterminated -> 0");
    assert_eq(cron_entry_from_json_str(str_from("")), 0, "empty string -> 0");
    # record types with missing required fields -> rejected (fail-closed, ADR-0005)
    assert_eq(cron_task_template_from_json_str(str_from("{}")), 0, "record missing required -> 0");
    assert_eq(scheduled_task_from_json_str(str_from("{}")), 0, "task missing required -> 0");
    assert_eq(node_capacity_from_json_str(str_from("{}")), 0, "node missing node_id -> 0");
    # container types with no items -> valid empty container (no required scalar fields)
    var es = task_scheduler_from_json_str(str_from("{}"));
    assert_eq(es != 0, 1, "empty scheduler obj -> valid");
    assert_eq(map_size(TaskScheduler_tasks(es)), 0, "empty scheduler has 0 tasks");
    return 0;
}

# GUARD 5 — behavior parity + numeric boundaries after round-trip.
fn test_json_parity_boundaries() {
    test_group("json_parity_bounds");
    # f64 boundaries bit-exact through NodeCapacity.total_cpu
    var tiny = node_capacity_new(str_from("n"), f64_div(f64_from(1), f64_from(1000000000)), 1, 1, 0);
    var tiny2 = node_capacity_from_json_str(node_capacity_to_json_str(tiny));
    assert_eq(NodeCapacity_total_cpu(tiny2) == NodeCapacity_total_cpu(tiny), 1, "1e-9 cpu bit-exact");
    var zero = node_capacity_new(str_from("z"), f64_from(0), 1, 1, 0);
    var zero2 = node_capacity_from_json_str(node_capacity_to_json_str(zero));
    assert_eq(NodeCapacity_total_cpu(zero2) == f64_from(0), 1, "0.0 cpu bit-exact");
    # i64 boundary: near-max timestamp, no coercion
    var t = scheduled_task_new(str_from("t"), str_from("d"), str_from("a"), 5, resource_req_default());
    ScheduledTask_set_scheduled_at(t, 9223372036854775807);
    var t2 = scheduled_task_from_json_str(scheduled_task_to_json_str(t));
    assert_eq(ScheduledTask_scheduled_at(t2), 9223372036854775807, "i64-max timestamp exact");
    # chip-count-exact placement boundary through a restored node
    var node = node_capacity_add_accel(
        node_capacity_new(str_from("tpu"), f64_from(8), 4096, 8192, 0), profile_tpu(0, 8, TPU_V4));
    var node2 = node_capacity_from_json_str(node_capacity_to_json_str(node));
    assert_eq(node_capacity_can_fit(node2, resource_req_new(f64_from(1), 1, REQ_TPU, 8, 0, 0)), 1, "restored fits TPU(8)");
    assert_eq(node_capacity_can_fit(node2, resource_req_new(f64_from(1), 1, REQ_TPU, 9, 0, 0)), 0, "restored rejects TPU(9)");
    return 0;
}

# --- M5: determinism guarantees (tie-breaks independent of hashmap order) ---

fn _det_task(id, prio, created) {
    var t = make_task(id, prio);
    ScheduledTask_set_task_id(t, str_from(id));
    ScheduledTask_set_created_at(t, created);
    return t;
}

# Flagship: same 3 equal-priority/equal-created tasks + 2 equal nodes, inserted
# in opposite orders, must yield an identical decision sequence.
fn test_det_schedule_pending() {
    test_group("det_schedule");
    var a = task_scheduler_new();
    task_scheduler_register_node(a, make_node("node-a", f64_from(8), 8192));
    task_scheduler_register_node(a, make_node("node-b", f64_from(8), 8192));
    task_scheduler_submit_task(a, _det_task("task-1", 5, 100));
    task_scheduler_submit_task(a, _det_task("task-2", 5, 100));
    task_scheduler_submit_task(a, _det_task("task-3", 5, 100));
    var b = task_scheduler_new();
    task_scheduler_submit_task(b, _det_task("task-3", 5, 100));
    task_scheduler_submit_task(b, _det_task("task-2", 5, 100));
    task_scheduler_submit_task(b, _det_task("task-1", 5, 100));
    task_scheduler_register_node(b, make_node("node-b", f64_from(8), 8192));
    task_scheduler_register_node(b, make_node("node-a", f64_from(8), 8192));
    var da = task_scheduler_schedule_pending(a);
    var db = task_scheduler_schedule_pending(b);
    assert_eq(vec_len(da), vec_len(db), "same decision count");
    var i = 0;
    while (i < vec_len(da)) {
        assert_eq(str_eq(SchedulingDecision_task_id(vec_get(da, i)), SchedulingDecision_task_id(vec_get(db, i))), 1, "task order identical");
        assert_eq(str_eq(SchedulingDecision_assigned_node(vec_get(da, i)), SchedulingDecision_assigned_node(vec_get(db, i))), 1, "node choice identical");
        i = i + 1;
    }
    # pending order tie-break: lexicographically-first task_id goes first
    assert_eq(str_eq_cstr(SchedulingDecision_task_id(vec_get(da, 0)), "task-1"), 1, "task-1 first (task_id tie-break)");
    return 0;
}

# best-fit tie: one task, two equal-utilization nodes -> lowest node_id, both orders.
fn test_det_best_fit_tie() {
    test_group("det_best_fit");
    var a = task_scheduler_new();
    task_scheduler_register_node(a, make_node("node-a", f64_from(4), 4096));
    task_scheduler_register_node(a, make_node("node-b", f64_from(4), 4096));
    task_scheduler_submit_task(a, _det_task("t", 5, 100));
    var b = task_scheduler_new();
    task_scheduler_register_node(b, make_node("node-b", f64_from(4), 4096));
    task_scheduler_register_node(b, make_node("node-a", f64_from(4), 4096));
    task_scheduler_submit_task(b, _det_task("t", 5, 100));
    var na = SchedulingDecision_assigned_node(vec_get(task_scheduler_schedule_pending(a), 0));
    var nb = SchedulingDecision_assigned_node(vec_get(task_scheduler_schedule_pending(b), 0));
    assert_eq(str_eq_cstr(na, "node-a"), 1, "tie -> node-a (order 1)");
    assert_eq(str_eq_cstr(nb, "node-a"), 1, "tie -> node-a (order 2)");
    return 0;
}

# tasks_for_node returns task_id order regardless of submission order.
fn test_det_tasks_for_node() {
    test_group("det_tasks_for_node");
    var s = task_scheduler_new();
    var t3 = _det_task("t3", 5, 100); ScheduledTask_set_status(t3, TASK_RUNNING); ScheduledTask_set_node_preference(t3, str_from("n"));
    var t1 = _det_task("t1", 5, 100); ScheduledTask_set_status(t1, TASK_RUNNING); ScheduledTask_set_node_preference(t1, str_from("n"));
    var t2 = _det_task("t2", 5, 100); ScheduledTask_set_status(t2, TASK_RUNNING); ScheduledTask_set_node_preference(t2, str_from("n"));
    task_scheduler_submit_task(s, t3);
    task_scheduler_submit_task(s, t1);
    task_scheduler_submit_task(s, t2);
    var v = task_scheduler_tasks_for_node(s, str_from("n"));
    assert_eq(vec_len(v), 3, "3 tasks for node n");
    assert_eq(str_eq_cstr(ScheduledTask_task_id(vec_get(v, 0)), "t1"), 1, "sorted t1");
    assert_eq(str_eq_cstr(ScheduledTask_task_id(vec_get(v, 1)), "t2"), 1, "sorted t2");
    assert_eq(str_eq_cstr(ScheduledTask_task_id(vec_get(v, 2)), "t3"), 1, "sorted t3");
    return 0;
}

# The strong guard: task_ids that COLLIDE in the hashmap (all hash to slot 9 at
# cap 16), so opposite insertion orders yield opposite map_values bucket order.
# Without the samay_str_lt tie-break this test would FAIL (the UUID-based guards
# above can silently false-clean, since non-colliding keys iterate identically).
# Self-validating: first asserts the raw map order actually differs.
fn test_det_schedule_colliding() {
    test_group("det_collide");
    var a = task_scheduler_new();
    task_scheduler_register_node(a, make_node("node-a", f64_from(16), 16384));
    task_scheduler_submit_task(a, _det_task("task-0", 5, 100));
    task_scheduler_submit_task(a, _det_task("task-15", 5, 100));
    task_scheduler_submit_task(a, _det_task("task-20", 5, 100));
    task_scheduler_submit_task(a, _det_task("task-33", 5, 100));
    var b = task_scheduler_new();
    task_scheduler_register_node(b, make_node("node-a", f64_from(16), 16384));
    task_scheduler_submit_task(b, _det_task("task-33", 5, 100));
    task_scheduler_submit_task(b, _det_task("task-20", 5, 100));
    task_scheduler_submit_task(b, _det_task("task-15", 5, 100));
    task_scheduler_submit_task(b, _det_task("task-0", 5, 100));
    # non-vacuity: raw bucket order must differ between the two insertion orders
    var ra = map_values(TaskScheduler_tasks(a));
    var rb = map_values(TaskScheduler_tasks(b));
    assert_eq(str_eq(ScheduledTask_task_id(vec_get(ra, 0)), ScheduledTask_task_id(vec_get(rb, 0))), 0,
        "raw map order differs (test is non-vacuous)");
    # despite that, scheduling decisions are byte-identical
    var da = task_scheduler_schedule_pending(a);
    var db = task_scheduler_schedule_pending(b);
    assert_eq(vec_len(da), 4, "4 decisions");
    var i = 0;
    while (i < 4) {
        assert_eq(str_eq(SchedulingDecision_task_id(vec_get(da, i)), SchedulingDecision_task_id(vec_get(db, i))), 1, "collide task order identical");
        i = i + 1;
    }
    # and pending order is task_id-sorted: task-0 < task-15 < task-20 < task-33
    assert_eq(str_eq_cstr(SchedulingDecision_task_id(vec_get(da, 0)), "task-0"), 1, "sorted[0]=task-0");
    assert_eq(str_eq_cstr(SchedulingDecision_task_id(vec_get(da, 3)), "task-33"), 1, "sorted[3]=task-33");
    return 0;
}

# preempt tie-break: several equal-priority/equal-created RUNNING tasks with
# colliding ids, opposite orders -> the preempted victim is the lowest task_id.
fn test_det_preempt_tie() {
    test_group("det_preempt");
    var a = task_scheduler_new();
    var b = task_scheduler_new();
    var ids0 = _det_task("task-0", 2, 100);  ScheduledTask_set_status(ids0, TASK_RUNNING);
    var ids15 = _det_task("task-15", 2, 100); ScheduledTask_set_status(ids15, TASK_RUNNING);
    var ids20 = _det_task("task-20", 2, 100); ScheduledTask_set_status(ids20, TASK_RUNNING);
    task_scheduler_submit_task(a, ids0);
    task_scheduler_submit_task(a, ids15);
    task_scheduler_submit_task(a, ids20);
    var jds0 = _det_task("task-0", 2, 100);  ScheduledTask_set_status(jds0, TASK_RUNNING);
    var jds15 = _det_task("task-15", 2, 100); ScheduledTask_set_status(jds15, TASK_RUNNING);
    var jds20 = _det_task("task-20", 2, 100); ScheduledTask_set_status(jds20, TASK_RUNNING);
    task_scheduler_submit_task(b, jds20);
    task_scheduler_submit_task(b, jds15);
    task_scheduler_submit_task(b, jds0);
    var pa = task_scheduler_preempt_if_needed(a, make_task("hi", 10));
    var pb = task_scheduler_preempt_if_needed(b, make_task("hi", 10));
    assert_eq(pa != 0, 1, "preemption produced");
    assert_eq(str_eq_cstr(PreemptionAction_preempted_task_id(pa), "task-0"), 1, "victim = task-0 (order 1)");
    assert_eq(str_eq_cstr(PreemptionAction_preempted_task_id(pb), "task-0"), 1, "victim = task-0 (order 2)");
    return 0;
}

# cron list determinism under a map rehash (14 entries forces grow past cap 16).
fn test_det_cron_list_rehash() {
    test_group("det_cron_rehash");
    var fwd = cron_scheduler_new();
    var rev = cron_scheduler_new();
    var i = 0;
    while (i < 14) {
        var sb = str_builder_new(); str_builder_add_cstr(sb, "e"); str_builder_add_int(sb, i);
        cron_scheduler_add(fwd, str_builder_build(sb), str_from("* * * * *"), make_template(), 1, CRON_SKIP);
        var sb2 = str_builder_new(); str_builder_add_cstr(sb2, "e"); str_builder_add_int(sb2, 13 - i);
        cron_scheduler_add(rev, str_builder_build(sb2), str_from("* * * * *"), make_template(), 1, CRON_SKIP);
        i = i + 1;
    }
    var lf = cron_scheduler_list_entries(fwd);
    var lr = cron_scheduler_list_entries(rev);
    assert_eq(vec_len(lf), 14, "14 entries");
    var j = 0;
    while (j < 14) {
        assert_eq(str_eq(CronEntry_name(vec_get(lf, j)), CronEntry_name(vec_get(lr, j))), 1, "rehash list order identical");
        j = j + 1;
    }
    # spot-check sorted: e0 < e1 (byte order "e0".."e9","e1"? no — lexical: e0,e1,e10,e11,e12,e13,e2..e9)
    assert_eq(str_eq_cstr(CronEntry_name(vec_get(lf, 0)), "e0"), 1, "first is e0");
    return 0;
}

# cron list_entries emits name order regardless of insertion order.
fn test_det_cron_list() {
    test_group("det_cron_list");
    var c = cron_scheduler_new();
    cron_scheduler_add(c, str_from("zebra"), str_from("* * * * *"), make_template(), 1, CRON_SKIP);
    cron_scheduler_add(c, str_from("alpha"), str_from("* * * * *"), make_template(), 1, CRON_SKIP);
    cron_scheduler_add(c, str_from("mid"), str_from("* * * * *"), make_template(), 1, CRON_SKIP);
    var e = cron_scheduler_list_entries(c);
    assert_eq(str_eq_cstr(CronEntry_name(vec_get(e, 0)), "alpha"), 1, "list[0]=alpha");
    assert_eq(str_eq_cstr(CronEntry_name(vec_get(e, 1)), "mid"), 1, "list[1]=mid");
    assert_eq(str_eq_cstr(CronEntry_name(vec_get(e, 2)), "zebra"), 1, "list[2]=zebra");
    return 0;
}

# --- Security regression guards (restore-side validation, ADR-0005) ---

# A valid ScheduledTask snapshot, minus whichever required field the caller omits.
fn _task_json_full() {
    var t = scheduled_task_new(str_from("t"), str_from("n"), str_from("a"), 5,
        resource_req_new(f64_from(1), 256, REQ_NONE, 0, 0, 0));
    return scheduled_task_to_json_str(t);
}

# Missing required fields must reject (return 0), not produce a poisoned struct
# that SIGSEGVs on later use.
fn test_sec_reject_missing_required() {
    test_group("sec_reject_missing");
    # training: missing model_id
    assert_eq(training_job_template_from_json_str(str_from("{\"method\":0,\"dataset\":\"d\"}")), 0, "training no model_id -> 0");
    # scheduled task: missing task_id (map-key field)
    assert_eq(scheduled_task_from_json_str(str_from("{\"name\":\"n\",\"description\":\"d\",\"agent_id\":\"a\"}")), 0, "task no task_id -> 0");
    # node: missing node_id
    assert_eq(node_capacity_from_json_str(str_from("{\"total_cpu\":1.0}")), 0, "node no node_id -> 0");
    # task with missing nested resource_requirements
    assert_eq(scheduled_task_from_json_str(str_from("{\"task_id\":\"t\",\"name\":\"n\",\"description\":\"d\",\"agent_id\":\"a\"}")), 0, "task no req -> 0");
    return 0;
}

# A container with a malformed record drops that record and still serializes
# (the null-key map crash is gone).
fn test_sec_container_drops_bad() {
    test_group("sec_drop_bad");
    var s = task_scheduler_from_json_str(str_from("{\"tasks\":[{\"name\":\"orphan\"}]}"));
    assert_eq(s != 0, 1, "scheduler restored");
    assert_eq(map_size(TaskScheduler_tasks(s)), 0, "malformed task dropped");
    # re-serialization must not crash on a null key/Str
    var js = task_scheduler_to_json_str(s);
    assert_eq(str_len(js) > 0, 1, "re-serialized without crash");
    return 0;
}

# Out-of-range priority is clamped to 1..10 on restore (i64-overflow guard).
fn test_sec_clamp_priority() {
    test_group("sec_clamp_prio");
    var hi = scheduled_task_from_json_str(str_from("{\"task_id\":\"t\",\"name\":\"n\",\"description\":\"d\",\"agent_id\":\"a\",\"resource_requirements\":{\"cpu_cores\":1.0,\"memory_mb\":1,\"accel_req\":0,\"accel_min_chips\":0,\"network\":0,\"disk_mb\":0},\"priority\":9999999999}"));
    assert_eq(hi != 0, 1, "restored");
    assert_eq(ScheduledTask_priority(hi), 10, "priority clamped to 10");
    var lo = scheduled_task_from_json_str(str_from("{\"task_id\":\"t\",\"name\":\"n\",\"description\":\"d\",\"agent_id\":\"a\",\"resource_requirements\":{\"cpu_cores\":1.0,\"memory_mb\":1,\"accel_req\":0,\"accel_min_chips\":0,\"network\":0,\"disk_mb\":0},\"priority\":-5}"));
    assert_eq(ScheduledTask_priority(lo), 1, "priority clamped to 1");
    return 0;
}

# Negative unsigned-domain values are clamped to 0 on NodeCapacity restore.
fn test_sec_clamp_negative_resources() {
    test_group("sec_clamp_neg");
    var n = node_capacity_from_json_str(str_from("{\"node_id\":\"n\",\"total_cpu\":1.0,\"available_cpu\":1.0,\"total_memory_mb\":-1000,\"running_tasks\":-3}"));
    assert_eq(n != 0, 1, "restored");
    assert_eq(NodeCapacity_total_memory_mb(n), 0, "negative memory -> 0");
    assert_eq(NodeCapacity_running_tasks(n), 0, "negative running_tasks -> 0");
    return 0;
}


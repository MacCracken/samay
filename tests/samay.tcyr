    return 0;
}

fn test_json_scheduled_task() {
    test_group("json_scheduled_task");
    var req = resource_req_new(f64_div(f64_from(1), f64_from(3)), 4096, REQ_GPU, 4, 1, 10000);
    var t = scheduled_task_new(str_from("nightly"), str_from("desc"), str_from("agent-x"), 7, req);
    ScheduledTask_set_node_preference(t, str_from("gpu-1"));
    ScheduledTask_set_status(t, TASK_SCHEDULED);
    ScheduledTask_set_scheduled_at(t, 1234567890);
    ScheduledTask_set_fail_reason(t, str_from("prior OOM"));
    var t2 = scheduled_task_from_json_str(scheduled_task_to_json_str(t));
    assert_eq(str_eq(ScheduledTask_task_id(t2), ScheduledTask_task_id(t)), 1, "st task_id");
    assert_eq(str_eq(ScheduledTask_name(t2), str_from("nightly")), 1, "st name");
    assert_eq(ScheduledTask_priority(t2), 7, "st priority");
    assert_eq(ScheduledTask_status(t2), TASK_SCHEDULED, "st status");
    assert_eq(ScheduledTask_scheduled_at(t2), 1234567890, "st scheduled_at");
    assert_eq(str_eq(ScheduledTask_node_preference(t2), str_from("gpu-1")), 1, "st node_pref");
    assert_eq(str_eq(ScheduledTask_fail_reason(t2), str_from("prior OOM")), 1, "st fail_reason");
    assert_eq(ScheduledTask_created_at(t2), ScheduledTask_created_at(t), "st created_at preserved");
    var r2 = ScheduledTask_resource_requirements(t2);
    assert_eq(ResourceReq_cpu_cores(r2) == ResourceReq_cpu_cores(req), 1, "st nested cpu bit-exact");
    assert_eq(ResourceReq_accel_min_chips(r2), 4, "st nested min_chips");
    return 0;
}


# samay test suite
# Stdlib auto-included via cyrius.cyml; project modules included explicitly.

include "src/uuid.cyr"
include "src/types.cyr"
include "src/scheduler.cyr"
include "src/cronexpr.cyr"
include "src/cron.cyr"
include "src/training.cyr"

# --- helpers (mirror the Rust test helpers) ---

fn make_req(cpu, mem) {
    return resource_req_new(cpu, mem, REQ_NONE, 0, 0, 0);
}
fn make_node(id, cpu, mem) {
    return node_capacity_new(str_from(id), cpu, mem, 10240, 0);
}
fn make_task(name, priority) {
    return scheduled_task_new(str_from(name), str_from("test task"),
        str_from("agent-1"), priority, make_req(f64_from(1), 256));
}
fn make_template() {
    return cron_task_template_new(str_from("cron-job"), str_from("recurring"),
        str_from("agent-1"), 5, make_req(f64_from(1), 128));
}
fn at_ns(y, mo, d, h, mi) {
    return _chrono_ymd_to_epoch_secs(y, mo, d, h, mi, 0) * 1000000000;
}
fn mk_cron(expr_str, policy) {
    var c = cron_scheduler_new();
    cron_scheduler_add(c, str_from("job"), str_from(expr_str), make_template(), 1, policy);
    return c;
}

# --- uuid ---

fn test_uuid_format() {
    test_group("uuid");
    var u = uuid_v4();
    assert_eq(str_len(u), 36, "uuid is 36 chars");
    assert_eq(load8(str_data(u) + 8), 45, "dash at index 8");
    assert_eq(load8(str_data(u) + 14), 52, "version nibble is '4'");
    return 0;
}
fn test_uuid_unique() {
    test_group("uuid_unique");
    assert_eq(str_eq_cstr(uuid_v4(), uuid_v4()), 0, "two uuids differ");
    return 0;
}

# --- priority ---

fn test_priority_from_numeric() {
    test_group("priority_from_numeric");
    assert_eq(task_priority_from_numeric(1), PRIO_NORMAL, "1->normal");
    assert_eq(task_priority_from_numeric(3), PRIO_NORMAL, "3->normal");
    assert_eq(task_priority_from_numeric(4), PRIO_HIGH, "4->high");
    assert_eq(task_priority_from_numeric(6), PRIO_HIGH, "6->high");
    assert_eq(task_priority_from_numeric(7), PRIO_CRITICAL, "7->critical");
    assert_eq(task_priority_from_numeric(10), PRIO_EMERGENCY, "10->emergency");
    return 0;
}
fn test_priority_ordering() {
    test_group("priority_ordering");
    assert_eq(PRIO_EMERGENCY > PRIO_CRITICAL, 1, "emergency>critical");
    assert_eq(PRIO_CRITICAL > PRIO_HIGH, 1, "critical>high");
    assert_eq(PRIO_HIGH > PRIO_NORMAL, 1, "high>normal");
    return 0;
}
fn test_can_preempt() {
    test_group("can_preempt");
    assert_eq(task_priority_can_preempt(PRIO_EMERGENCY, PRIO_NORMAL), 1, "emergency preempts normal");
    assert_eq(task_priority_can_preempt(PRIO_CRITICAL, PRIO_HIGH), 1, "critical preempts high");
    assert_eq(task_priority_can_preempt(PRIO_NORMAL, PRIO_NORMAL), 0, "normal !preempt normal");
    assert_eq(task_priority_can_preempt(PRIO_HIGH, PRIO_CRITICAL), 0, "high !preempt critical");
    return 0;
}

# --- status transitions ---

fn test_valid_transitions() {
    test_group("valid_transitions");
    var t = make_task("t", 5);
    assert_eq(is_ok(scheduled_task_transition(t, TASK_SCHEDULED)), 1, "queued->scheduled");
    assert_eq(ScheduledTask_status(t), TASK_SCHEDULED, "status is scheduled");
    assert_eq(is_ok(scheduled_task_transition(t, TASK_RUNNING)), 1, "scheduled->running");
    assert_eq(is_ok(scheduled_task_transition(t, TASK_COMPLETED)), 1, "running->completed");
    return 0;
}
fn test_invalid_transitions() {
    test_group("invalid_transitions");
    var t = make_task("t", 5);
    assert_eq(is_err_result(scheduled_task_transition(t, TASK_COMPLETED)), 1, "queued->completed err");
    var t2 = make_task("t2", 5);
    scheduled_task_transition(t2, TASK_CANCELLED);
    assert_eq(is_err_result(scheduled_task_transition(t2, TASK_QUEUED)), 1, "cancelled->queued err");
    return 0;
}
fn test_running_to_failed() {
    test_group("running_to_failed");
    var t = make_task("t", 5);
    scheduled_task_transition(t, TASK_SCHEDULED);
    scheduled_task_transition(t, TASK_RUNNING);
    assert_eq(is_ok(scheduled_task_transition(t, TASK_FAILED)), 1, "running->failed");
    return 0;
}
fn test_invalid_completed_to_running() {
    test_group("completed_to_running");
    var t = make_task("t", 5);
    scheduled_task_transition(t, TASK_SCHEDULED);
    scheduled_task_transition(t, TASK_RUNNING);
    scheduled_task_transition(t, TASK_COMPLETED);
    assert_eq(is_err_result(scheduled_task_transition(t, TASK_RUNNING)), 1, "completed->running err");
    return 0;
}
fn test_preempt_requeue() {
    test_group("preempt_requeue");
    var t = make_task("t", 5);
    scheduled_task_transition(t, TASK_SCHEDULED);
    scheduled_task_transition(t, TASK_RUNNING);
    assert_eq(is_ok(scheduled_task_transition(t, TASK_PREEMPTED)), 1, "running->preempted");
    assert_eq(is_ok(scheduled_task_transition(t, TASK_QUEUED)), 1, "preempted->queued");
    return 0;
}

# --- node capacity ---

fn test_node_can_fit() {
    test_group("node_can_fit");
    var n = make_node("n1", f64_from(4), 8192);
    assert_eq(node_capacity_can_fit(n, make_req(f64_from(2), 4096)), 1, "fits");
    assert_eq(node_capacity_can_fit(n, make_req(f64_from(5), 1024)), 0, "too much cpu");
    assert_eq(node_capacity_can_fit(n, make_req(f64_from(1), 16384)), 0, "too much mem");
    return 0;
}
fn test_node_can_fit_gpu() {
    test_group("node_can_fit_gpu");
    var req = resource_req_new(f64_from(1), 256, REQ_GPU, 0, 0, 0);
    assert_eq(node_capacity_can_fit(node_capacity_new(str_from("n1"), f64_from(4), 8192, 10240, 0), req), 0, "no gpu");
    assert_eq(node_capacity_can_fit(node_capacity_new(str_from("n2"), f64_from(4), 8192, 10240, 1), req), 1, "gpu");
    return 0;
}
fn test_node_can_fit_tpu() {
    test_group("node_can_fit_tpu");
    var n = node_capacity_with_tpu(node_capacity_new(str_from("n1"), f64_from(4), 8192, 10240, 0), 4);
    var req = resource_req_new(f64_from(1), 256, REQ_TPU, 2, 0, 0);
    assert_eq(node_capacity_can_fit(n, req), 1, "tpu 4 chips >= 2");
    return 0;
}
fn test_node_gpu_or_tpu() {
    test_group("gpu_or_tpu");
    var n = node_capacity_with_tpu(node_capacity_new(str_from("n1"), f64_from(4), 8192, 10240, 0), 2);
    var req = resource_req_new(f64_from(1), 256, REQ_GPU_OR_TPU, 0, 0, 0);
    assert_eq(node_capacity_can_fit(n, req), 1, "tpu satisfies gpu-or-tpu");
    return 0;
}

# --- M3: real availability checking via ai-hwaccel profiles (ADR-0002) ---

fn test_node_gaudi_requires_profile() {
    test_group("node_gaudi");
    var req = resource_req_new(f64_from(1), 256, REQ_GAUDI, 0, 0, 0);
    # No accelerator profile -> does NOT fit (Rust port's stub returned true here).
    assert_eq(node_capacity_can_fit(node_capacity_new(str_from("n1"), f64_from(4), 8192, 10240, 0), req), 0, "no accel -> no gaudi");
    # A real Gaudi profile satisfies it.
    var g = node_capacity_add_accel(node_capacity_new(str_from("n2"), f64_from(4), 8192, 10240, 0), profile_gaudi(0, GAUDI2));
    assert_eq(node_capacity_can_fit(g, req), 1, "gaudi profile fits");
    # A GPU node does NOT satisfy REQ_GAUDI (specificity).
    assert_eq(node_capacity_can_fit(node_capacity_new(str_from("n3"), f64_from(4), 8192, 10240, 1), req), 0, "gpu != gaudi");
    return 0;
}
fn test_node_neuron_requires_profile() {
    test_group("node_neuron");
    var req = resource_req_new(f64_from(1), 256, REQ_AWS_NEURON, 0, 0, 0);
    assert_eq(node_capacity_can_fit(node_capacity_new(str_from("n1"), f64_from(4), 8192, 10240, 0), req), 0, "no accel -> no neuron");
    var n = node_capacity_add_accel(node_capacity_new(str_from("n2"), f64_from(4), 8192, 10240, 0), profile_neuron(0, 0, 2));
    assert_eq(node_capacity_can_fit(n, req), 1, "neuron profile fits");
    return 0;
}
fn test_node_any_accelerator() {
    test_group("node_any_accel");
    var req = resource_req_new(f64_from(1), 256, REQ_ANY_ACCELERATOR, 0, 0, 0);
    assert_eq(node_capacity_can_fit(node_capacity_new(str_from("cpu"), f64_from(4), 8192, 10240, 0), req), 0, "cpu-only -> no");
    assert_eq(node_capacity_can_fit(node_capacity_new(str_from("gpu"), f64_from(4), 8192, 10240, 1), req), 1, "gpu -> any-accel");
    return 0;
}
fn test_node_add_accel_gpu() {
    test_group("node_add_accel");
    var req = resource_req_new(f64_from(1), 256, REQ_GPU, 0, 0, 0);
    var n = node_capacity_add_accel(node_capacity_new(str_from("n"), f64_from(4), 8192, 10240, 0), profile_cuda(0, 0));
    assert_eq(node_capacity_can_fit(n, req), 1, "added cuda satisfies gpu");
    return 0;
}
fn test_node_tpu_insufficient_chips() {
    test_group("node_tpu_chips");
    # TPU with 1 chip does not satisfy a 2-chip requirement.
    var n = node_capacity_with_tpu(node_capacity_new(str_from("n1"), f64_from(4), 8192, 10240, 0), 1);
    var req = resource_req_new(f64_from(1), 256, REQ_TPU, 2, 0, 0);
    assert_eq(node_capacity_can_fit(n, req), 0, "1 chip < 2 required");
    return 0;
}
fn test_node_utilization() {
    test_group("utilization");
    var n = make_node("n1", f64_from(4), 1000);
    assert_eq(f64_to(node_capacity_utilization(n)), 0, "util 0 initially");
    node_capacity_reserve(n, make_req(f64_from(2), 500));
    assert_eq(f64_to(f64_mul(node_capacity_utilization(n), f64_from(100))), 50, "util ~0.5");
    return 0;
}
fn test_node_reserve_release() {
    test_group("reserve_release");
    var n = make_node("n1", f64_from(4), 2048);
    var req = make_req(f64_from(2), 1024);
    node_capacity_reserve(n, req);
    assert_eq(f64_to(NodeCapacity_available_cpu(n)), 2, "avail cpu 2");
    assert_eq(NodeCapacity_available_memory_mb(n), 1024, "avail mem 1024");
    assert_eq(NodeCapacity_running_tasks(n), 1, "running 1");
    node_capacity_release(n, req);
    assert_eq(f64_to(NodeCapacity_available_cpu(n)), 4, "avail cpu 4 after release");
    assert_eq(NodeCapacity_available_memory_mb(n), 2048, "avail mem 2048 after release");
    assert_eq(NodeCapacity_running_tasks(n), 0, "running 0 after release");
    return 0;
}
fn test_node_utilization_empty() {
    test_group("util_empty");
    var n = node_capacity_new(str_from("empty"), f64_from(0), 0, 0, 0);
    assert_eq(f64_to(node_capacity_utilization(n)), 0, "zero-capacity util 0");
    return 0;
}
fn test_deadline_field() {
    test_group("deadline_field");
    var t = make_task("deadline-task", 8);
    ScheduledTask_set_deadline(t, dt_add(dt_now(), dur_seconds(3600)));
    assert_eq(ScheduledTask_deadline(t) != 0, 1, "deadline set");
    assert_eq(ScheduledTask_deadline(t) > dt_now(), 1, "deadline in future");
    return 0;
}
fn test_priority_clamped() {
    test_group("priority_clamped");
    assert_eq(ScheduledTask_priority(scheduled_task_new(str_from("t"), str_from("d"), str_from("a"), 15, resource_req_default())), 10, "clamp 15->10");
    assert_eq(ScheduledTask_priority(scheduled_task_new(str_from("t"), str_from("d"), str_from("a"), 0, resource_req_default())), 1, "clamp 0->1");
    return 0;
}

# --- scheduler: submission ---

fn test_submit_task() {
    test_group("submit_task");
    var s = task_scheduler_new();
    var id = result_unwrap(task_scheduler_submit_task(s, make_task("t1", 5)));
    assert_eq(task_scheduler_get_task(s, id) != 0, 1, "task present");
    assert_eq(ScheduledTask_status(task_scheduler_get_task(s, id)), TASK_QUEUED, "initial queued");
    return 0;
}
fn test_submit_multiple() {
    test_group("submit_multiple");
    var s = task_scheduler_new();
    var id1 = result_unwrap(task_scheduler_submit_task(s, make_task("t1", 3)));
    var id2 = result_unwrap(task_scheduler_submit_task(s, make_task("t2", 7)));
    assert_eq(str_eq_cstr(id1, id2), 0, "ids differ");
    assert_eq(SchedulerStats_total_tasks(task_scheduler_stats(s)), 2, "total 2");
    return 0;
}

# --- scheduler: pending ordering ---

fn test_pending_sorted_by_priority() {
    test_group("pending_by_priority");
    var s = task_scheduler_new();
    var low = make_task("low", 2);
    ScheduledTask_set_created_at(low, dt_sub(dt_now(), dur_seconds(10)));
    var high = make_task("high", 8);
    ScheduledTask_set_created_at(high, dt_sub(dt_now(), dur_seconds(5)));
    task_scheduler_submit_task(s, low);
    task_scheduler_submit_task(s, high);
    var pending = task_scheduler_pending_tasks(s);
    assert_eq(vec_len(pending), 2, "2 pending");
    assert_eq(str_eq_cstr(ScheduledTask_name(vec_get(pending, 0)), "high"), 1, "high first");
    assert_eq(str_eq_cstr(ScheduledTask_name(vec_get(pending, 1)), "low"), 1, "low second");
    return 0;
}
fn test_pending_same_priority_by_created() {
    test_group("pending_by_created");
    var s = task_scheduler_new();
    var older = make_task("older", 5);
    ScheduledTask_set_created_at(older, dt_sub(dt_now(), dur_seconds(100)));
    var newer = make_task("newer", 5);
    ScheduledTask_set_created_at(newer, dt_now());
    task_scheduler_submit_task(s, newer);
    task_scheduler_submit_task(s, older);
    var pending = task_scheduler_pending_tasks(s);
    assert_eq(str_eq_cstr(ScheduledTask_name(vec_get(pending, 0)), "older"), 1, "older first");
    assert_eq(str_eq_cstr(ScheduledTask_name(vec_get(pending, 1)), "newer"), 1, "newer second");
    return 0;
}

# --- scheduler: preemption ---

fn test_preempt_higher_over_lower() {
    test_group("preempt_higher");
    var s = task_scheduler_new();
    var running = make_task("low", 2);
    ScheduledTask_set_status(running, TASK_RUNNING);
    task_scheduler_submit_task(s, running);
    var emergency = make_task("emergency", 10);
    var action = task_scheduler_preempt_if_needed(s, emergency);
    assert_eq(action != 0, 1, "action produced");
    assert_eq(str_eq(PreemptionAction_preempting_task_id(action), ScheduledTask_task_id(emergency)), 1, "emergency preempts");
    return 0;
}
fn test_no_preempt_same_priority() {
    test_group("no_preempt_same");
    var s = task_scheduler_new();
    var running = make_task("existing", 5);
    ScheduledTask_set_status(running, TASK_RUNNING);
    task_scheduler_submit_task(s, running);
    assert_eq(task_scheduler_preempt_if_needed(s, make_task("same", 5)), 0, "no preempt");
    return 0;
}
fn test_no_preempt_lower_priority() {
    test_group("no_preempt_lower");
    var s = task_scheduler_new();
    var running = make_task("high", 8);
    ScheduledTask_set_status(running, TASK_RUNNING);
    task_scheduler_submit_task(s, running);
    assert_eq(task_scheduler_preempt_if_needed(s, make_task("low", 2)), 0, "no preempt");
    return 0;
}

# --- scheduler: scheduling decisions ---

fn test_schedule_assigns_to_node() {
    test_group("schedule_assigns");
    var s = task_scheduler_new();
    task_scheduler_register_node(s, make_node("n1", f64_from(4), 4096));
    task_scheduler_submit_task(s, make_task("t1", 5));
    var decisions = task_scheduler_schedule_pending(s);
    assert_eq(vec_len(decisions), 1, "1 decision");
    assert_eq(str_eq_cstr(SchedulingDecision_assigned_node(vec_get(decisions, 0)), "n1"), 1, "assigned n1");
    return 0;
}
fn test_schedule_prefers_preference() {
    test_group("schedule_pref");
    var s = task_scheduler_new();
    task_scheduler_register_node(s, make_node("n1", f64_from(8), 8192));
    task_scheduler_register_node(s, make_node("n2", f64_from(8), 8192));
    var task = make_task("t1", 5);
    ScheduledTask_set_node_preference(task, str_from("n2"));
    task_scheduler_submit_task(s, task);
    var d = vec_get(task_scheduler_schedule_pending(s), 0);
    assert_eq(str_eq_cstr(SchedulingDecision_assigned_node(d), "n2"), 1, "assigned n2");
    assert_eq(str_eq_cstr(SchedulingDecision_reason(d), "preferred node"), 1, "reason preferred");
    return 0;
}
fn test_schedule_fallback_when_full() {
    test_group("schedule_fallback");
    var s = task_scheduler_new();
    var n1 = make_node("n1", f64_from(1), 128);
    NodeCapacity_set_available_cpu(n1, f64_from(0));
    NodeCapacity_set_available_memory_mb(n1, 0);
    task_scheduler_register_node(s, n1);
    task_scheduler_register_node(s, make_node("n2", f64_from(4), 4096));
    var task = make_task("t1", 5);
    ScheduledTask_set_node_preference(task, str_from("n1"));
    task_scheduler_submit_task(s, task);
    var d = vec_get(task_scheduler_schedule_pending(s), 0);
    assert_eq(str_eq_cstr(SchedulingDecision_assigned_node(d), "n2"), 1, "fallback n2");
    assert_eq(str_eq_cstr(SchedulingDecision_reason(d), "best-fit selection"), 1, "reason best-fit");
    return 0;
}
fn test_schedule_transitions() {
    test_group("schedule_transitions");
    var s = task_scheduler_new();
    task_scheduler_register_node(s, make_node("n1", f64_from(4), 4096));
    var id = result_unwrap(task_scheduler_submit_task(s, make_task("t1", 5)));
    task_scheduler_schedule_pending(s);
    assert_eq(ScheduledTask_status(task_scheduler_get_task(s, id)), TASK_SCHEDULED, "scheduled");
    return 0;
}

# --- scheduler: cancel ---

fn test_cancel_queued() {
    test_group("cancel_queued");
    var s = task_scheduler_new();
    var id = result_unwrap(task_scheduler_submit_task(s, make_task("t1", 5)));
    assert_eq(is_ok(task_scheduler_cancel_task(s, id)), 1, "cancel ok");
    assert_eq(ScheduledTask_status(task_scheduler_get_task(s, id)), TASK_CANCELLED, "cancelled");
    return 0;
}
fn test_cancel_nonexistent() {
    test_group("cancel_nonexistent");
    var s = task_scheduler_new();
    assert_eq(is_err_result(task_scheduler_cancel_task(s, str_from("nonexistent"))), 1, "err");
    return 0;
}

# --- scheduler: stats + edge cases ---

fn test_stats_empty() {
    test_group("stats_empty");
    var st = task_scheduler_stats(task_scheduler_new());
    assert_eq(SchedulerStats_total_tasks(st), 0, "total 0");
    assert_eq(SchedulerStats_queued(st), 0, "queued 0");
    assert_eq(SchedulerStats_running(st), 0, "running 0");
    return 0;
}
fn test_stats_counts() {
    test_group("stats_counts");
    var s = task_scheduler_new();
    task_scheduler_submit_task(s, make_task("q1", 3));
    task_scheduler_submit_task(s, make_task("q2", 5));
    var r = make_task("r1", 7);
    ScheduledTask_set_status(r, TASK_RUNNING);
    task_scheduler_submit_task(s, r);
    var st = task_scheduler_stats(s);
    assert_eq(SchedulerStats_total_tasks(st), 3, "total 3");
    assert_eq(SchedulerStats_queued(st), 2, "queued 2");
    assert_eq(SchedulerStats_running(st), 1, "running 1");
    return 0;
}
fn test_empty_pending() {
    test_group("empty_pending");
    assert_eq(vec_len(task_scheduler_pending_tasks(task_scheduler_new())), 0, "no pending");
    return 0;
}
fn test_schedule_no_nodes() {
    test_group("schedule_no_nodes");
    var s = task_scheduler_new();
    task_scheduler_submit_task(s, make_task("t1", 5));
    assert_eq(vec_len(task_scheduler_schedule_pending(s)), 0, "no decisions");
    assert_eq(vec_len(task_scheduler_pending_tasks(s)), 1, "still queued");
    return 0;
}
fn test_all_nodes_full() {
    test_group("all_nodes_full");
    var s = task_scheduler_new();
    var n = make_node("n1", f64_from(1), 128);
    NodeCapacity_set_available_cpu(n, f64_from(0));
    NodeCapacity_set_available_memory_mb(n, 0);
    task_scheduler_register_node(s, n);
    task_scheduler_submit_task(s, make_task("t1", 5));
    assert_eq(vec_len(task_scheduler_schedule_pending(s)), 0, "no decisions");
    return 0;
}
fn test_tasks_for_node() {
    test_group("tasks_for_node");
    var s = task_scheduler_new();
    task_scheduler_register_node(s, make_node("n1", f64_from(8), 8192));
    task_scheduler_register_node(s, make_node("n2", f64_from(8), 8192));
    var t1 = make_task("t1", 5);
    ScheduledTask_set_node_preference(t1, str_from("n1"));
    var t2 = make_task("t2", 5);
    ScheduledTask_set_node_preference(t2, str_from("n2"));
    task_scheduler_submit_task(s, t1);
    task_scheduler_submit_task(s, t2);
    task_scheduler_schedule_pending(s);
    assert_eq(vec_len(task_scheduler_tasks_for_node(s, str_from("n1"))), 1, "n1 has 1");
    assert_eq(vec_len(task_scheduler_tasks_for_node(s, str_from("n2"))), 1, "n2 has 1");
    assert_eq(vec_len(task_scheduler_tasks_for_node(s, str_from("n3"))), 0, "n3 has 0");
    return 0;
}

# --- cron (expression-based, deterministic via check_due_at) ---

fn test_cron_add_valid() {
    test_group("cron_add");
    var c = cron_scheduler_new();
    assert_eq(is_ok(cron_scheduler_add(c, str_from("backup"), str_from("0 2 * * *"), make_template(), 1, CRON_SKIP)), 1, "add ok");
    assert_eq(vec_len(cron_scheduler_list_entries(c)), 1, "1 entry");
    return 0;
}
fn test_cron_add_empty_name() {
    test_group("cron_empty_name");
    var c = cron_scheduler_new();
    assert_eq(is_err_result(cron_scheduler_add(c, str_from(""), str_from("0 2 * * *"), make_template(), 1, CRON_SKIP)), 1, "empty rejected");
    return 0;
}
fn test_cron_add_invalid_expr() {
    test_group("cron_bad_expr");
    var c = cron_scheduler_new();
    assert_eq(is_err_result(cron_scheduler_add(c, str_from("j"), str_from("not a cron"), make_template(), 1, CRON_SKIP)), 1, "garbage rejected");
    assert_eq(is_err_result(cron_scheduler_add(c, str_from("j"), str_from("99 * * * *"), make_template(), 1, CRON_SKIP)), 1, "range rejected");
    return 0;
}
fn test_cron_remove() {
    test_group("cron_remove");
    var c = cron_scheduler_new();
    cron_scheduler_add(c, str_from("backup"), str_from("0 2 * * *"), make_template(), 1, CRON_SKIP);
    assert_eq(is_ok(cron_scheduler_remove_entry(c, str_from("backup"))), 1, "remove ok");
    assert_eq(vec_len(cron_scheduler_list_entries(c)), 0, "empty");
    return 0;
}
fn test_cron_remove_nonexistent() {
    test_group("cron_remove_none");
    assert_eq(is_err_result(cron_scheduler_remove_entry(cron_scheduler_new(), str_from("nope"))), 1, "err");
    return 0;
}
fn test_cron_disabled() {
    test_group("cron_disabled");
    var c = cron_scheduler_new();
    cron_scheduler_add(c, str_from("d"), str_from("* * * * *"), make_template(), 0, CRON_CATCHUP);
    assert_eq(vec_len(cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 12, 0))), 0, "disabled skipped");
    return 0;
}
fn test_cron_first_eval_match() {
    test_group("cron_first_match");
    var c = mk_cron("* * * * *", CRON_SKIP);
    var f = cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 12, 0));
    assert_eq(vec_len(f), 1, "fires once at match");
    assert_eq(str_eq_cstr(ScheduledTask_name(vec_get(f, 0)), "cron-job (cron)"), 1, "task name");
    return 0;
}
fn test_cron_first_eval_nomatch() {
    test_group("cron_first_nomatch");
    var c = mk_cron("30 3 * * *", CRON_SKIP);
    assert_eq(vec_len(cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 3, 0))), 0, "no fire at 3:00");
    assert_eq(vec_len(cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 3, 30))), 1, "fire at 3:30");
    assert_eq(vec_len(cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 3, 45))), 0, "no fire at 3:45");
    return 0;
}
fn test_cron_catchup() {
    test_group("cron_catchup");
    var c = mk_cron("* * * * *", CRON_CATCHUP);
    cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 12, 0));
    var f = cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 12, 5));
    assert_eq(vec_len(f), 5, "catch-up fires 5 missed");
    return 0;
}
fn test_cron_skip() {
    test_group("cron_skip");
    var c = mk_cron("* * * * *", CRON_SKIP);
    cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 12, 0));
    var f = cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 12, 5));
    assert_eq(vec_len(f), 1, "skip fires once");
    return 0;
}
fn test_cron_step_expr() {
    test_group("cron_step");
    var c = mk_cron("*/15 * * * *", CRON_CATCHUP);
    cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 12, 0));
    var f = cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 13, 0));
    assert_eq(vec_len(f), 4, "every-15 fires 4 in an hour");
    return 0;
}

# --- cron: regression tests for review findings ---

fn test_cron_star_list() {
    test_group("cron_star_list");
    # "15,*" in DOM begins with '1' -> NOT a star; neither DOM nor DOW is star
    # -> OR rule; DOM covers all days -> fires every day, not only Mondays.
    var e = result_unwrap(cron_expr_parse(str_from("0 0 15,* * 1")));
    assert_eq(cron_expr_matches(e, at_ns(2026, 7, 21, 0, 0) / 1000000000), 1, "fires on a Tuesday");
    return 0;
}
fn test_cron_step_star_dom() {
    test_group("cron_step_star");
    # "*/2" in DOM begins with '*' -> DOM starred -> DOW (Monday) governs (Vixie).
    var e = result_unwrap(cron_expr_parse(str_from("0 0 */2 * 1")));
    assert_eq(cron_expr_matches(e, at_ns(2026, 7, 20, 0, 0) / 1000000000), 1, "Monday (even day) fires");
    assert_eq(cron_expr_matches(e, at_ns(2026, 7, 21, 0, 0) / 1000000000), 0, "Tuesday (odd day) no fire");
    return 0;
}
fn test_cron_trailing_comma() {
    test_group("cron_trailing_comma");
    assert_eq(is_err_result(cron_expr_parse(str_from("0,30, 12 1 1 *"))), 1, "trailing comma rejected");
    return 0;
}
fn test_cron_overflow_field() {
    test_group("cron_overflow");
    assert_eq(is_err_result(cron_expr_parse(str_from("18446744073709551621 * * * *"))), 1, "overflow field rejected");
    return 0;
}
fn test_cron_negative_epoch() {
    test_group("cron_neg_epoch");
    assert_eq(cron_expr_matches(result_unwrap(cron_expr_parse(str_from("@hourly"))), 0 - 3600), 0, "negative epoch no match");
    return 0;
}
fn test_cron_catchup_cap() {
    test_group("cron_catchup_cap");
    var c = mk_cron("* * * * *", CRON_CATCHUP);
    cron_scheduler_check_due_at(c, at_ns(2026, 7, 18, 0, 0));
    var f = cron_scheduler_check_due_at(c, at_ns(2026, 7, 19, 1, 0));
    assert_eq(vec_len(f), 1000, "catch-up capped at 1000");
    return 0;
}

# --- training ---

fn test_training_method_name() {
    test_group("training_name");
    assert_eq(streq(samay_training_method_name(TM_LORA), "lora"), 1, "lora");
    assert_eq(streq(samay_training_method_name(TM_QLORA), "qlora"), 1, "qlora");
    assert_eq(streq(samay_training_method_name(TM_FULL), "full"), 1, "full");
    assert_eq(streq(samay_training_method_name(TM_DPO), "dpo"), 1, "dpo");
    assert_eq(streq(samay_training_method_name(TM_RLHF), "rlhf"), 1, "rlhf");
    assert_eq(streq(samay_training_method_name(TM_DISTILL), "distillation"), 1, "distillation");
    return 0;
}
fn test_training_high_priority() {
    test_group("training_high_prio");
    var job = training_job_template_new(str_from("meta-llama/Llama-2-7b"), TM_LORA, str_from("/data/training.jsonl"), 0, 3600, 300);
    var task = training_job_to_scheduled_task(job, str_from("agent-123"));
    assert_eq(str_eq_cstr(ScheduledTask_name(task), "train-lora-meta-llama/Llama-2-7b"), 1, "name");
    assert_eq(ScheduledTask_priority(task), 6, "priority 6");
    assert_eq(ResourceReq_accel_req(ScheduledTask_resource_requirements(task)) != REQ_NONE, 1, "has accel");
    assert_eq(ScheduledTask_deadline(task) != 0, 1, "has deadline");
    return 0;
}
fn test_training_no_deadline_when_zero() {
    test_group("training_no_deadline");
    var job = training_job_template_new(str_from("model"), TM_QLORA, str_from("data"), str_from("gpu-node-1"), 0, 600);
    var task = training_job_to_scheduled_task(job, str_from("agent-456"));
    assert_eq(ScheduledTask_deadline(task), 0, "no deadline");
    assert_eq(str_eq_cstr(ScheduledTask_node_preference(task), "gpu-node-1"), 1, "node pref");
    return 0;
}
fn test_training_requires_accel() {
    test_group("training_accel");
    var job = training_job_template_new(str_from("m"), TM_FULL, str_from("d"), 0, 0, 0);
    var task = training_job_to_scheduled_task(job, str_from("a"));
    var req = ScheduledTask_resource_requirements(task);
    assert_eq(ResourceReq_accel_req(req), REQ_GPU_OR_TPU, "gpu-or-tpu");
    assert_eq(ResourceReq_memory_mb(req) >= 4096, 1, "mem >= 4096");
    return 0;
}


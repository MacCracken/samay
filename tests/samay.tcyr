    assert_eq(TrainingJobTemplate_method(j2), TM_QLORA, "tjt method");
    assert_eq(str_eq(TrainingJobTemplate_target_node(j2), str_from("gpu-7")), 1, "tjt target set");
    assert_eq(TrainingJobTemplate_max_duration_secs(j2), 3600, "tjt max_dur");
    # target_node null (0)
    var jn = training_job_template_new(str_from("m"), TM_FULL, str_from("d"), 0, 0, 0);
    var jn2 = training_job_template_from_json_str(training_job_template_to_json_str(jn));
    assert_eq(TrainingJobTemplate_target_node(jn2), 0, "tjt target null->0");
    return 0;
}


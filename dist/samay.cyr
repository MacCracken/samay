    scheduled_at: i64;
    started_at: i64;
    completed_at: i64;
    deadline: i64;
    node_preference: Str;
}

# Create a new task in Queued status. Priority is clamped to 1-10.
fn scheduled_task_new(name, description, agent_id, priority, req): i64 {
    var p = alloc(112);   # 14 fields * 8
    var prio = priority;
    if (prio < 1) { prio = 1; }
    if (prio > 10) { prio = 10; }
    ScheduledTask_set_task_id(p, uuid_v4());
    ScheduledTask_set_name(p, name);
    ScheduledTask_set_description(p, description);
    ScheduledTask_set_agent_id(p, agent_id);
    ScheduledTask_set_priority(p, prio);
    ScheduledTask_set_resource_requirements(p, req);
    ScheduledTask_set_status(p, TASK_QUEUED);
    ScheduledTask_set_fail_reason(p, 0);
    ScheduledTask_set_created_at(p, dt_now());
    ScheduledTask_set_scheduled_at(p, 0);
    ScheduledTask_set_started_at(p, 0);
    ScheduledTask_set_completed_at(p, 0);
    ScheduledTask_set_deadline(p, 0);
    ScheduledTask_set_node_preference(p, 0);
    return p;
}

# Derived priority classification.
fn scheduled_task_priority_class(t): i64 {
    return task_priority_from_numeric(ScheduledTask_priority(t));
}

# Transition to a new status. Returns Ok(0) on success, Err(1) on an
# invalid transition (Rust returns Result<()> with a bail! message).
fn scheduled_task_transition(t, to): i64 {
    if (task_status_valid_transition(ScheduledTask_status(t), to) != 1) {
        return Err(1);
    }
    ScheduledTask_set_status(t, to);
    return Ok(0);
}

# ---------------------------------------------------------------------------
# NodeCapacity
# ---------------------------------------------------------------------------

# M3 (ADR-0002): accelerator availability is a list of real ai-hwaccel
# accelerator profiles (profile_cuda/rocm/tpu/gaudi/neuron), not flat
# gpu/tpu booleans. can_fit delegates to ai-hwaccel's requirement_satisfied().
#derive(accessors)
struct NodeCapacity {
    node_id: Str;
    total_cpu: f64;
    available_cpu: f64;
    total_memory_mb: i64;
    available_memory_mb: i64;
    total_disk_mb: i64;
    available_disk_mb: i64;
    accel_profiles: i64;
    running_tasks: i64;
}

fn node_capacity_new(node_id, total_cpu, total_memory_mb, total_disk_mb, gpu_available): i64 {
    var p = alloc(72);   # 9 fields * 8
    NodeCapacity_set_node_id(p, node_id);
    NodeCapacity_set_total_cpu(p, total_cpu);
    NodeCapacity_set_available_cpu(p, total_cpu);
    NodeCapacity_set_total_memory_mb(p, total_memory_mb);
    NodeCapacity_set_available_memory_mb(p, total_memory_mb);
    NodeCapacity_set_total_disk_mb(p, total_disk_mb);
    NodeCapacity_set_available_disk_mb(p, total_disk_mb);
    NodeCapacity_set_accel_profiles(p, vec_new());
    NodeCapacity_set_running_tasks(p, 0);
    # Convenience: a `gpu_available` node registers one CUDA profile.
    if (gpu_available == 1) {
        vec_push(NodeCapacity_accel_profiles(p), profile_cuda(0, 0));
    }
    return p;
}

# Attach a real ai-hwaccel accelerator profile (profile_cuda / profile_rocm /
# profile_tpu / profile_gaudi / profile_neuron). Chainable. This is how
# accelerator availability is registered for resource-aware placement.
fn node_capacity_add_accel(node, profile): i64 {
    vec_push(NodeCapacity_accel_profiles(node), profile);
    return node;
}

# Convenience: register a TPU profile with `chip_count` chips (chainable).
fn node_capacity_with_tpu(node, chip_count): i64 {
    if (chip_count > 0) {
        vec_push(NodeCapacity_accel_profiles(node), profile_tpu(0, chip_count, TPU_V4));
    }
    return node;
}

# Accelerator availability check (M3, ADR-0002): delegates to ai-hwaccel's
# requirement_satisfied() over this node's real profiles. REQ_NONE always
# fits; any other requirement must be satisfied by at least one profile —
# so REQ_GAUDI / REQ_AWS_NEURON / REQ_ANY_ACCELERATOR now require an actual
# matching accelerator (vs the Rust port's always-true stub).
fn _accel_ok(req_ar, req_chips, node): i64 {
    if (req_ar == REQ_NONE) { return 1; }
    if (find_satisfying_profile(req_ar, req_chips, NodeCapacity_accel_profiles(node)) != 0) {
        return 1;
    }
    return 0;
}

# True (1) if this node can fit the given resource requirements.
fn node_capacity_can_fit(node, req): i64 {
    if (f64_lt(NodeCapacity_available_cpu(node), ResourceReq_cpu_cores(req)) == 1) { return 0; }
    if (NodeCapacity_available_memory_mb(node) < ResourceReq_memory_mb(req)) { return 0; }
    if (_accel_ok(ResourceReq_accel_req(req), ResourceReq_accel_min_chips(req), node) != 1) { return 0; }
    if (NodeCapacity_available_disk_mb(node) < ResourceReq_disk_mb(req)) { return 0; }
    return 1;
}

# Utilization ratio 0.0-1.0 (average of CPU and memory) as an f64.
fn node_capacity_utilization(node): i64 {
    var total_cpu = NodeCapacity_total_cpu(node);
    var total_mem = NodeCapacity_total_memory_mb(node);
    if (f64_eq(total_cpu, f64_from(0)) == 1) {
        if (total_mem == 0) { return f64_from(0); }
    }
    var cpu_util = f64_from(0);
    if (f64_gt(total_cpu, f64_from(0)) == 1) {
        cpu_util = f64_sub(f64_from(1), f64_div(NodeCapacity_available_cpu(node), total_cpu));
    }
    var mem_util = f64_from(0);
    if (total_mem > 0) {
        mem_util = f64_sub(f64_from(1), f64_div(f64_from(NodeCapacity_available_memory_mb(node)), f64_from(total_mem)));
    }
    return f64_div(f64_add(cpu_util, mem_util), f64_from(2));
}

# Reserve resources for a task.
fn node_capacity_reserve(node, req): i64 {
    var used_cpu = f64_sub(NodeCapacity_available_cpu(node), ResourceReq_cpu_cores(req));
    NodeCapacity_set_available_cpu(node, _f64_max(used_cpu, f64_from(0)));
    var mem = NodeCapacity_available_memory_mb(node) - ResourceReq_memory_mb(req);
    if (mem < 0) { mem = 0; }
    NodeCapacity_set_available_memory_mb(node, mem);
    var disk = NodeCapacity_available_disk_mb(node) - ResourceReq_disk_mb(req);
    if (disk < 0) { disk = 0; }
    NodeCapacity_set_available_disk_mb(node, disk);
    NodeCapacity_set_running_tasks(node, NodeCapacity_running_tasks(node) + 1);
    return 0;
}

# Release resources after a task completes.
fn node_capacity_release(node, req): i64 {
    var rel_cpu = f64_add(NodeCapacity_available_cpu(node), ResourceReq_cpu_cores(req));
    NodeCapacity_set_available_cpu(node, _f64_min(rel_cpu, NodeCapacity_total_cpu(node)));
    var mem = NodeCapacity_available_memory_mb(node) + ResourceReq_memory_mb(req);
    if (mem > NodeCapacity_total_memory_mb(node)) { mem = NodeCapacity_total_memory_mb(node); }
    NodeCapacity_set_available_memory_mb(node, mem);
    var disk = NodeCapacity_available_disk_mb(node) + ResourceReq_disk_mb(req);
    if (disk > NodeCapacity_total_disk_mb(node)) { disk = NodeCapacity_total_disk_mb(node); }
    NodeCapacity_set_available_disk_mb(node, disk);
    var rt = NodeCapacity_running_tasks(node) - 1;
    if (rt < 0) { rt = 0; }
    NodeCapacity_set_running_tasks(node, rt);
    return 0;
}


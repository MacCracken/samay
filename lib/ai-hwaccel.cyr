var SCHEMA_VERSION = 5;

# --- error.cyr ---

# error.cyr — detection error codes
# Non-fatal errors collected as warnings during hardware detection.
# Each error carries a code + tool/path name + optional message.

enum DetectionError {
    HWA_ERR_NONE = 0;
    HWA_ERR_TOOL_NOT_FOUND = 1;
    HWA_ERR_TOOL_FAILED = 2;
    HWA_ERR_TIMEOUT = 3;
    HWA_ERR_PARSE = 4;
    HWA_ERR_SYSFS_READ = 5;
}

# Warning struct layout (heap-allocated):
#   0: code (i64)     — DetectionError enum value
#   8: tool (ptr)     — tool name or sysfs path (null-terminated)
#  16: message (ptr)  — detail string (null-terminated), 0 if none
#  24: exit_code (i64) — for HWA_ERR_TOOL_FAILED, -1 if signal
#  32: timeout_secs (i64) — for HWA_ERR_TIMEOUT, seconds * 1000 (millis)
var WARNING_SIZE = 40;

fn warning_new(code, tool) {
    var w = alloc(WARNING_SIZE);
    store64(w, code);
    store64(w + 8, tool);
    store64(w + 16, 0);
    store64(w + 24, 0 - 1);
    store64(w + 32, 0);
    return w;
}

fn warning_code(w) { return load64(w); }
fn warning_tool(w) { return load64(w + 8); }
fn warning_message(w) { return load64(w + 16); }
fn warning_exit_code(w) { return load64(w + 24); }
fn warning_timeout_ms(w) { return load64(w + 32); }

fn warning_set_message(w, msg) { store64(w + 16, msg); return 0; }
fn warning_set_exit_code(w, ec) { store64(w + 24, ec); return 0; }
fn warning_set_timeout_ms(w, ms) { store64(w + 32, ms); return 0; }

fn warning_tool_not_found(tool) {
    return warning_new(HWA_ERR_TOOL_NOT_FOUND, tool);
}

fn warning_tool_failed(tool, exit_code, stderr_msg) {
    var w = warning_new(HWA_ERR_TOOL_FAILED, tool);
    warning_set_exit_code(w, exit_code);
    warning_set_message(w, stderr_msg);
    return w;
}

fn warning_timeout(tool, timeout_ms) {
    var w = warning_new(HWA_ERR_TIMEOUT, tool);
    warning_set_timeout_ms(w, timeout_ms);
    return w;
}

fn warning_parse(backend, msg) {
    var w = warning_new(HWA_ERR_PARSE, backend);
    warning_set_message(w, msg);
    return w;
}

fn warning_sysfs(path, msg) {
    var w = warning_new(HWA_ERR_SYSFS_READ, path);
    warning_set_message(w, msg);
    return w;
}

# Print a warning to stderr
fn warning_print(w) {
    var sb = str_builder_new();
    var code = warning_code(w);
    var tool = warning_tool(w);

    if (code == HWA_ERR_TOOL_NOT_FOUND) {
        str_builder_add_cstr(sb, tool);
        str_builder_add_cstr(sb, ": tool not found on $PATH\n");
    } elif (code == HWA_ERR_TOOL_FAILED) {
        str_builder_add_cstr(sb, tool);
        var ec = warning_exit_code(w);
        if (ec != (0 - 1)) {
            str_builder_add_cstr(sb, ": exited with code ");
            str_builder_add_int(sb, ec);
        } else {
            str_builder_add_cstr(sb, ": exited with signal");
        }
        var msg2 = warning_message(w);
        if (msg2 != 0) {
            str_builder_add_cstr(sb, " - ");
            str_builder_add_cstr(sb, msg2);
        }
        str_builder_add_cstr(sb, "\n");
    } elif (code == HWA_ERR_TIMEOUT) {
        str_builder_add_cstr(sb, tool);
        str_builder_add_cstr(sb, ": timed out after ");
        str_builder_add_int(sb, warning_timeout_ms(w) / 1000);
        str_builder_add_cstr(sb, "s\n");
    } elif (code == HWA_ERR_PARSE) {
        str_builder_add_cstr(sb, tool);
        str_builder_add_cstr(sb, ": parse error");
        var msg3 = warning_message(w);
        if (msg3 != 0) {
            str_builder_add_cstr(sb, " - ");
            str_builder_add_cstr(sb, msg3);
        }
        str_builder_add_cstr(sb, "\n");
    } elif (code == HWA_ERR_SYSFS_READ) {
        str_builder_add_cstr(sb, "sysfs ");
        str_builder_add_cstr(sb, tool);
        str_builder_add_cstr(sb, ": ");
        var msg4 = warning_message(w);
        if (msg4 != 0) {
            str_builder_add_cstr(sb, msg4);
        }
        str_builder_add_cstr(sb, "\n");
    }

    var result = str_builder_build(sb);
    syscall(1, 2, str_data(result), str_len(result));
    return 0;
}

# --- types.cyr ---

# types.cyr — hardware accelerator type definitions
# Enums for device families, accelerator types, backends,
# and hardware-specific generations/versions.

# --- Accelerator family (broad category) ---

enum AcceleratorFamily {
    FAMILY_CPU = 0;
    FAMILY_GPU = 1;
    FAMILY_NPU = 2;
    FAMILY_TPU = 3;
    FAMILY_AI_ASIC = 4;
}

fn family_name(f) {
    if (f == FAMILY_CPU) { return "CPU"; }
    if (f == FAMILY_GPU) { return "GPU"; }
    if (f == FAMILY_NPU) { return "NPU"; }
    if (f == FAMILY_TPU) { return "TPU"; }
    if (f == FAMILY_AI_ASIC) { return "AI ASIC"; }
    return "Unknown";
}

# --- Accelerator type (specific device kind) ---
# In Cyrius, device_id is stored on the profile, not on the type enum.

enum AcceleratorType {
    ACCEL_CPU = 0;
    ACCEL_CUDA = 1;
    ACCEL_ROCM = 2;
    ACCEL_METAL = 3;
    ACCEL_VULKAN = 4;
    ACCEL_INTEL_NPU = 5;
    ACCEL_AMD_XDNA = 6;
    ACCEL_APPLE_NPU = 7;
    ACCEL_TPU = 8;
    ACCEL_GAUDI = 9;
    ACCEL_NEURON = 10;
    ACCEL_QUALCOMM = 11;
    ACCEL_INTEL_ONEAPI = 12;
    ACCEL_CEREBRAS = 13;
    ACCEL_GRAPHCORE = 14;
    ACCEL_GROQ = 15;
    ACCEL_SAMSUNG_NPU = 16;
    ACCEL_MEDIATEK_APU = 17;
    ACCEL_WIN_GPU = 18;
}

fn accel_name(a) {
    if (a == ACCEL_CPU) { return "CPU"; }
    if (a == ACCEL_CUDA) { return "CUDA GPU"; }
    if (a == ACCEL_ROCM) { return "ROCm GPU"; }
    if (a == ACCEL_METAL) { return "Metal GPU"; }
    if (a == ACCEL_VULKAN) { return "Vulkan GPU"; }
    if (a == ACCEL_INTEL_NPU) { return "Intel NPU"; }
    if (a == ACCEL_AMD_XDNA) { return "AMD XDNA NPU"; }
    if (a == ACCEL_APPLE_NPU) { return "Apple Neural Engine"; }
    if (a == ACCEL_TPU) { return "TPU"; }
    if (a == ACCEL_GAUDI) { return "Intel Gaudi"; }
    if (a == ACCEL_NEURON) { return "AWS Neuron"; }
    if (a == ACCEL_QUALCOMM) { return "Qualcomm Cloud AI 100"; }
    if (a == ACCEL_INTEL_ONEAPI) { return "Intel oneAPI GPU"; }
    if (a == ACCEL_CEREBRAS) { return "Cerebras WSE"; }
    if (a == ACCEL_GRAPHCORE) { return "Graphcore IPU"; }
    if (a == ACCEL_GROQ) { return "Groq LPU"; }
    if (a == ACCEL_SAMSUNG_NPU) { return "Samsung NPU"; }
    if (a == ACCEL_MEDIATEK_APU) { return "MediaTek APU"; }
    if (a == ACCEL_WIN_GPU) { return "Windows GPU"; }
    return "Unknown";
}

# --- Family classification ---

fn accel_is_gpu(a) {
    if (a == ACCEL_CUDA) { return 1; }
    if (a == ACCEL_ROCM) { return 1; }
    if (a == ACCEL_METAL) { return 1; }
    if (a == ACCEL_VULKAN) { return 1; }
    if (a == ACCEL_INTEL_ONEAPI) { return 1; }
    if (a == ACCEL_WIN_GPU) { return 1; }
    return 0;
}

fn accel_is_npu(a) {
    if (a == ACCEL_INTEL_NPU) { return 1; }
    if (a == ACCEL_APPLE_NPU) { return 1; }
    if (a == ACCEL_AMD_XDNA) { return 1; }
    if (a == ACCEL_SAMSUNG_NPU) { return 1; }
    if (a == ACCEL_MEDIATEK_APU) { return 1; }
    return 0;
}

fn accel_is_tpu(a) {
    return a == ACCEL_TPU;
}

fn accel_is_ai_asic(a) {
    if (a == ACCEL_GAUDI) { return 1; }
    if (a == ACCEL_NEURON) { return 1; }
    if (a == ACCEL_QUALCOMM) { return 1; }
    if (a == ACCEL_CEREBRAS) { return 1; }
    if (a == ACCEL_GRAPHCORE) { return 1; }
    if (a == ACCEL_GROQ) { return 1; }
    return 0;
}

fn accel_family(a) {
    if (a == ACCEL_CPU) { return FAMILY_CPU; }
    if (accel_is_gpu(a) == 1) { return FAMILY_GPU; }
    if (accel_is_npu(a) == 1) { return FAMILY_NPU; }
    if (accel_is_tpu(a) == 1) { return FAMILY_TPU; }
    if (accel_is_ai_asic(a) == 1) { return FAMILY_AI_ASIC; }
    return FAMILY_CPU;
}

# --- TPU version ---

enum TpuVersion {
    TPU_V4 = 0;
    TPU_V5E = 1;
    TPU_V5P = 2;
}

fn tpu_version_name(v) {
    if (v == TPU_V4) { return "v4"; }
    if (v == TPU_V5E) { return "v5e"; }
    if (v == TPU_V5P) { return "v5p"; }
    return "unknown";
}

# HBM per chip in bytes
fn tpu_hbm_per_chip(v) {
    if (v == TPU_V4) { return 32 * 1024 * 1024 * 1024; }
    if (v == TPU_V5E) { return 16 * 1024 * 1024 * 1024; }
    if (v == TPU_V5P) { return 95 * 1024 * 1024 * 1024; }
    return 0;
}

# --- Gaudi generation ---

enum GaudiGeneration {
    GAUDI2 = 0;
    GAUDI3 = 1;
}

fn gaudi_gen_name(g) {
    if (g == GAUDI2) { return "Gaudi2"; }
    if (g == GAUDI3) { return "Gaudi3"; }
    return "unknown";
}

# HBM per device in bytes
fn gaudi_hbm_bytes(g) {
    if (g == GAUDI2) { return 96 * 1024 * 1024 * 1024; }
    if (g == GAUDI3) { return 128 * 1024 * 1024 * 1024; }
    return 0;
}

# --- Neuron chip type ---

enum NeuronChipType {
    NEURON_INFERENTIA = 0;
    NEURON_TRAINIUM = 1;
}

fn neuron_chip_name(c) {
    if (c == NEURON_INFERENTIA) { return "Inferentia"; }
    if (c == NEURON_TRAINIUM) { return "Trainium"; }
    return "unknown";
}

# HBM per core in bytes
fn neuron_hbm_per_core(c) {
    if (c == NEURON_INFERENTIA) { return 16 * 1024 * 1024 * 1024; }
    if (c == NEURON_TRAINIUM) { return 32 * 1024 * 1024 * 1024; }
    return 0;
}

# --- Throughput multiplier (inference, relative to CPU = 1.0x) ---
# Returns multiplier * 1000 (fixed-point) to avoid float
# e.g., CUDA = 20000 means 20.0x

fn accel_throughput_x1000(a) {
    if (a == ACCEL_CPU) { return 1000; }
    if (a == ACCEL_CUDA) { return 20000; }
    if (a == ACCEL_ROCM) { return 15000; }
    if (a == ACCEL_METAL) { return 12000; }
    if (a == ACCEL_VULKAN) { return 10000; }
    if (a == ACCEL_INTEL_NPU) { return 8000; }
    if (a == ACCEL_APPLE_NPU) { return 10000; }
    if (a == ACCEL_AMD_XDNA) { return 7000; }
    if (a == ACCEL_QUALCOMM) { return 14000; }
    if (a == ACCEL_INTEL_ONEAPI) { return 13000; }
    if (a == ACCEL_CEREBRAS) { return 50000; }
    if (a == ACCEL_GRAPHCORE) { return 16000; }
    if (a == ACCEL_GROQ) { return 30000; }
    if (a == ACCEL_SAMSUNG_NPU) { return 6000; }
    if (a == ACCEL_MEDIATEK_APU) { return 5000; }
    if (a == ACCEL_WIN_GPU) { return 10000; }
    # TPU and Gaudi/Neuron need version/gen — use profile-level functions
    return 1000;
}

# TPU throughput (version-aware), returns x1000
fn tpu_throughput_x1000(version) {
    if (version == TPU_V4) { return 25000; }
    if (version == TPU_V5E) { return 18000; }
    if (version == TPU_V5P) { return 35000; }
    return 1000;
}

# Gaudi throughput (generation-aware), returns x1000
fn gaudi_throughput_x1000(gen) {
    if (gen == GAUDI2) { return 22000; }
    if (gen == GAUDI3) { return 30000; }
    return 1000;
}

# Neuron throughput (chip+core-aware), returns x1000
fn neuron_throughput_x1000(chip_type, core_count) {
    var base = 15000;
    if (chip_type == NEURON_TRAINIUM) { base = 24000; }
    # base * (core_count / 2).max(1)
    var scale = core_count / 2;
    if (scale < 1) { scale = 1; }
    return base * scale;
}

# --- Training multiplier (relative to CPU = 1.0x), returns x1000 ---
# 0 = does not support training

fn accel_training_x1000(a) {
    if (a == ACCEL_CPU) { return 1000; }
    if (a == ACCEL_CUDA) { return 20000; }
    if (a == ACCEL_ROCM) { return 15000; }
    if (a == ACCEL_METAL) { return 10000; }
    if (a == ACCEL_VULKAN) { return 6000; }
    if (a == ACCEL_WIN_GPU) { return 6000; }
    # NPUs: inference only
    if (a == ACCEL_INTEL_NPU) { return 0; }
    if (a == ACCEL_APPLE_NPU) { return 0; }
    if (a == ACCEL_AMD_XDNA) { return 0; }
    if (a == ACCEL_SAMSUNG_NPU) { return 0; }
    if (a == ACCEL_MEDIATEK_APU) { return 0; }
    if (a == ACCEL_QUALCOMM) { return 0; }
    if (a == ACCEL_GROQ) { return 0; }
    if (a == ACCEL_INTEL_ONEAPI) { return 10000; }
    if (a == ACCEL_CEREBRAS) { return 60000; }
    if (a == ACCEL_GRAPHCORE) { return 18000; }
    # TPU/Gaudi/Neuron need version — use specific functions
    return 1000;
}

fn tpu_training_x1000(version) {
    if (version == TPU_V4) { return 28000; }
    if (version == TPU_V5E) { return 20000; }
    if (version == TPU_V5P) { return 40000; }
    return 1000;
}

fn gaudi_training_x1000(gen) {
    if (gen == GAUDI2) { return 25000; }
    if (gen == GAUDI3) { return 35000; }
    return 1000;
}

fn neuron_training_x1000(chip_type, core_count) {
    if (chip_type == NEURON_INFERENTIA) { return 0; }
    var scale = core_count / 2;
    if (scale < 1) { scale = 1; }
    return 26000 * scale;
}

fn accel_supports_training(a) {
    return accel_training_x1000(a) > 0;
}

# --- Priority rank (higher = preferred for best_available) ---

fn accel_rank(a) {
    if (a == ACCEL_CEREBRAS) { return 85; }
    if (a == ACCEL_CUDA) { return 60; }
    if (a == ACCEL_ROCM) { return 50; }
    if (a == ACCEL_GRAPHCORE) { return 48; }
    if (a == ACCEL_INTEL_ONEAPI) { return 42; }
    if (a == ACCEL_METAL) { return 40; }
    if (a == ACCEL_QUALCOMM) { return 38; }
    if (a == ACCEL_VULKAN) { return 35; }
    if (a == ACCEL_WIN_GPU) { return 34; }
    if (a == ACCEL_APPLE_NPU) { return 30; }
    if (a == ACCEL_AMD_XDNA) { return 25; }
    if (a == ACCEL_INTEL_NPU) { return 20; }
    if (a == ACCEL_SAMSUNG_NPU) { return 18; }
    if (a == ACCEL_MEDIATEK_APU) { return 15; }
    if (a == ACCEL_CPU) { return 10; }
    # TPU/Gaudi/Neuron/Groq need version — use specific functions
    return 10;
}

fn tpu_rank(version) {
    if (version == TPU_V5P) { return 80; }
    if (version == TPU_V4) { return 70; }
    if (version == TPU_V5E) { return 55; }
    return 50;
}

fn gaudi_rank(gen) {
    if (gen == GAUDI3) { return 75; }
    if (gen == GAUDI2) { return 65; }
    return 50;
}

fn neuron_rank(chip_type) {
    if (chip_type == NEURON_TRAINIUM) { return 58; }
    if (chip_type == NEURON_INFERENTIA) { return 45; }
    return 40;
}

fn groq_rank() { return 55; }

# --- Detection backends ---

enum Backend {
    BACKEND_CUDA = 0;
    BACKEND_ROCM = 1;
    BACKEND_APPLE = 2;
    BACKEND_VULKAN = 3;
    BACKEND_INTEL_NPU = 4;
    BACKEND_AMD_XDNA = 5;
    BACKEND_TPU = 6;
    BACKEND_GAUDI = 7;
    BACKEND_NEURON = 8;
    BACKEND_INTEL_ONEAPI = 9;
    BACKEND_QUALCOMM = 10;
    BACKEND_CEREBRAS = 11;
    BACKEND_GRAPHCORE = 12;
    BACKEND_GROQ = 13;
    BACKEND_SAMSUNG_NPU = 14;
    BACKEND_MEDIATEK_APU = 15;
    BACKEND_WINDOWS = 16;
}
var BACKEND_COUNT = 17;

fn backend_name(b) {
    if (b == BACKEND_CUDA) { return "cuda"; }
    if (b == BACKEND_ROCM) { return "rocm"; }
    if (b == BACKEND_APPLE) { return "apple"; }
    if (b == BACKEND_VULKAN) { return "vulkan"; }
    if (b == BACKEND_INTEL_NPU) { return "intel-npu"; }
    if (b == BACKEND_AMD_XDNA) { return "amd-xdna"; }
    if (b == BACKEND_TPU) { return "tpu"; }
    if (b == BACKEND_GAUDI) { return "gaudi"; }
    if (b == BACKEND_NEURON) { return "neuron"; }
    if (b == BACKEND_INTEL_ONEAPI) { return "intel-oneapi"; }
    if (b == BACKEND_QUALCOMM) { return "qualcomm"; }
    if (b == BACKEND_CEREBRAS) { return "cerebras"; }
    if (b == BACKEND_GRAPHCORE) { return "graphcore"; }
    if (b == BACKEND_GROQ) { return "groq"; }
    if (b == BACKEND_SAMSUNG_NPU) { return "samsung-npu"; }
    if (b == BACKEND_MEDIATEK_APU) { return "mediatek-apu"; }
    if (b == BACKEND_WINDOWS) { return "windows"; }
    return "unknown";
}

# Classifies whether a backend's detector spawns a subprocess
# (vendor CLI: nvidia-smi, hl-smi, neuron-ls, xpu-smi, system_profiler,
# vulkaninfo, cerebras_cli, gc-info). Library consumers with a no-exec
# contract (e.g. mihi's probe surface) use builder_no_exec() / the
# registry_detect_no_exec() entry point, which honors this predicate.
# Source-of-truth grep: any detect_<backend> that calls run_tool* in
# src/detect/<backend>.cyr is EXEC; everything else is sysfs/syscall.
fn backend_uses_exec(b) {
    if (b == BACKEND_CUDA) { return 1; }
    if (b == BACKEND_APPLE) { return 1; }
    if (b == BACKEND_VULKAN) { return 1; }
    if (b == BACKEND_GAUDI) { return 1; }
    if (b == BACKEND_NEURON) { return 1; }
    if (b == BACKEND_INTEL_ONEAPI) { return 1; }
    if (b == BACKEND_CEREBRAS) { return 1; }
    if (b == BACKEND_GRAPHCORE) { return 1; }
    if (b == BACKEND_WINDOWS) { return 1; }
    return 0;
}

# --- quantization.cyr ---

# quantization.cyr — model weight quantization levels

enum QuantizationLevel {
    QUANT_NONE = 0;
    QUANT_FP16 = 1;
    QUANT_BF16 = 2;
    QUANT_INT8 = 3;
    QUANT_INT4 = 4;
}

# Bits per parameter for each quantization level
fn quant_bits(q) {
    if (q == QUANT_NONE) { return 32; }
    if (q == QUANT_FP16) { return 16; }
    if (q == QUANT_BF16) { return 16; }
    if (q == QUANT_INT8) { return 8; }
    if (q == QUANT_INT4) { return 4; }
    return 32;
}

# Memory reduction factor vs FP32, returns x1000 fixed-point
# e.g., INT8 = 4000 (4.0x reduction)
fn quant_reduction_x1000(q) {
    var bits = quant_bits(q);
    if (bits == 0) { return 1000; }
    return 32 * 1000 / bits;
}

# Display name
fn quant_name(q) {
    if (q == QUANT_NONE) { return "FP32"; }
    if (q == QUANT_FP16) { return "FP16"; }
    if (q == QUANT_BF16) { return "BF16"; }
    if (q == QUANT_INT8) { return "INT8"; }
    if (q == QUANT_INT4) { return "INT4"; }
    return "Unknown";
}

# Parse from bit width (32 -> QUANT_NONE, 16 -> QUANT_FP16, etc.)
# Returns -1 on invalid input
fn quant_from_bits(bits) {
    if (bits == 32) { return QUANT_NONE; }
    if (bits == 16) { return QUANT_FP16; }
    if (bits == 8) { return QUANT_INT8; }
    if (bits == 4) { return QUANT_INT4; }
    return 0 - 1;
}

# Parse from string name ("fp32", "fp16", "bf16", "int8", "int4")
# Returns -1 on no match
fn quant_from_str(s) {
    if (streq(s, "fp32") == 1) { return QUANT_NONE; }
    if (streq(s, "FP32") == 1) { return QUANT_NONE; }
    if (streq(s, "fp16") == 1) { return QUANT_FP16; }
    if (streq(s, "FP16") == 1) { return QUANT_FP16; }
    if (streq(s, "bf16") == 1) { return QUANT_BF16; }
    if (streq(s, "BF16") == 1) { return QUANT_BF16; }
    if (streq(s, "int8") == 1) { return QUANT_INT8; }
    if (streq(s, "INT8") == 1) { return QUANT_INT8; }
    if (streq(s, "int4") == 1) { return QUANT_INT4; }
    if (streq(s, "INT4") == 1) { return QUANT_INT4; }
    return 0 - 1;
}

# Calculate model memory in bytes given param count and quant level
fn quant_model_bytes(param_count, quant) {
    var bits = quant_bits(quant);
    return param_count * bits / BITS_PER_BYTE;
}

# Calculate model memory with activation overhead (20%)
fn quant_model_bytes_with_overhead(param_count, quant) {
    var raw = quant_model_bytes(param_count, quant);
    return raw + raw / ACTIVATION_OVERHEAD_DIVISOR;
}

# --- profile.cyr ---

# profile.cyr — accelerator capability profile.
# 20-field heap-allocated descriptor with typed accessors. The biggest
# single struct in the codebase (160 bytes / 20 fields), most-called
# accessor surface (every detect/* backend, registry helpers, json_out,
# sharding, training, cost).
#
# 2.1.6: 20 hand-rolled getters + 17 setters replaced with
# #derive(accessors). Param `p` is canonical across the codebase but
# only as a `profile` pointer — verified unambiguous, so this struct
# uses the libro-style cross-file `check_struct` CI guard rather than
# the field-count bound check. The 4 raw cross-file writes that existed
# at 2.1.5 (in gaudi.cyr / vulkan.cyr / cuda.cyr / rocm.cyr — all
# adjusting memory_bytes after hardware-specific detection) were
# converted to `profile_set_memory_bytes(p, …)` in this slot.
#
# Sentinel: PROFILE_NONE (=-1) marks "field not reported by this
# backend" for the numeric optional fields (memory bandwidth, mem
# used/free, temperature, power, gpu util, tpu/gaudi/neuron versions).
# 0 marks "not applicable" for tpu_chip_count and neuron_cores. String
# fields (compute_cap, driver_version, device_name) use 0 as the
# null-cstr sentinel.

#derive(accessors)
struct profile {
    accel_type;
    device_id;
    available;
    memory_bytes;
    compute_cap;
    driver_version;
    device_name;
    mem_bw_x1000;
    mem_used;
    mem_free;
    pcie_bw_x1000;
    numa_node;
    temp_c;
    power_x1000;
    gpu_util;
    tpu_version;
    tpu_chips;
    gaudi_gen;
    neuron_chip;
    neuron_cores;
}

var PROFILE_SIZE = 160;
var PROFILE_NONE = 0 - 1;

fn profile_new(atype, dev_id, mem_bytes) {
    var p = alloc(PROFILE_SIZE);
    profile_set_accel_type(p, atype);
    profile_set_device_id(p, dev_id);
    profile_set_available(p, 1);
    profile_set_memory_bytes(p, mem_bytes);
    profile_set_compute_cap(p, 0);
    profile_set_driver_version(p, 0);
    profile_set_device_name(p, 0);
    profile_set_mem_bw_x1000(p, PROFILE_NONE);
    profile_set_mem_used(p, PROFILE_NONE);
    profile_set_mem_free(p, PROFILE_NONE);
    profile_set_pcie_bw_x1000(p, PROFILE_NONE);
    profile_set_numa_node(p, PROFILE_NONE);
    profile_set_temp_c(p, PROFILE_NONE);
    profile_set_power_x1000(p, PROFILE_NONE);
    profile_set_gpu_util(p, PROFILE_NONE);
    profile_set_tpu_version(p, PROFILE_NONE);
    profile_set_tpu_chips(p, 0);
    profile_set_gaudi_gen(p, PROFILE_NONE);
    profile_set_neuron_chip(p, PROFILE_NONE);
    profile_set_neuron_cores(p, 0);
    return p;
}

# --- Convenience constructors ---

fn profile_cpu(mem_bytes) {
    return profile_new(ACCEL_CPU, 0, mem_bytes);
}

fn profile_cuda(dev_id, vram_bytes) {
    return profile_new(ACCEL_CUDA, dev_id, vram_bytes);
}

fn profile_rocm(dev_id, vram_bytes) {
    return profile_new(ACCEL_ROCM, dev_id, vram_bytes);
}

fn profile_tpu(dev_id, chip_count, version) {
    var hbm = tpu_hbm_per_chip(version) * chip_count;
    var p = profile_new(ACCEL_TPU, dev_id, hbm);
    profile_set_tpu_version(p, version);
    profile_set_tpu_chips(p, chip_count);
    return p;
}

fn profile_gaudi(dev_id, gen) {
    var p = profile_new(ACCEL_GAUDI, dev_id, gaudi_hbm_bytes(gen));
    profile_set_gaudi_gen(p, gen);
    return p;
}

fn profile_neuron(dev_id, chip_type, core_count) {
    var mem = neuron_hbm_per_core(chip_type) * core_count;
    var p = profile_new(ACCEL_NEURON, dev_id, mem);
    profile_set_neuron_chip(p, chip_type);
    profile_set_neuron_cores(p, core_count);
    return p;
}

# --- Derived queries ---

# Get the accelerator family for this profile
fn profile_family(p) {
    return accel_family(profile_accel_type(p));
}

# Get throughput multiplier (x1000) for this profile
fn profile_throughput_x1000(p) {
    var at = profile_accel_type(p);
    if (at == ACCEL_TPU) { return tpu_throughput_x1000(profile_tpu_version(p)); }
    if (at == ACCEL_GAUDI) { return gaudi_throughput_x1000(profile_gaudi_gen(p)); }
    if (at == ACCEL_NEURON) {
        return neuron_throughput_x1000(
        profile_neuron_chip(p), profile_neuron_cores(p));
    }
    return accel_throughput_x1000(at);
}

# Get training multiplier (x1000) for this profile
fn profile_training_x1000(p) {
    var at = profile_accel_type(p);
    if (at == ACCEL_TPU) { return tpu_training_x1000(profile_tpu_version(p)); }
    if (at == ACCEL_GAUDI) { return gaudi_training_x1000(profile_gaudi_gen(p)); }
    if (at == ACCEL_NEURON) {
        return neuron_training_x1000(
        profile_neuron_chip(p), profile_neuron_cores(p));
    }
    return accel_training_x1000(at);
}

# Get rank for this profile (higher = preferred)
fn profile_rank(p) {
    var at = profile_accel_type(p);
    if (at == ACCEL_TPU) { return tpu_rank(profile_tpu_version(p)); }
    if (at == ACCEL_GAUDI) { return gaudi_rank(profile_gaudi_gen(p)); }
    if (at == ACCEL_NEURON) { return neuron_rank(profile_neuron_chip(p)); }
    if (at == ACCEL_GROQ) { return groq_rank(); }
    return accel_rank(at);
}

# Whether this profile supports training
fn profile_supports_training(p) {
    return profile_training_x1000(p) > 0;
}

# --- Quantization support ---

fn profile_supports_quant(p, quant) {
    var fam = profile_family(p);
    # CPU and GPU support all quant levels
    if (fam == FAMILY_CPU) { return 1; }
    if (fam == FAMILY_GPU) { return 1; }
    # NPU: INT8 and INT4 only
    if (fam == FAMILY_NPU) {
        if (quant == QUANT_INT8) { return 1; }
        if (quant == QUANT_INT4) { return 1; }
        return 0;
    }
    # TPU: FP32, BF16, INT8
    if (fam == FAMILY_TPU) {
        if (quant == QUANT_NONE) { return 1; }
        if (quant == QUANT_BF16) { return 1; }
        if (quant == QUANT_INT8) { return 1; }
        return 0;
    }
    # AI ASICs: device-specific
    var at = profile_accel_type(p);
    if (at == ACCEL_QUALCOMM) {
        if (quant == QUANT_FP16) { return 1; }
        if (quant == QUANT_INT8) { return 1; }
        if (quant == QUANT_INT4) { return 1; }
        return 0;
    }
    if (at == ACCEL_GROQ) {
        if (quant == QUANT_FP16) { return 1; }
        if (quant == QUANT_INT8) { return 1; }
        if (quant == QUANT_INT4) { return 1; }
        return 0;
    }
    if (at == ACCEL_GRAPHCORE) {
        if (quant == QUANT_NONE) { return 1; }
        if (quant == QUANT_FP16) { return 1; }
        if (quant == QUANT_INT8) { return 1; }
        return 0;
    }
    # Gaudi, Neuron, Cerebras: FP32, BF16, FP16, INT8
    if (quant == QUANT_NONE) { return 1; }
    if (quant == QUANT_BF16) { return 1; }
    if (quant == QUANT_FP16) { return 1; }
    if (quant == QUANT_INT8) { return 1; }
    return 0;
}

# Preferred quantization for this profile
fn profile_preferred_quant(p) {
    var fam = profile_family(p);
    if (fam == FAMILY_CPU) { return QUANT_FP16; }
    if (fam == FAMILY_GPU) { return QUANT_FP16; }
    if (fam == FAMILY_NPU) { return QUANT_INT8; }
    if (fam == FAMILY_TPU) { return QUANT_BF16; }
    # AI ASICs
    var at = profile_accel_type(p);
    if (at == ACCEL_GAUDI) { return QUANT_BF16; }
    if (at == ACCEL_NEURON) { return QUANT_BF16; }
    if (at == ACCEL_QUALCOMM) { return QUANT_INT8; }
    if (at == ACCEL_CEREBRAS) { return QUANT_BF16; }
    if (at == ACCEL_GRAPHCORE) { return QUANT_FP16; }
    if (at == ACCEL_GROQ) { return QUANT_INT8; }
    return QUANT_FP16;
}

# --- system_io.cyr ---

# system_io.cyr — system-level I/O topology
# Interconnects, storage devices, runtime environment, sharding types.

# --- Interconnect kind ---

enum InterconnectKind {
    ICK_INFINIBAND = 0;
    ICK_ROCE = 1;
    ICK_ROCEV2 = 2;
    ICK_NVLINK = 3;
    ICK_NVSWITCH = 4;
    ICK_XGMI = 5;
    ICK_ICI = 6;
    ICK_PCIE = 7;
}

fn ick_name(k) {
    if (k == ICK_INFINIBAND) { return "InfiniBand"; }
    if (k == ICK_ROCE) { return "RoCE"; }
    if (k == ICK_ROCEV2) { return "RoCE v2"; }
    if (k == ICK_NVLINK) { return "NVLink"; }
    if (k == ICK_NVSWITCH) { return "NVSwitch"; }
    if (k == ICK_XGMI) { return "XGMI"; }
    if (k == ICK_ICI) { return "ICI"; }
    if (k == ICK_PCIE) { return "PCIe"; }
    return "Unknown";
}

# Interconnect — port/device + bandwidth + state descriptor.
# Struct name `ic` matches the `ic_*` accessor convention; constructor
# stays the descriptive `interconnect_new`. 2.1.4: hand-rolled
# accessors replaced with #derive(accessors).

#derive(accessors)
struct ic {
    kind;
    name;
    bw_x1000;
    state;
}

var INTERCONNECT_SIZE = 32;

fn interconnect_new(kind, name, bw_x1000) {
    var ic = alloc(INTERCONNECT_SIZE);
    ic_set_kind(ic, kind);
    ic_set_name(ic, name);
    ic_set_bw_x1000(ic, bw_x1000);
    ic_set_state(ic, 0);
    return ic;
}

# --- Storage kind ---

enum StorageKind {
    STK_NVME = 0;
    STK_SATA_SSD = 1;
    STK_HDD = 2;
    STK_UNKNOWN = 3;
}

fn stk_name(k) {
    if (k == STK_NVME) { return "NVMe"; }
    if (k == STK_SATA_SSD) { return "SATA SSD"; }
    if (k == STK_HDD) { return "HDD"; }
    return "Unknown";
}

# StorageDevice — block device + bandwidth descriptor.
# 2.1.3: hand-rolled load64 accessors replaced with #derive(accessors).

#derive(accessors)
struct storage {
    name;
    kind;
    bw_x1000;
}

var STORAGE_SIZE = 24;

fn storage_new(name, kind, bw_x1000) {
    var sd = alloc(STORAGE_SIZE);
    storage_set_name(sd, name);
    storage_set_kind(sd, kind);
    storage_set_bw_x1000(sd, bw_x1000);
    return sd;
}

# --- Runtime environment ---
# 2.1.7: hand-rolled accessors replaced with #derive(accessors).
# Struct name `env` matches the `env_*` accessor convention; field
# names retain the `is_docker` / `is_k8s` semantics (sentinel: 0 for
# i64 fields means "not detected", 0 for ptr fields means cstr-null).
# Note: setter for `is_docker` is `env_set_is_docker` (derived from
# the field name); the legacy pre-derive name was `env_set_docker`.
# Same for `env_set_is_k8s` (was `env_set_k8s`). Detection code in
# environment.cyr was updated to the new names in this slot.

#derive(accessors)
struct env {
    is_docker;
    is_k8s;
    k8s_namespace;
    cloud_provider;
    instance_type;
    region;
    k8s_gpu_count;
    k8s_gpu_source;
}

var RUNTIME_ENV_SIZE = 64;

fn runtime_env_new() {
    var e = alloc(RUNTIME_ENV_SIZE);
    env_set_is_docker(e, 0);
    env_set_is_k8s(e, 0);
    env_set_k8s_namespace(e, 0);
    env_set_cloud_provider(e, 0);
    env_set_instance_type(e, 0);
    env_set_region(e, 0);
    env_set_k8s_gpu_count(e, 0);
    env_set_k8s_gpu_source(e, 0);
    return e;
}

# --- SystemIo container ---
# 2.1.7: hand-rolled accessors replaced with #derive(accessors).
# Struct name `sio` matches the existing `sio_*` accessor convention.
# Internal `load64(sio)` shortcuts in helpers below switched to the
# derived getters for consistency.

#derive(accessors)
struct sio {
    interconnects;
    storage;
    environment;
}

var SYSTEM_IO_SIZE = 24;

fn system_io_new() {
    var sio = alloc(SYSTEM_IO_SIZE);
    sio_set_interconnects(sio, vec_new());
    sio_set_storage(sio, vec_new());
    sio_set_environment(sio, 0);
    return sio;
}

fn sio_add_interconnect(sio, ic) {
    vec_push(sio_interconnects(sio), ic);
    return 0;
}

fn sio_add_storage(sio, sd) {
    vec_push(sio_storage(sio), sd);
    return 0;
}

fn sio_has_interconnect(sio) {
    return vec_len(sio_interconnects(sio)) > 0;
}

# Total interconnect bandwidth (x1000)
fn sio_total_ic_bw_x1000(sio) {
    var ics = sio_interconnects(sio);
    var total = 0;
    var n = vec_len(ics);
    for (var i = 0; i < n; i = i + 1) {
        total = total + ic_bw_x1000(vec_get(ics, i));
    }
    return total;
}

# Has NVSwitch?
fn sio_has_nvswitch(sio) {
    var ics = sio_interconnects(sio);
    var n = vec_len(ics);
    for (var i = 0; i < n; i = i + 1) {
        if (ic_kind(vec_get(ics, i)) == ICK_NVSWITCH) { return 1; }
    }
    return 0;
}

# Has NVLink?
fn sio_has_nvlink(sio) {
    var ics = sio_interconnects(sio);
    var n = vec_len(ics);
    for (var i = 0; i < n; i = i + 1) {
        var k = ic_kind(vec_get(ics, i));
        if (k == ICK_NVLINK) { return 1; }
        if (k == ICK_NVSWITCH) { return 1; }
    }
    return 0;
}

# Has ICI (TPU interconnect)?
fn sio_has_ici(sio) {
    var ics = sio_interconnects(sio);
    var n = vec_len(ics);
    for (var i = 0; i < n; i = i + 1) {
        if (ic_kind(vec_get(ics, i)) == ICK_ICI) { return 1; }
    }
    return 0;
}

# Max interconnect bandwidth (x1000) — used for sharding decisions
fn sio_max_ic_bw_x1000(sio) {
    var ics = sio_interconnects(sio);
    var best = 0;
    var n = vec_len(ics);
    for (var i = 0; i < n; i = i + 1) {
        var bw = ic_bw_x1000(vec_get(ics, i));
        if (bw > best) { best = bw; }
    }
    return best;
}

# --- Sharding strategy ---

enum ShardingStrategy {
    SHARD_NONE = 0;
    SHARD_PIPELINE = 1;
    SHARD_TENSOR = 2;
    SHARD_DATA = 3;
}

fn shard_strategy_name(s) {
    if (s == SHARD_NONE) { return "None"; }
    if (s == SHARD_PIPELINE) { return "Pipeline Parallel"; }
    if (s == SHARD_TENSOR) { return "Tensor Parallel"; }
    if (s == SHARD_DATA) { return "Data Parallel"; }
    return "Unknown";
}

# --- ModelShard ---
# 2.1.7: hand-rolled accessors replaced with #derive(accessors).
# Struct name `shard` matches the `shard_*` accessor convention;
# constructor stays `model_shard_new`. Field name `id` collides
# with the `shard_id` accessor only if read as `shard_id(ms)` —
# which is the actual accessor name we want, so the field is named
# `id` directly. Same for `layer_start` / `layer_end` etc.

#derive(accessors)
struct shard {
    id;
    layer_start;
    layer_end;
    device_type;
    device_id;
    memory_bytes;
}

var MODEL_SHARD_SIZE = 48;

fn model_shard_new(sid, lstart, lend, devtype, devid, membytes) {
    var ms = alloc(MODEL_SHARD_SIZE);
    shard_set_id(ms, sid);
    shard_set_layer_start(ms, lstart);
    shard_set_layer_end(ms, lend);
    shard_set_device_type(ms, devtype);
    shard_set_device_id(ms, devid);
    shard_set_memory_bytes(ms, membytes);
    return ms;
}

fn shard_num_layers(ms) {
    var s = shard_layer_start(ms);
    var e = shard_layer_end(ms);
    if (e >= s) { return e - s + 1; }
    return 0;
}

fn shard_is_valid(ms) {
    return shard_layer_start(ms) <= shard_layer_end(ms);
}

# ShardingPlan — sharding strategy + computed memory/throughput.
# Struct name `plan` matches the `plan_*` accessor convention;
# constructor stays the descriptive `sharding_plan_new`. The shards
# field carries a `vec` pointer (heterogeneous), initialised to a
# fresh empty vec by the constructor.
# 2.1.4: hand-rolled accessors replaced with #derive(accessors).

#derive(accessors)
struct plan {
    shards;
    strategy;
    strategy_count;
    total_memory;
    est_tps_x1000;
}

var SHARDING_PLAN_SIZE = 40;

fn sharding_plan_new(strategy, count) {
    var sp = alloc(SHARDING_PLAN_SIZE);
    plan_set_shards(sp, vec_new());
    plan_set_strategy(sp, strategy);
    plan_set_strategy_count(sp, count);
    plan_set_total_memory(sp, 0);
    plan_set_est_tps_x1000(sp, PROFILE_NONE);
    return sp;
}

fn plan_add_shard(sp, ms) {
    vec_push(load64(sp), ms);
    return 0;
}

fn plan_num_shards(sp) {
    return vec_len(load64(sp));
}

fn plan_min_devices(sp) {
    var s = plan_strategy(sp);
    if (s == SHARD_NONE) { return 1; }
    return plan_strategy_count(sp);
}

# --- platform.cyr ---

# platform.cyr — sysfs/procfs/devfs helpers for hardware detection
# Wrappers around io.cyr and fs.cyr for common detection patterns.

var SYSFS_MAX_READ = 4096;

# Read a sysfs/procfs file into a Str. Returns Str or 0 on error.
fn sysfs_read(path) {
    var buf = alloc(SYSFS_MAX_READ);
    var n = file_read_all(path, buf, SYSFS_MAX_READ);
    if (n <= 0) { return 0; }
    store8(buf + n, 0);
    # Trim trailing newline
    if (n > 0) {
        if (load8(buf + n - 1) == 10) { n = n - 1; }
    }
    return str_new(buf, n);
}

# Read a sysfs file as an integer. Returns value, or -1 on error.
fn sysfs_read_int(path) {
    var s = sysfs_read(path);
    if (s == 0) { return 0 - 1; }
    return str_to_int(s);
}

# Check if a path exists (file or directory)
fn path_exists(path) {
    return file_exists(path);
}

# Check if a directory exists
fn dir_exists(path) {
    var s = str_from(path);
    return is_dir(s);
}

# Read symlink target. Returns Str or 0.
# Uses readlink syscall (SYS_readlink = 89)
fn read_symlink(path) {
    var buf = alloc(256);
    var n = syscall(89, path, buf, 255);
    if (n <= 0) { return 0; }
    store8(buf + n, 0);
    return str_new(buf, n);
}

# Scan /dev/ for devices matching a prefix (e.g., "neuron", "accel").
# Returns vec of device IDs parsed from the suffix.
fn scan_dev_devices(prefix) {
    var ids = vec_new();
    var dev_dir = str_from("/dev");
    var entries = dir_list(dev_dir);
    var plen = strlen(prefix);
    var ei = 0;
    var nent = vec_len(entries);
    while (ei < nent) {
        var entry = vec_get(entries, ei);
        var elen = str_len(entry);
        var edata = str_data(entry);
        if (elen > plen) {
            if (memeq(edata, prefix, plen) == 1) {
                # Parse suffix as integer
                var suffix = str_sub(entry, plen, elen - plen);
                var id = str_to_int(suffix);
                if (id >= 0) {
                    vec_push(ids, id);
                }
            }
        }
        ei = ei + 1;
    }
    return ids;
}

# Check if any /dev/<prefix>* device exists
fn has_dev_device(prefix) {
    var ids = scan_dev_devices(prefix);
    return vec_len(ids) > 0;
}

# Parse `wmic computersystem get TotalPhysicalMemory` output (a
# `TotalPhysicalMemory=<bytes>` line) into a byte count. 0 if absent.
# Pure — Linux-testable. v2.3.7.
fn win_parse_total_memory(out) {
    var lines = str_split(out, 10);
    var nl = vec_len(lines);
    var i = 0;
    while (i < nl) {
        var line = str_trim(vec_get(lines, i));
        var ld = str_data(line);
        var ll = str_len(line);
        if (ll >= 20) {
            if (memeq(ld, "TotalPhysicalMemory=", 20) == 1) {
                return str_to_int(str_new(ld + 20, ll - 20));
            }
        }
        i = i + 1;
    }
    return 0;
}

# Get total system memory (in bytes). Windows: `wmic computersystem`
# via CreateProcessW spawn. Else: /proc/meminfo. Returns 0 on failure
# (caller substitutes a default).
fn detect_system_memory() {
    #ifdef CYRIUS_TARGET_WIN
    var wargs = vec_new();
    vec_push(wargs, "wmic");
    vec_push(wargs, "computersystem");
    vec_push(wargs, "get");
    vec_push(wargs, "TotalPhysicalMemory");
    vec_push(wargs, "/value");
    var wbuf = alloc(4096);
    var wn = exec_capture(wargs, wbuf, 4096);
    if (wn > 0) {
        store8(wbuf + wn, 0);
        return win_parse_total_memory(str_new(wbuf, wn));
    }
    return 0;
    #endif
    var buf = alloc(4096);
    var n = file_read_all("/proc/meminfo", buf, 4096);
    if (n <= 0) { return 0; }
    store8(buf + n, 0);
    # Find "MemTotal:" line, parse kB value
    var pos = 0;
    while (pos < n) {
        if (memeq(buf + pos, "MemTotal:", 9) == 1) {
            # Skip "MemTotal:" and whitespace
            pos = pos + 9;
            while (pos < n) {
                var c = load8(buf + pos);
                if (c != 32) { break; }
                pos = pos + 1;
            }
            # Parse number
            var kb = 0;
            while (pos < n) {
                var c2 = load8(buf + pos);
                if (c2 >= 48) {
                    if (c2 <= 57) {
                        kb = kb * 10 + c2 - 48;
                        pos = pos + 1;
                        continue;
                    }
                }
                break;
            }
            return kb * 1024;
        }
        # Skip to next line
        while (pos < n) {
            if (load8(buf + pos) == 10) { pos = pos + 1; break; }
            pos = pos + 1;
        }
    }
    return 0;
}

# List entries in a sysfs directory. Returns vec of Str names.
fn sysfs_list_dir(path) {
    var s = str_from(path);
    return dir_list(s);
}

# Build a sysfs path: base/entry/suffix
# Returns null-terminated C string (heap-allocated)
fn sysfs_path(base, entry, suffix) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, "/");
    if (entry != 0) {
        str_builder_add_cstr(sb, entry);
        if (suffix != 0) {
            str_builder_add_cstr(sb, "/");
        }
    }
    if (suffix != 0) {
        str_builder_add_cstr(sb, suffix);
    }
    var result = str_builder_build(sb);
    # Return null-terminated C string for syscall compatibility
    var clen = str_len(result);
    var cstr = alloc(clen + 1);
    memcpy(cstr, str_data(result), clen);
    store8(cstr + clen, 0);
    return cstr;
}

# Build sysfs path from Str components
fn sysfs_path_str(base, entry_str, suffix) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, base);
    str_builder_add_cstr(sb, "/");
    if (entry_str != 0) {
        str_builder_add(sb, entry_str);
        if (suffix != 0) {
            str_builder_add_cstr(sb, "/");
        }
    }
    if (suffix != 0) {
        str_builder_add_cstr(sb, suffix);
    }
    var result = str_builder_build(sb);
    var clen = str_len(result);
    var cstr = alloc(clen + 1);
    memcpy(cstr, str_data(result), clen);
    store8(cstr + clen, 0);
    return cstr;
}

# Parse a line containing a number with a suffix like "123 MB" or "456GB"
# Returns value in the base unit (MB stays MB, GB stays GB)
fn parse_value_with_suffix(s) {
    var slen = str_len(s);
    var sd = str_data(s);
    var num = 0;
    var pi = 0;
    # Skip leading whitespace
    while (pi < slen) {
        var c = load8(sd + pi);
        if (c != 32) { break; }
        pi = pi + 1;
    }
    # Parse digits
    while (pi < slen) {
        var c2 = load8(sd + pi);
        if (c2 >= 48) {
            if (c2 <= 57) {
                num = num * 10 + c2 - 48;
                pi = pi + 1;
                continue;
            }
        }
        break;
    }
    return num;
}

# --- command.cyr ---

# command.cyr — safe subprocess execution for hardware detection
# Wraps lib/process.cyr with:
#   - PATH resolution (absolute path)
#   - Environment sanitization (strip LD_PRELOAD etc.)
#   - Output size limits (1 MiB stdout)
#   - Timeout (via alarm signal — future enhancement)
#   - CSV parsing helpers
#   - Device ID validation

var CMD_MAX_STDOUT = 1048576;
var CMD_DEFAULT_TIMEOUT_MS = 5000;
var CMD_MAX_DEVICE_ID = 1024;

# Read an environment variable from /proc/self/environ.
# Returns heap-allocated null-terminated string, or 0 if not found.
# Note: works around io.cyr getenv bug (variable re-declaration in loop).
fn cmd_getenv(name) {
    var ebuf[8192];
    var fd = file_open("/proc/self/environ", 0, 0);
    if (fd < 0) { return 0; }
    var n = file_read(fd, &ebuf, 8192);
    file_close(fd);
    if (n <= 0) { return 0; }
    var nlen = strlen(name);
    var pos = 0;
    while (pos < n) {
        if (memeq(&ebuf + pos, name, nlen) == 1) {
            if (load8(&ebuf + pos + nlen) == 61) {
                var vstart = pos + nlen + 1;
                var vlen = 0;
                while (vstart + vlen < n) {
                    if (load8(&ebuf + vstart + vlen) == 0) { break; }
                    vlen = vlen + 1;
                }
                var result = alloc(vlen + 1);
                memcpy(result, &ebuf + vstart, vlen);
                store8(result + vlen, 0);
                return result;
            }
        }
        # Skip to next null-terminated entry
        while (pos < n) {
            if (load8(&ebuf + pos) == 0) { pos = pos + 1; break; }
            pos = pos + 1;
        }
    }
    return 0;
}

# Scan argv for `--data-dir <path>`, returning the path cstr or 0.
#
# Self-contained (argv/argc/streq, no dependency on main.cyr's parser) so
# it works on PE: argv is populated from GetCommandLineW/CommandLineToArgvW
# (cyrius PE reroutes 0xF006/0xF010), unlike environment variables, which
# cmd_getenv cannot read on PE — there is no /proc/self/environ and cyrius
# 6.2.11 exposes no GetEnvironmentVariable reroute (see data_file_path).
fn cmd_data_dir_arg() {
    var n = argc();
    var i = 1;
    while (i < n) {
        var a = argv(i);
        if (a != 0) {
            if (streq(a, "--data-dir") == 1) {
                if (i + 1 < n) { return argv(i + 1); }
                return 0;
            }
        }
        i = i + 1;
    }
    return 0;
}

# Resolve a data-file path. The binary reads VERSION (--version) and
# data/cloud_pricing.json (--cost) at runtime; invoked from outside the
# project root (e.g. a pip-installed wheel) those are not cwd-relative.
# Resolution precedence:
#   1. `--data-dir <path>` CLI flag — works on EVERY platform including
#      Windows PE, because argv is readable there. This is the portable
#      channel a consumer (Python _runner now, agnos later) should use.
#   2. AI_HWACCEL_DATA_DIR env var — honoured on Linux/macOS, but a SILENT
#      NO-OP on PE (cmd_getenv reads /proc/self/environ, absent on Windows;
#      cyrius has no env-read reroute). Kept for back-compat with consumers
#      that set it; the flag supersedes it where both are present.
#   3. cwd-relative <rel> — the original fallback.
# See roadmap 2.3.3 (env var) and 2.3.12 (the --data-dir flag for PE).
fn data_file_path(rel) {
    var dir = cmd_data_dir_arg();
    if (dir == 0) { dir = cmd_getenv("AI_HWACCEL_DATA_DIR"); }
    if (dir == 0) { return rel; }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, dir);
    str_builder_putc(sb, '/');
    str_builder_add_cstr(sb, rel);
    return str_data(str_builder_build(sb));
}

# Resolve tool name to absolute path by searching $PATH.
# Returns heap-allocated path string, or 0 if not found.
fn which(name) {
    var path_val = cmd_getenv("PATH");
    if (path_val == 0) { return 0; }
    var path_str = str_from(path_val);
    var dirs = str_split(path_str, 58);

    var di = 0;
    var ndir = vec_len(dirs);
    while (di < ndir) {
        var dir = vec_get(dirs, di);
        # Build candidate: dir/name
        var sb = str_builder_new();
        str_builder_add(sb, dir);
        str_builder_add_cstr(sb, "/");
        str_builder_add_cstr(sb, name);
        var candidate = str_builder_build(sb);
        # Check if file exists
        if (file_exists(str_data(candidate)) == 1) {
            # Return null-terminated copy
            var clen = str_len(candidate);
            var result = alloc(clen + 1);
            memcpy(result, str_data(candidate), clen);
            store8(result + clen, 0);
            return result;
        }
        di = di + 1;
    }
    return 0;
}

# Run a tool with up to 5 args. Returns Str with stdout, or 0 on error.
# Pushes a warning to the warnings vec on failure.
fn run_tool(tool, args, warnings) {
    var abs_path = which(tool);
    if (abs_path == 0) {
        if (warnings != 0) { vec_push(warnings, warning_tool_not_found(tool)); }
        return 0;
    }

    # Build exec args vec
    var exec_args = vec_new();
    vec_push(exec_args, abs_path);
    var ai = 0;
    var nargs = vec_len(args);
    while (ai < nargs) {
        vec_push(exec_args, vec_get(args, ai));
        ai = ai + 1;
    }

    # Capture stdout (1 MiB buffer)
    var buf = alloc(CMD_MAX_STDOUT);
    var n = exec_capture(exec_args, buf, CMD_MAX_STDOUT);

    if (n < 0) {
        if (warnings != 0) { vec_push(warnings, warning_tool_failed(tool, 0 - 1, "exec failed")); }
        return 0;
    }
    if (n == 0) {
        return str_new(buf, 0);
    }

    # Null-terminate
    store8(buf + n, 0);
    return str_new(buf, n);
}

# Convenience: run tool with string args (up to 5)
fn run_tool1(tool, arg1, warnings) {
    var args = vec_new();
    vec_push(args, arg1);
    return run_tool(tool, args, warnings);
}

fn run_tool2(tool, arg1, arg2, warnings) {
    var args = vec_new();
    vec_push(args, arg1);
    vec_push(args, arg2);
    return run_tool(tool, args, warnings);
}

fn run_tool3(tool, arg1, arg2, arg3, warnings) {
    var args = vec_new();
    vec_push(args, arg1);
    vec_push(args, arg2);
    vec_push(args, arg3);
    return run_tool(tool, args, warnings);
}

# --- CSV parsing helpers ---

# Split a line by commas into a vec of trimmed Str values.
# Returns vec, or 0 if fewer than min_fields.
fn parse_csv_line(line, min_fields) {
    var parts = str_split(line, 44);
    if (vec_len(parts) < min_fields) { return 0; }
    # Trim each field
    var trimmed = vec_new();
    var ci = 0;
    var nparts = vec_len(parts);
    while (ci < nparts) {
        vec_push(trimmed, str_trim(vec_get(parts, ci)));
        ci = ci + 1;
    }
    return trimmed;
}

# Parse an integer from a Str field. Returns value, or -1 on error.
fn parse_field_int(field) {
    return str_to_int(field);
}

# Validate device ID is in sane range (0-1024)
fn validate_device_id(raw_str) {
    var id = str_to_int(raw_str);
    if (id < 0) { return 0 - 1; }
    if (id > CMD_MAX_DEVICE_ID) { return 0 - 1; }
    return id;
}

# Validate memory in MB (0 to 16 TiB)
fn validate_memory_mb(raw_str) {
    var mb = str_to_int(raw_str);
    if (mb < 0) { return 0 - 1; }
    if (mb > 16 * 1024 * 1024) { return 0 - 1; }
    return mb;
}

# --- cuda.cyr ---

# cuda.cyr — NVIDIA CUDA GPU detection via nvidia-smi

# nvidia-smi query args
var _NVSMI_QUERY = "--query-gpu=index,memory.total,memory.used,memory.free,compute_cap,driver_version,name,temperature.gpu,power.draw,utilization.gpu,clocks.max.memory"; #skip-lint
var _NVSMI_FMT = "--format=csv,noheader,nounits";

# Bus width lookup by compute capability (bits)
fn nvidia_bus_width(cc) {
    var cclen = str_len(cc);
    var ccd = str_data(cc);
    # 9.0 = H100/H200 (5120-bit HBM3)
    if (cclen >= 3 && memeq(ccd, "9.0", 3) == 1) { return 5120; }
    # 8.9 = RTX 4090 (384-bit)
    if (cclen >= 3 && memeq(ccd, "8.9", 3) == 1) { return 384; }
    # 8.6 = RTX 3090/3080 (384-bit)
    if (cclen >= 3 && memeq(ccd, "8.6", 3) == 1) { return 384; }
    # 8.0 = A100 (5120-bit HBM2e)
    if (cclen >= 3 && memeq(ccd, "8.0", 3) == 1) { return 5120; }
    # 7.5 = T4/RTX 2080 (256-bit)
    if (cclen >= 3 && memeq(ccd, "7.5", 3) == 1) { return 256; }
    # 7.0 = V100 (4096-bit HBM2)
    if (cclen >= 3 && memeq(ccd, "7.0", 3) == 1) { return 4096; }
    # Default
    return 256;
}

# Estimate bandwidth from compute capability (GB/s * 1000)
fn nvidia_est_bw_x1000(cc) {
    var cclen = str_len(cc);
    var ccd = str_data(cc);
    if (cclen >= 3 && memeq(ccd, "9.0", 3) == 1) { return 3350000; }
    if (cclen >= 3 && memeq(ccd, "8.9", 3) == 1) { return 1008000; }
    if (cclen >= 3 && memeq(ccd, "8.6", 3) == 1) { return 936000; }
    if (cclen >= 3 && memeq(ccd, "8.0", 3) == 1) { return 2039000; }
    if (cclen >= 3 && memeq(ccd, "7.5", 3) == 1) { return 320000; }
    if (cclen >= 3 && memeq(ccd, "7.0", 3) == 1) { return 900000; }
    return 0;
}

# Parse nvidia-smi CSV output into profiles
fn parse_cuda_output(output, profiles, warnings) {
    var lines = str_split(output, 10);
    var li = 0;
    var nlines = vec_len(lines);
    while (li < nlines) {
        var line = vec_get(lines, li);
        li = li + 1;
        if (str_len(line) == 0) { continue; }

        var fields = parse_csv_line(line, 6);
        if (fields == 0) {
            vec_push(warnings, warning_parse("cuda", "too few CSV fields"));
            hwlog_warn("cuda: too few CSV fields");
            continue;
        }

        var f_id = vec_get(fields, 0);
        var dev_id = validate_device_id(f_id);
        if (dev_id < 0) {
            vec_push(warnings, warning_parse("cuda", "bad device id"));
            hwlog_warn("cuda: bad device id");
            continue;
        }

        var f_mem = vec_get(fields, 1);
        var mem_mb = validate_memory_mb(f_mem);
        if (mem_mb < 0) {
            vec_push(warnings, warning_parse("cuda", "bad memory"));
            hwlog_warn("cuda: bad memory");
            continue;
        }

        var mem_bytes = mem_mb * 1024 * 1024;
        var mem_used_mb = str_to_int(vec_get(fields, 2));
        var mem_free_mb = str_to_int(vec_get(fields, 3));

        var p = profile_cuda(dev_id, mem_bytes);

        # Compute capability (field 4)
        if (vec_len(fields) > 4) {
            var cc = vec_get(fields, 4);
            if (str_len(cc) > 0) {
                profile_set_compute_cap(p, str_cstr(cc));

                # Calculate memory bandwidth from clock + bus width
                if (vec_len(fields) > 10) {
                    var clock_str = vec_get(fields, 10);
                    var clock_mhz = str_to_int(clock_str);
                    if (clock_mhz > 0) {
                        var bw_bits = nvidia_bus_width(cc);
                        # BW = clock * bus_width * 2 (DDR) / 8 / 1000 (GB/s)
                        # Store as x1000
                        var bw_x1000 = clock_mhz * bw_bits * 2 / 8;
                        profile_set_mem_bw_x1000(p, bw_x1000);
                    }
                }
                # Fallback: estimate from CC
                if (profile_mem_bw_x1000(p) == PROFILE_NONE) {
                    var est = nvidia_est_bw_x1000(cc);
                    if (est > 0) { profile_set_mem_bw_x1000(p, est); }
                }
            }
        }

        # Driver version (field 5)
        if (vec_len(fields) > 5) {
            var dv = vec_get(fields, 5);
            if (str_len(dv) > 0) {
                profile_set_driver_version(p, str_cstr(dv));
            }
        }

        # GPU name (field 6)
        if (vec_len(fields) > 6) {
            var gn = vec_get(fields, 6);
            if (str_len(gn) > 0) {
                profile_set_device_name(p, str_cstr(gn));

                # Grace Hopper: add unified CPU+GPU memory
                if (str_contains_cstr(gn, "GH200") == 1) {
                    if (mem_bytes > 80 * BYTES_PER_GIB) {
                        if (mem_bytes < 100 * BYTES_PER_GIB) {
                            # Add 480 GB unified LPDDR5X
                            profile_set_memory_bytes(p, mem_bytes + 480 * BYTES_PER_GIB);
                        }
                    }
                }
            }
        }

        # Memory usage
        if (mem_used_mb > 0) { profile_set_mem_used(p, mem_used_mb * 1024 * 1024); }
        if (mem_free_mb > 0) { profile_set_mem_free(p, mem_free_mb * 1024 * 1024); }

        # Temperature (field 7)
        if (vec_len(fields) > 7) {
            var tc = str_to_int(vec_get(fields, 7));
            if (tc > 0) { profile_set_temp_c(p, tc); }
        }

        # Power (field 8) — integer watts (losing decimal precision, acceptable)
        if (vec_len(fields) > 8) {
            var pw = str_to_int(vec_get(fields, 8));
            if (pw > 0) { profile_set_power_x1000(p, pw * 1000); }
        }

        # GPU utilization (field 9)
        if (vec_len(fields) > 9) {
            var gu = str_to_int(vec_get(fields, 9));
            if (gu >= 0) { profile_set_gpu_util(p, gu); }
        }

        vec_push(profiles, p);
    }
    return 0;
}

# Detect CUDA GPUs
fn detect_cuda(profiles, warnings) {
    var result = run_tool2("nvidia-smi", _NVSMI_QUERY, _NVSMI_FMT, warnings);
    if (result == 0) { return 0; }
    parse_cuda_output(result, profiles, warnings);
    return 0;
}

# --- rocm.cyr ---

# rocm.cyr — AMD ROCm GPU detection via sysfs

fn detect_rocm(profiles, warnings) {
    var drm_dir = str_from("/sys/class/drm");
    var entries = dir_list(drm_dir);
    var nent = vec_len(entries);
    var dev_id = 0;

    var ei = 0;
    while (ei < nent) {
        var name = vec_get(entries, ei);
        ei = ei + 1;

        # Must start with "card" and not contain '-' (skip card0-DP-1 etc.)
        if (str_starts_with(name, "card") != 1) { continue; }
        if (str_index_of(name, 45) >= 0) { continue; }

        # Check driver is amdgpu
        var dev_path = sysfs_path_str("/sys/class/drm", name, "device/driver");
        var driver_link = read_symlink(dev_path);
        if (driver_link == 0) { continue; }
        # Driver link target basename should be "amdgpu"
        var drv_base = path_basename(driver_link);
        var drv_data = str_data(drv_base);
        if (memeq(drv_data, "amdgpu", 6) != 1) { continue; }

        # Read VRAM total
        var vram_path = sysfs_path_str("/sys/class/drm", name, "device/mem_info_vram_total");
        var mem_total = sysfs_read_int(vram_path);
        if (mem_total <= 0) { mem_total = 8 * BYTES_PER_GIB; }

        # Read VRAM used
        var used_path = sysfs_path_str("/sys/class/drm", name, "device/mem_info_vram_used");
        var mem_used = sysfs_read_int(used_path);

        var p = profile_rocm(dev_id, mem_total);

        # Device name: prefer the kernel-exposed product_name (newer
        # amdgpu drivers populate it for discrete cards); otherwise
        # build a synthesized "AMD Radeon (PCI vendor:device)" string
        # from the sysfs vendor + device files, which always exist.
        # Worst case (both missing) we fall through to "AMD Radeon".
        # This closes the 2.2.5 gap where ROCm GPUs reported a null
        # device name (mihi 0.4.0 smoke showed "(unnamed)").
        var prod_path = sysfs_path_str("/sys/class/drm", name, "device/product_name");
        var prod = sysfs_read(prod_path);
        if (prod != 0 && str_len(prod) > 0) {
            profile_set_device_name(p, str_cstr(prod));
        } else {
            var vendor_path = sysfs_path_str("/sys/class/drm", name, "device/vendor");
            var device_path = sysfs_path_str("/sys/class/drm", name, "device/device");
            var vendor_s = sysfs_read(vendor_path);
            var device_s = sysfs_read(device_path);
            if (vendor_s != 0 && device_s != 0) {
                # Build "AMD Radeon (PCI 0x1002:0x1638)" — vendor + device
                # files come prefixed with "0x" already.
                var sb = str_builder_new();
                str_builder_add_cstr(sb, "AMD Radeon (PCI ");
                str_builder_add(sb, vendor_s);
                str_builder_add_cstr(sb, ":");
                str_builder_add(sb, device_s);
                str_builder_add_cstr(sb, ")");
                var nm = str_builder_build(sb);
                profile_set_device_name(p, str_data(nm));
            } else {
                profile_set_device_name(p, "AMD Radeon");
            }
        }

        if (mem_used > 0) {
            profile_set_mem_used(p, mem_used);
            profile_set_mem_free(p, mem_total - mem_used);
        }

        # Temperature from hwmon (millidegrees C)
        var hwmon_base = sysfs_path_str("/sys/class/drm", name, "device/hwmon");
        var hwmon_entries = dir_list(str_from(hwmon_base));
        if (vec_len(hwmon_entries) > 0) {
            var hw_name = vec_get(hwmon_entries, 0);
            var temp_path = sysfs_path_str(hwmon_base, hw_name, "temp1_input");
            var millideg = sysfs_read_int(temp_path);
            if (millideg > 0) { profile_set_temp_c(p, millideg / 1000); }

            # Power (microwatts)
            var pow_path = sysfs_path_str(hwmon_base, hw_name, "power1_average");
            var microwatts = sysfs_read_int(pow_path);
            if (microwatts <= 0) {
                var pow_path2 = sysfs_path_str(hwmon_base, hw_name, "power1_input");
                microwatts = sysfs_read_int(pow_path2);
            }
            if (microwatts > 0) { profile_set_power_x1000(p, microwatts / 1000); }
        }

        # GPU busy percent
        var busy_path = sysfs_path_str("/sys/class/drm", name, "device/gpu_busy_percent");
        var gpu_busy = sysfs_read_int(busy_path);
        if (gpu_busy >= 0) { profile_set_gpu_util(p, gpu_busy); }

        # VBIOS version as driver_version
        var vbios_path = sysfs_path_str("/sys/class/drm", name, "device/vbios_version");
        var vbios = sysfs_read(vbios_path);
        if (vbios != 0) {
            if (str_len(vbios) > 0) {
                profile_set_driver_version(p, str_cstr(vbios));
            }
        }

        # Compute capability from revision
        var rev_path = sysfs_path_str("/sys/class/drm", name, "device/revision");
        var rev = sysfs_read(rev_path);
        if (rev != 0) {
            if (str_len(rev) > 0) {
                profile_set_compute_cap(p, str_cstr(rev));
            }
        }

        # CXL memory detection (MI300X/MI350)
        var vis_path = sysfs_path_str("/sys/class/drm", name, "device/mem_info_vis_vram_total");
        var vis_total = sysfs_read_int(vis_path);
        if (vis_total > mem_total) {
            # CXL memory detected — add to total
            profile_set_memory_bytes(p, vis_total);
        }

        vec_push(profiles, p);
        dev_id = dev_id + 1;
    }
    return 0;
}

# --- tpu.cyr ---

# tpu.cyr — Google TPU detection via sysfs

fn detect_tpu(profiles, warnings) {
    var accel_dir = str_from("/sys/class/accel");
    var entries = dir_list(accel_dir);
    var nent = vec_len(entries);

    var ei = 0;
    while (ei < nent) {
        var name = vec_get(entries, ei);
        ei = ei + 1;

        # Must start with "accel"
        if (str_starts_with(name, "accel") != 1) { continue; }

        # Skip AMD XDNA devices (check driver)
        var drv_path = sysfs_path_str("/sys/class/accel", name, "device/driver");
        var drv_link = read_symlink(drv_path);
        if (drv_link != 0) {
            var drv_base = path_basename(drv_link);
            if (memeq(str_data(drv_base), "amdxdna", 7) == 1) { continue; }
        }

        # Parse device ID from "accelN"
        var dev_id_str = str_sub(name, 5, str_len(name) - 5);
        var dev_id = str_to_int(dev_id_str);
        if (dev_id < 0) { continue; }

        # Read TPU version
        var ver_path = sysfs_path_str("/sys/class/accel", name, "device/tpu_version");
        var ver_str = sysfs_read(ver_path);
        var version = TPU_V4;
        if (ver_str != 0) {
            if (str_contains_cstr(ver_str, "v5p") == 1) { version = TPU_V5P; }
            elif (str_contains_cstr(ver_str, "v5e") == 1) { version = TPU_V5E; }
            elif (str_contains_cstr(ver_str, "v5litepod") == 1) { version = TPU_V5E; }
        }

        # Read chip count
        var chip_path = sysfs_path_str("/sys/class/accel", name, "device/chip_count");
        var chip_count = sysfs_read_int(chip_path);
        if (chip_count <= 0) { chip_count = 1; }

        var p = profile_tpu(dev_id, chip_count, version);
        # Device name: "Google TPU v4" / "v5e" / "v5p" via the
        # version-enum → string helper. 2.2.5 left this null.
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "Google TPU ");
        str_builder_add_cstr(sb, tpu_version_name(version));
        var tnm = str_builder_build(sb);
        profile_set_device_name(p, str_data(tnm));
        vec_push(profiles, p);
    }
    return 0;
}

# --- gaudi.cyr ---

# gaudi.cyr — Intel Gaudi (Habana Labs) detection via hl-smi

var _HLSMI_QUERY = "--query-aip=index,name,memory.total,memory.free";
var _HLSMI_FMT = "--format=csv,noheader,nounits";

fn detect_gaudi(profiles, warnings) {
    var result = run_tool2("hl-smi", _HLSMI_QUERY, _HLSMI_FMT, warnings);
    if (result == 0) { return 0; }

    var lines = str_split(result, 10);
    var li = 0;
    var nlines = vec_len(lines);
    while (li < nlines) {
        var line = vec_get(lines, li);
        li = li + 1;
        if (str_len(line) == 0) { continue; }

        var fields = parse_csv_line(line, 3);
        if (fields == 0) {
            vec_push(warnings, warning_parse("gaudi", "too few CSV fields"));
            hwlog_warn("gaudi: too few CSV fields");
            continue;
        }

        var dev_id = str_to_int(vec_get(fields, 0));
        if (dev_id < 0) { dev_id = 0; }

        # Determine generation from device name
        var gen = GAUDI2;
        var name_field = vec_get(fields, 1);
        var name_lower = str_data(name_field);
        var name_len = str_len(name_field);
        # Check for "gaudi3" or "hl-325" in name
        if (name_len >= 6) {
            if (str_contains_cstr(name_field, "gaudi3") == 1) { gen = GAUDI3; }
            elif (str_contains_cstr(name_field, "Gaudi3") == 1) { gen = GAUDI3; }
            elif (str_contains_cstr(name_field, "HL-325") == 1) { gen = GAUDI3; }
            elif (str_contains_cstr(name_field, "hl-325") == 1) { gen = GAUDI3; }
        }

        # Memory in MB
        var mem_mb = str_to_int(vec_get(fields, 2));
        if (mem_mb <= 0) { mem_mb = gaudi_hbm_bytes(gen) / (1024 * 1024); }

        var p = profile_gaudi(dev_id, gen);
        # Override memory from hl-smi if available
        profile_set_memory_bytes(p, mem_mb * 1024 * 1024);

        # Device name: prefer the hl-smi CSV "name" field (e.g.
        # "HL-225" / "HL-325") when present; otherwise synthesize
        # "Intel Gaudi2" / "Intel Gaudi3" from the generation enum.
        # name_field is a str_split slice (not guaranteed null-
        # terminated), so str_cstr copies out an owned NUL-terminated
        # buffer.
        if (str_len(name_field) > 0) {
            profile_set_device_name(p, str_cstr(name_field));
        } else {
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "Intel ");
            str_builder_add_cstr(sb, gaudi_gen_name(gen));
            var gnm = str_builder_build(sb);
            profile_set_device_name(p, str_data(gnm));
        }

        vec_push(profiles, p);
    }
    return 0;
}

# --- neuron.cyr ---

# neuron.cyr — AWS Inferentia/Trainium detection via neuron-ls + sysfs fallback

fn detect_neuron(profiles, warnings) {
    # Try neuron-ls --json-output first
    var result = run_tool1("neuron-ls", "--json-output", warnings);
    if (result != 0) {
        if (str_len(result) > 2) {
            _parse_neuron_json(result, profiles);
            return 0;
        }
    }

    # Fallback: scan /dev/neuron*
    var ids = scan_dev_devices("neuron");
    if (vec_len(ids) == 0) { return 0; }

    # Detect chip type from DMI product name
    var chip = NEURON_INFERENTIA;
    var dmi = sysfs_read("/sys/devices/virtual/dmi/id/product_name");
    if (dmi != 0) {
        if (str_contains_cstr(dmi, "trn") == 1) { chip = NEURON_TRAINIUM; }
        elif (str_contains_cstr(dmi, "Trn") == 1) { chip = NEURON_TRAINIUM; }
    }

    var ni = 0;
    var nids = vec_len(ids);
    while (ni < nids) {
        var dev_id = vec_get(ids, ni);
        var p = profile_neuron(dev_id, chip, 2);
        # Device name: "AWS Inferentia" / "AWS Trainium" via the
        # chip-enum → string helper. 2.2.5 left this null.
        var sb = str_builder_new();
        str_builder_add_cstr(sb, "AWS ");
        str_builder_add_cstr(sb, neuron_chip_name(chip));
        var nnm = str_builder_build(sb);
        profile_set_device_name(p, str_data(nnm));
        vec_push(profiles, p);
        ni = ni + 1;
    }
    return 0;
}

# Parse neuron-ls JSON output (simplified — extract model, nc_count, memory)
# JSON format: [{"model":"trn1","nc_count":2,"memory_per_nc_mb":32768},...]
fn _parse_neuron_json(output, profiles) {
    var data = str_data(output);
    var dlen = str_len(output);
    var pos = 0;

    while (pos < dlen) {
        # Find next "model"
        var found_model = 0;
        while (pos < dlen - 7) {
            if (memeq(data + pos, "\"model\"", 7) == 1) { found_model = 1; break; }
            pos = pos + 1;
        }
        if (found_model == 0) { break; }

        # Determine chip type from model value
        var chip = NEURON_INFERENTIA;
        # Scan ahead for "trn" in the model value
        var scan = pos;
        var scan_end = pos + 50;
        if (scan_end > dlen) { scan_end = dlen; }
        while (scan < scan_end) {
            if (memeq(data + scan, "trn", 3) == 1) { chip = NEURON_TRAINIUM; break; }
            if (memeq(data + scan, "Trn", 3) == 1) { chip = NEURON_TRAINIUM; break; }
            scan = scan + 1;
        }

        # Find nc_count
        var cores = 2;
        var nc_scan = pos;
        var nc_end = pos + 200;
        if (nc_end > dlen) { nc_end = dlen; }
        while (nc_scan < nc_end - 10) {
            if (memeq(data + nc_scan, "\"nc_count\"", 10) == 1) {
                # Find the colon then the number
                var ns = nc_scan + 10;
                while (ns < nc_end) {
                    var c = load8(data + ns);
                    if (c >= 48) {
                        if (c <= 57) {
                            # Parse number
                            var num = 0;
                            while (ns < nc_end) {
                                var d = load8(data + ns);
                                if (d >= 48) {
                                    if (d <= 57) { num = num * 10 + d - 48; ns = ns + 1; continue; }
                                }
                                break;
                            }
                            cores = num;
                            break;
                        }
                    }
                    ns = ns + 1;
                }
                break;
            }
            nc_scan = nc_scan + 1;
        }

        var dev_id = vec_len(profiles);
        var p = profile_neuron(dev_id, chip, cores);
        # Device name: "AWS Inferentia" / "AWS Trainium" — same shape
        # as the sysfs-fallback path. 2.2.5 left this null too.
        var jnm_sb = str_builder_new();
        str_builder_add_cstr(jnm_sb, "AWS ");
        str_builder_add_cstr(jnm_sb, neuron_chip_name(chip));
        var jnm = str_builder_build(jnm_sb);
        profile_set_device_name(p, str_data(jnm));
        vec_push(profiles, p);

        pos = pos + 10;
    }
    return 0;
}

# --- vulkan.cyr ---

# vulkan.cyr — Vulkan GPU detection via vulkaninfo + sysfs fallback

fn detect_vulkan(profiles, warnings) {
    # Try vulkaninfo --summary first
    var result = run_tool1("vulkaninfo", "--summary", warnings);
    if (result != 0) {
        if (str_len(result) > 10) {
            _parse_vulkaninfo(result, profiles);
            return 0;
        }
    }

    # Fallback: sysfs PCI device scan
    _detect_vulkan_sysfs(profiles);
    return 0;
}

# Parse vulkaninfo --summary output
fn _parse_vulkaninfo(output, profiles) {
    var lines = str_split(output, 10);
    var nlines = vec_len(lines);
    var dev_id = 0;
    var li = 0;

    while (li < nlines) {
        var line = vec_get(lines, li);
        li = li + 1;

        # Look for "deviceName" lines
        if (str_contains_cstr(line, "deviceName") != 1) { continue; }

        # Extract device name after "= "
        var eq_pos = str_index_of(line, 61);
        if (eq_pos < 0) { continue; }
        var name_part = str_trim(str_sub(line, eq_pos + 1, str_len(line) - eq_pos - 1));
        if (str_len(name_part) == 0) { continue; }

        # Create profile with estimated VRAM
        var p = profile_new(ACCEL_VULKAN, dev_id, 4 * BYTES_PER_GIB);

        profile_set_device_name(p, str_cstr(name_part));

        # Look for memory size in nearby lines
        var mi = li;
        var mem_end = li + 10;
        if (mem_end > nlines) { mem_end = nlines; }
        while (mi < mem_end) {
            var mline = vec_get(lines, mi);
            mi = mi + 1;
            if (str_contains_cstr(mline, "heapSize") == 1) {
                # Extract number after "= "
                var meq = str_index_of(mline, 61);
                if (meq >= 0) {
                    var mval = str_trim(str_sub(mline, meq + 1, str_len(mline) - meq - 1));
                    var mem_bytes = str_to_int(mval);
                    if (mem_bytes > 0) {
                        profile_set_memory_bytes(p, mem_bytes);
                        break;
                    }
                }
            }
        }

        vec_push(profiles, p);
        dev_id = dev_id + 1;
    }
    return 0;
}

# Sysfs fallback: scan /sys/class/drm/card*/device/{vendor,device}
fn _detect_vulkan_sysfs(profiles) {
    var drm_dir = str_from("/sys/class/drm");
    var entries = dir_list(drm_dir);
    var nent = vec_len(entries);
    var dev_id = 0;

    var ei = 0;
    while (ei < nent) {
        var name = vec_get(entries, ei);
        ei = ei + 1;
        if (str_starts_with(name, "card") != 1) { continue; }
        if (str_index_of(name, 45) >= 0) { continue; }

        var vendor_path = sysfs_path_str("/sys/class/drm", name, "device/vendor");
        var vendor_str = sysfs_read(vendor_path);
        if (vendor_str == 0) { continue; }

        # Check for known GPU vendors
        var vdata = str_data(vendor_str);
        var vlen = str_len(vendor_str);
        var is_gpu = 0;
        var gpu_name = "Unknown GPU";
        var est_vram = 4 * BYTES_PER_GIB;

        # NVIDIA: 0x10de
        if (str_contains_cstr(vendor_str, "0x10de") == 1) {
            is_gpu = 1;
            gpu_name = "NVIDIA GPU (Vulkan)";
        }
        # AMD: 0x1002
        elif (str_contains_cstr(vendor_str, "0x1002") == 1) {
            is_gpu = 1;
            gpu_name = "AMD GPU (Vulkan)";
            # Try reading actual VRAM
            var vram_path = sysfs_path_str("/sys/class/drm", name, "device/mem_info_vram_total");
            var vram = sysfs_read_int(vram_path);
            if (vram > 0) { est_vram = vram; }
        }
        # Intel: 0x8086
        elif (str_contains_cstr(vendor_str, "0x8086") == 1) {
            is_gpu = 1;
            gpu_name = "Intel GPU (Vulkan)";
            est_vram = 2 * BYTES_PER_GIB;
        }

        if (is_gpu == 1) {
            var p = profile_new(ACCEL_VULKAN, dev_id, est_vram);
            profile_set_device_name(p, gpu_name);
            vec_push(profiles, p);
            dev_id = dev_id + 1;
        }
    }
    return 0;
}

# --- apple.cyr ---

# apple.cyr — Apple Metal GPU + Neural Engine detection
# macOS: system_profiler parsing
# Linux (Asahi): /proc/device-tree/compatible check

fn detect_apple(profiles, warnings) {
    # Try macOS detection first
    var hw = run_tool1("system_profiler", "SPHardwareDataType", warnings);
    if (hw != 0) {
        if (str_len(hw) > 0) {
            _parse_apple_macos(hw, profiles);
            return 0;
        }
    }

    # Linux Asahi fallback
    var compat = sysfs_read("/proc/device-tree/compatible");
    if (compat != 0) {
        if (str_contains_cstr(compat, "apple") == 1) {
            # Detect system memory for Metal GPU
            var sys_mem = detect_system_memory();
            if (sys_mem == 0) { sys_mem = 8 * BYTES_PER_GIB; }
            var p = profile_new(ACCEL_METAL, 0, sys_mem);
            profile_set_device_name(p, "Apple Silicon (Asahi Linux)");
            vec_push(profiles, p);

            # Apple Neural Engine (ANE)
            var ane = profile_new(ACCEL_APPLE_NPU, 0, 4 * BYTES_PER_GIB);
            profile_set_device_name(ane, "Apple Neural Engine");
            vec_push(profiles, ane);
        }
    }
    return 0;
}

fn _parse_apple_macos(hw_output, profiles) {
    var lines = str_split(hw_output, 10);
    var nlines = vec_len(lines);
    var chip_name = "Apple Silicon";
    var mem_bytes = 8 * BYTES_PER_GIB;
    var ane_mem = 4 * BYTES_PER_GIB;

    var li = 0;
    while (li < nlines) {
        var line = vec_get(lines, li);
        li = li + 1;

        # Chip name: "Chip: Apple M4 Pro"
        if (str_contains_cstr(line, "Chip:") == 1) {
            var col = str_index_of(line, 58);
            if (col >= 0) {
                var cn = str_trim(str_sub(line, col + 1, str_len(line) - col - 1));
                if (str_len(cn) > 0) {
                    chip_name = str_cstr(cn);

                    # ANE memory estimate by chip generation
                    if (str_contains_cstr(cn, "M4") == 1) { ane_mem = 8 * BYTES_PER_GIB; }
                    elif (str_contains_cstr(cn, "M3") == 1) { ane_mem = 8 * BYTES_PER_GIB; }
                    elif (str_contains_cstr(cn, "M2") == 1) { ane_mem = 6 * BYTES_PER_GIB; }
                }
            }
        }

        # Memory: "Memory: 36 GB"
        if (str_contains_cstr(line, "Memory:") == 1) {
            var mcol = str_index_of(line, 58);
            if (mcol >= 0) {
                var mval = str_trim(str_sub(line, mcol + 1, str_len(line) - mcol - 1));
                var val = parse_value_with_suffix(mval);
                if (val > 0) { mem_bytes = val * BYTES_PER_GIB; }
            }
        }
    }

    var gpu = profile_new(ACCEL_METAL, 0, mem_bytes);
    profile_set_device_name(gpu, chip_name);
    vec_push(profiles, gpu);

    var ane = profile_new(ACCEL_APPLE_NPU, 0, ane_mem);
    profile_set_device_name(ane, "Apple Neural Engine");
    vec_push(profiles, ane);
    return 0;
}

# --- intel.cyr ---

# intel.cyr — Intel NPU + Intel oneAPI GPU detection

# Intel NPU (Meteor Lake+): simple sysfs check
fn detect_intel_npu(profiles, warnings) {
    if (path_exists("/sys/class/misc/intel_npu") == 1) {
        var p = profile_new(ACCEL_INTEL_NPU, 0, 2 * BYTES_PER_GIB);
        profile_set_device_name(p, "Intel NPU");
        vec_push(profiles, p);
    }
    return 0;
}

# Intel oneAPI (Arc / Data Center GPU Max): xpu-smi CLI
fn detect_intel_oneapi(profiles, warnings) {
    var result = run_tool2("xpu-smi", "discovery", "--dump 1,2,18,19", warnings);
    if (result == 0) { return 0; }

    var lines = str_split(result, 10);
    var nlines = vec_len(lines);
    var li = 0;
    while (li < nlines) {
        var line = vec_get(lines, li);
        li = li + 1;
        if (str_len(line) == 0) { continue; }
        # Skip header lines
        if (str_contains_cstr(line, "DeviceId") == 1) { continue; }

        var fields = parse_csv_line(line, 2);
        if (fields == 0) { continue; }

        var dev_id = str_to_int(vec_get(fields, 0));
        if (dev_id < 0) { dev_id = 0; }

        # Memory field (MB) — usually field 2 or 3
        var mem_bytes = 16 * BYTES_PER_GIB;
        if (vec_len(fields) > 2) {
            var mem_mb = str_to_int(vec_get(fields, 2));
            if (mem_mb > 0) { mem_bytes = mem_mb * 1024 * 1024; }
        }

        var p = profile_new(ACCEL_INTEL_ONEAPI, dev_id, mem_bytes);

        # Device name from field 1
        if (vec_len(fields) > 1) {
            var nm = vec_get(fields, 1);
            if (str_len(nm) > 0) {
                profile_set_device_name(p, str_cstr(nm));
            }
        }

        vec_push(profiles, p);
    }
    return 0;
}

# --- amd_xdna.cyr ---

# amd_xdna.cyr — AMD Ryzen AI NPU detection via sysfs

fn detect_amd_xdna(profiles, warnings) {
    var accel_dir = str_from("/sys/class/accel");
    var entries = dir_list(accel_dir);
    var nent = vec_len(entries);

    var ei = 0;
    while (ei < nent) {
        var name = vec_get(entries, ei);
        ei = ei + 1;
        if (str_starts_with(name, "accel") != 1) { continue; }

        # Check driver is amdxdna
        var drv_path = sysfs_path_str("/sys/class/accel", name, "device/driver");
        var drv_link = read_symlink(drv_path);
        if (drv_link == 0) { continue; }
        var drv_base = path_basename(drv_link);
        if (memeq(str_data(drv_base), "amdxdna", 7) != 1) { continue; }

        var dev_id_str = str_sub(name, 5, str_len(name) - 5);
        var dev_id = str_to_int(dev_id_str);
        if (dev_id < 0) { dev_id = 0; }

        var p = profile_new(ACCEL_AMD_XDNA, dev_id, 2 * BYTES_PER_GIB);
        profile_set_device_name(p, "AMD Ryzen AI NPU");
        vec_push(profiles, p);
    }
    return 0;
}

# --- edge.cyr ---

# edge.cyr — edge/mobile NPU detectors
# Qualcomm Cloud AI 100, Samsung Exynos NPU, MediaTek APU (MDLA)

fn detect_qualcomm(profiles, warnings) {
    var found = 0;
    if (path_exists("/sys/class/qaic") == 1) { found = 1; }
    if (found == 0) {
        if (has_dev_device("qaic_") == 1) { found = 1; }
    }
    if (found == 1) {
        var p = profile_new(ACCEL_QUALCOMM, 0, 32 * BYTES_PER_GIB);
        profile_set_device_name(p, "Qualcomm Cloud AI 100");
        profile_set_compute_cap(p, "AI 100");
        vec_push(profiles, p);
    }
    return 0;
}

fn detect_samsung_npu(profiles, warnings) {
    var found = 0;
    if (path_exists("/sys/class/misc/samsung_npu") == 1) { found = 1; }
    if (found == 0) {
        if (has_dev_device("samsung_npu") == 1) { found = 1; }
    }
    if (found == 1) {
        var p = profile_new(ACCEL_SAMSUNG_NPU, 0, 2 * BYTES_PER_GIB);
        profile_set_device_name(p, "Samsung Exynos NPU");
        profile_set_compute_cap(p, "Exynos AI");
        vec_push(profiles, p);
    }
    return 0;
}

fn detect_mediatek_apu(profiles, warnings) {
    var found = 0;
    if (path_exists("/sys/class/misc/mtk_apu") == 1) { found = 1; }
    if (found == 0) {
        if (has_dev_device("mtk_mdla") == 1) { found = 1; }
    }
    if (found == 1) {
        var p = profile_new(ACCEL_MEDIATEK_APU, 0, 2 * BYTES_PER_GIB);
        profile_set_device_name(p, "MediaTek APU");
        profile_set_compute_cap(p, "MDLA");
        vec_push(profiles, p);
    }
    return 0;
}

# --- cloud_asic.cyr ---

# cloud_asic.cyr — cloud/datacenter AI ASIC detectors
# Cerebras WSE, Graphcore IPU, Groq LPU

fn detect_cerebras(profiles, warnings) {
    # Try CLI first
    var result = run_tool1("cerebras_cli", "system-info", warnings);
    if (result != 0) {
        if (str_len(result) > 0) {
            var mem_gb = 44;
            # Parse memory from output if available
            var lines = str_split(result, 10);
            var li = 0;
            while (li < vec_len(lines)) {
                var line = vec_get(lines, li);
                li = li + 1;
                if (str_contains_cstr(line, "memory") == 1) {
                    var val = parse_value_with_suffix(line);
                    if (val > 0) { mem_gb = val; }
                }
            }
            var p = profile_new(ACCEL_CEREBRAS, 0, mem_gb * BYTES_PER_GIB);
            profile_set_device_name(p, "Cerebras WSE");
            vec_push(profiles, p);
            return 0;
        }
    }

    # Fallback: /dev/cerebras* check
    if (has_dev_device("cerebras") == 1) {
        var p = profile_new(ACCEL_CEREBRAS, 0, 44 * BYTES_PER_GIB);
        profile_set_device_name(p, "Cerebras WSE");
        vec_push(profiles, p);
    }
    return 0;
}

fn detect_graphcore(profiles, warnings) {
    # Try gc-info CLI
    var result = run_tool3("gc-info", "-d", "0", "-i", warnings);
    if (result != 0) {
        if (str_len(result) > 0) {
            var mem_mb = 900;
            var lines = str_split(result, 10);
            var li = 0;
            while (li < vec_len(lines)) {
                var line = vec_get(lines, li);
                li = li + 1;
                if (str_contains_cstr(line, "memory") == 1) {
                    var val = parse_value_with_suffix(line);
                    if (val > 0) { mem_mb = val; }
                }
                elif (str_contains_cstr(line, "sram") == 1) {
                    var val2 = parse_value_with_suffix(line);
                    if (val2 > 0) { mem_mb = val2; }
                }
            }
            var p = profile_new(ACCEL_GRAPHCORE, 0, mem_mb * 1024 * 1024);
            profile_set_device_name(p, "Graphcore IPU");
            profile_set_compute_cap(p, "IPU");
            vec_push(profiles, p);
            return 0;
        }
    }

    # Fallback: /dev/ipu* check
    if (has_dev_device("ipu") == 1) {
        var p = profile_new(ACCEL_GRAPHCORE, 0, 900 * 1024 * 1024);
        profile_set_device_name(p, "Graphcore IPU");
        profile_set_compute_cap(p, "IPU");
        vec_push(profiles, p);
    }
    return 0;
}

fn detect_groq(profiles, warnings) {
    if (has_dev_device("groq") == 1) {
        var p = profile_new(ACCEL_GROQ, 0, 230 * 1024 * 1024);
        profile_set_device_name(p, "Groq LPU");
        profile_set_compute_cap(p, "LPU");
        vec_push(profiles, p);
    }
    return 0;
}

# --- bandwidth.cyr ---

# bandwidth.cyr — memory bandwidth enrichment post-pass
# Enriches CUDA and ROCm profiles with memory_bandwidth_gbps

# AMD bus width lookup by PCI device ID substring
# Returns bus width in bits
fn _amd_bus_width(dev_id_str) {
    # MI300X: 8192-bit
    if (str_contains_cstr(dev_id_str, "740c") == 1) { return 8192; }
    if (str_contains_cstr(dev_id_str, "740f") == 1) { return 8192; }
    # MI250X: 8192-bit
    if (str_contains_cstr(dev_id_str, "7408") == 1) { return 8192; }
    # MI100: 4096-bit
    if (str_contains_cstr(dev_id_str, "738c") == 1) { return 4096; }
    # RX 7900 XTX: 384-bit
    if (str_contains_cstr(dev_id_str, "744c") == 1) { return 384; }
    # Default: estimate from VRAM size
    return 0;
}

fn _est_amd_bus_width_from_vram(vram_bytes) {
    # Rough heuristic: larger VRAM = wider bus
    if (vram_bytes >= 128 * BYTES_PER_GIB) { return 8192; }
    if (vram_bytes >= 64 * BYTES_PER_GIB) { return 4096; }
    if (vram_bytes >= 16 * BYTES_PER_GIB) { return 384; }
    if (vram_bytes >= 8 * BYTES_PER_GIB) { return 256; }
    return 128;
}

# Enrich profiles with memory bandwidth
fn enrich_bandwidth(profiles) {
    var np = vec_len(profiles);
    var pi = 0;
    while (pi < np) {
        var p = vec_get(profiles, pi);
        pi = pi + 1;
        var at = profile_accel_type(p);

        # Skip if already has bandwidth
        if (profile_mem_bw_x1000(p) != PROFILE_NONE) { continue; }

        if (at == ACCEL_ROCM) {
            # Try to read memory clock from sysfs
            var dev_id = profile_device_id(p);
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "/sys/class/drm/card");
            str_builder_add_int(sb, dev_id);
            str_builder_add_cstr(sb, "/device");
            var dev_path = str_builder_build(sb);
            var dp_cstr = str_cstr(dev_path);

            # Read max memory clock from pp_dpm_mclk
            var mclk_path = sysfs_path(dp_cstr, 0, "pp_dpm_mclk");
            var mclk_data = sysfs_read(mclk_path);
            var max_mclk = 0;
            if (mclk_data != 0) {
                # Parse last line for max clock: "N: XXXMhz"
                var mlines = str_split(mclk_data, 10);
                var mli = 0;
                while (mli < vec_len(mlines)) {
                    var ml = vec_get(mlines, mli);
                    mli = mli + 1;
                    var val = parse_value_with_suffix(ml);
                    if (val > max_mclk) { max_mclk = val; }
                }
            }

            # Read PCI device ID for bus width lookup
            var devid_path = sysfs_path(dp_cstr, 0, "device");
            var devid_str = sysfs_read(devid_path);
            var bus_width = 0;
            if (devid_str != 0) {
                bus_width = _amd_bus_width(devid_str);
            }
            if (bus_width == 0) {
                bus_width = _est_amd_bus_width_from_vram(profile_memory_bytes(p));
            }

            if (max_mclk > 0 && bus_width > 0) {
                var bw_x1000 = max_mclk * bus_width * 2 / 8;
                profile_set_mem_bw_x1000(p, bw_x1000);
            }
        }
        # CUDA bandwidth is already computed inline during parse_cuda_output
    }
    return 0;
}

# --- pcie.cyr ---

# pcie.cyr — PCIe link bandwidth enrichment post-pass
# Reads /sys/bus/pci/devices/<addr>/current_link_{width,speed}

fn enrich_pcie(profiles) {
    var np = vec_len(profiles);
    var pi = 0;
    while (pi < np) {
        var p = vec_get(profiles, pi);
        pi = pi + 1;
        var at = profile_accel_type(p);

        # Only enrich CUDA and ROCm GPUs
        if (at != ACCEL_CUDA) {
            if (at != ACCEL_ROCM) { continue; }
        }

        # Skip if already has PCIe bandwidth
        if (profile_pcie_bw_x1000(p) != PROFILE_NONE) { continue; }

        var dev_id = profile_device_id(p);
        var pci_addr = _find_pci_addr(at, dev_id);
        if (pci_addr == 0) { continue; }

        # Read link width
        var width_path = sysfs_path(pci_addr, 0, "current_link_width");
        var width = sysfs_read_int(width_path);
        if (width <= 0) { continue; }

        # Read link speed (e.g., "16 GT/s", "8 GT/s")
        var speed_path = sysfs_path(pci_addr, 0, "current_link_speed");
        var speed_str = sysfs_read(speed_path);
        if (speed_str == 0) { continue; }
        var speed_gts = parse_value_with_suffix(speed_str);
        if (speed_gts <= 0) { continue; }

        # Calculate bandwidth: speed_gts * width * encoding / 8
        # Gen3+ (>= 8 GT/s): 128b/130b encoding (~0.984)
        # Gen1/2 (< 8 GT/s): 8b/10b encoding (0.8)
        var bw_x1000 = 0;
        if (speed_gts >= PCIE_GEN3_SPEED_GTS) {
            # speed * width * 984 / 1000 / 8 * 1000 = speed * width * 984 / 8
            bw_x1000 = speed_gts * width * PCIE_GEN3_PLUS_ENCODING_X1000 / 8;
        } else {
            bw_x1000 = speed_gts * width * PCIE_GEN1_GEN2_ENCODING_X1000 / 8;
        }
        profile_set_pcie_bw_x1000(p, bw_x1000);
    }
    return 0;
}

# Find PCI address for a GPU device
fn _find_pci_addr(accel_type, dev_id) {
    var driver_dir = "/sys/bus/pci/drivers/nvidia";
    if (accel_type == ACCEL_ROCM) { driver_dir = "/sys/bus/pci/drivers/amdgpu"; }

    var entries = sysfs_list_dir(driver_dir);
    var nent = vec_len(entries);
    var idx = 0;
    var ei = 0;
    while (ei < nent) {
        var name = vec_get(entries, ei);
        ei = ei + 1;
        # PCI addresses look like "0000:XX:XX.X"
        if (str_len(name) < 10) { continue; }
        var d0 = load8(str_data(name));
        if (d0 < 48) { continue; }
        if (d0 > 57) { continue; }

        if (idx == dev_id) {
            # Build full sysfs path
            var sb = str_builder_new();
            str_builder_add_cstr(sb, "/sys/bus/pci/devices/");
            str_builder_add(sb, name);
            var result = str_builder_build(sb);
            return str_cstr(result);
        }
        idx = idx + 1;
    }
    return 0;
}

# --- numa.cyr ---

# numa.cyr — NUMA node enrichment post-pass
# Reads /sys/bus/pci/devices/<addr>/numa_node

fn enrich_numa(profiles) {
    var np = vec_len(profiles);
    var pi = 0;
    while (pi < np) {
        var p = vec_get(profiles, pi);
        pi = pi + 1;
        var at = profile_accel_type(p);

        if (at != ACCEL_CUDA) {
            if (at != ACCEL_ROCM) { continue; }
        }
        if (profile_numa_node(p) != PROFILE_NONE) { continue; }

        var pci_addr = _find_pci_addr(at, profile_device_id(p));
        if (pci_addr == 0) { continue; }

        var numa_path = sysfs_path(pci_addr, 0, "numa_node");
        var node = sysfs_read_int(numa_path);
        if (node >= 0) {
            profile_set_numa_node(p, node);
        }
    }
    return 0;
}

# --- interconnect.cyr ---

# interconnect.cyr — network interconnect detection
# InfiniBand, RoCE, NVLink, NVSwitch, XGMI, ICI

fn detect_interconnects(sio, profiles, warnings) {
    _detect_infiniband(sio);
    _detect_nvlink_nvswitch(sio, warnings);
    _detect_xgmi(sio);
    _detect_ici(sio, profiles);
    return 0;
}

# --- InfiniBand / RoCE ---

fn _detect_infiniband(sio) {
    var ib_dir = str_from("/sys/class/infiniband");
    var entries = dir_list(ib_dir);
    var nent = vec_len(entries);

    var ei = 0;
    while (ei < nent) {
        var name = vec_get(entries, ei);
        ei = ei + 1;

        # Read port 1 state
        var state_path = sysfs_path_str("/sys/class/infiniband", name, "ports/1/state");
        var state = sysfs_read(state_path);

        # Read rate (e.g., "200 Gb/sec (4X HDR)")
        var rate_path = sysfs_path_str("/sys/class/infiniband", name, "ports/1/rate");
        var rate_str = sysfs_read(rate_path);
        var bw_x1000 = 0;
        if (rate_str != 0) {
            var gbps = parse_value_with_suffix(rate_str);
            # Convert Gb/s to GB/s (* 1000 / 8)
            bw_x1000 = gbps * 1000 / GBITS_PER_GBYTE;
        }

        # Determine kind: IB vs RoCE
        var kind = ICK_INFINIBAND;
        var ll_path = sysfs_path_str("/sys/class/infiniband", name, "ports/1/link_layer");
        var ll = sysfs_read(ll_path);
        if (ll != 0) {
            if (str_contains_cstr(ll, "Ethernet") == 1) {
                kind = ICK_ROCEV2;
            }
        }

        var ic = interconnect_new(kind, str_cstr(name), bw_x1000);
        if (state != 0) {
            ic_set_state(ic, str_cstr(state));
        }
        sio_add_interconnect(sio, ic);
    }
    return 0;
}

# --- NVLink / NVSwitch ---

fn _detect_nvlink_nvswitch(sio, warnings) {
    # Check for NVSwitch via sysfs
    if (dir_exists("/sys/devices/virtual/nvidia-nvswitch") == 1) {
        var ic = interconnect_new(ICK_NVSWITCH, "nvswitch", 900000);
        ic_set_state(ic, "Active");
        sio_add_interconnect(sio, ic);
        return 0;
    }
    if (path_exists("/sys/bus/nvidia_nvswitch/devices") == 1) {
        var nvsw_entries = sysfs_list_dir("/sys/bus/nvidia_nvswitch/devices");
        if (vec_len(nvsw_entries) > 0) {
            var ic = interconnect_new(ICK_NVSWITCH, "nvswitch", 900000);
            ic_set_state(ic, "Active");
            sio_add_interconnect(sio, ic);
            return 0;
        }
    }

    # Try nvidia-smi nvlink -s for NVLink
    var result = run_tool2("nvidia-smi", "nvlink", "-s", warnings);
    if (result != 0) {
        if (str_len(result) > 0) {
            # Count NVLink entries and estimate bandwidth
            var link_count = 0;
            var link_bw = 25000;
            var lines = str_split(result, 10);
            var li = 0;
            while (li < vec_len(lines)) {
                var line = vec_get(lines, li);
                li = li + 1;
                if (str_contains_cstr(line, "Link") == 1) {
                    link_count = link_count + 1;
                    # Parse bandwidth if available
                    var bval = parse_value_with_suffix(line);
                    if (bval > 0) { link_bw = bval * 1000; }
                }
            }
            if (link_count > 0) {
                var total_bw = link_bw * link_count;
                var ic = interconnect_new(ICK_NVLINK, "nvlink", total_bw);
                sio_add_interconnect(sio, ic);
            }
        }
    }
    return 0;
}

# --- AMD XGMI / Infinity Fabric ---

fn _detect_xgmi(sio) {
    # Check sysfs for XGMI hive
    var drm_dir = str_from("/sys/class/drm");
    var entries = dir_list(drm_dir);
    var nent = vec_len(entries);
    var has_xgmi = 0;

    var ei = 0;
    while (ei < nent) {
        var name = vec_get(entries, ei);
        ei = ei + 1;
        if (str_starts_with(name, "card") != 1) { continue; }
        if (str_index_of(name, 45) >= 0) { continue; }

        var hive_path = sysfs_path_str("/sys/class/drm", name, "device/xgmi_hive_info");
        if (path_exists(str_data(hive_path)) == 1) {
            has_xgmi = 1;
            break;
        }
    }

    if (has_xgmi == 1) {
        var ic = interconnect_new(ICK_XGMI, "xgmi", 400000);
        sio_add_interconnect(sio, ic);
    }
    return 0;
}

# --- Google TPU ICI ---

fn _detect_ici(sio, profiles) {
    var np = vec_len(profiles);
    var pi = 0;
    while (pi < np) {
        var p = vec_get(profiles, pi);
        pi = pi + 1;
        if (profile_accel_type(p) != ACCEL_TPU) { continue; }

        var version = profile_tpu_version(p);
        var chips = profile_tpu_chips(p);
        # Per-chip ICI bandwidth by version (GB/s * 1000)
        var per_chip_bw = 192000;
        if (version == TPU_V5E) { per_chip_bw = 204800; }
        elif (version == TPU_V5P) { per_chip_bw = 409600; }

        var total_bw = per_chip_bw * chips;
        var ic = interconnect_new(ICK_ICI, "ici", total_bw);
        sio_add_interconnect(sio, ic);
        break;
    }
    return 0;
}

# --- disk.cyr ---

# disk.cyr — storage device detection via /sys/block/

fn detect_storage(sio) {
    var block_dir = str_from("/sys/block");
    var entries = dir_list(block_dir);
    var nent = vec_len(entries);

    var ei = 0;
    while (ei < nent) {
        var name = vec_get(entries, ei);
        ei = ei + 1;

        # Skip virtual devices: loop, dm-, ram, zram, sr, fd, md
        if (str_starts_with(name, "loop") == 1) { continue; }
        if (str_starts_with(name, "dm-") == 1) { continue; }
        if (str_starts_with(name, "ram") == 1) { continue; }
        if (str_starts_with(name, "zram") == 1) { continue; }
        if (str_starts_with(name, "sr") == 1) { continue; }
        if (str_starts_with(name, "fd") == 1) { continue; }
        if (str_starts_with(name, "md") == 1) { continue; }

        # Determine storage kind and bandwidth
        var kind = STK_UNKNOWN;
        var bw_x1000 = 100;

        if (str_starts_with(name, "nvme") == 1) {
            kind = STK_NVME;
            bw_x1000 = 3500;
        } else {
            # Check rotational flag
            var rot_path = sysfs_path_str("/sys/block", name, "queue/rotational");
            var rot = sysfs_read_int(rot_path);
            if (rot == 0) {
                kind = STK_SATA_SSD;
                bw_x1000 = 550;
            } elif (rot == 1) {
                kind = STK_HDD;
                bw_x1000 = 150;
            }
        }

        var sd = storage_new(str_cstr(name), kind, bw_x1000);
        sio_add_storage(sio, sd);
    }
    return 0;
}

# --- environment.cyr ---

# environment.cyr — runtime environment detection
# Docker, Kubernetes, cloud provider (AWS/GCP/Azure)

fn detect_environment(sio) {
    var env = runtime_env_new();
    var detected = 0;

    # --- Docker detection ---
    if (path_exists("/.dockerenv") == 1) {
        env_set_is_docker(env, 1);
        detected = 1;
    } else {
        # Check /proc/1/cgroup for docker/containerd
        var cgroup = sysfs_read("/proc/1/cgroup");
        if (cgroup != 0) {
            if (str_contains_cstr(cgroup, "docker") == 1) {
                env_set_is_docker(env, 1);
                detected = 1;
            } elif (str_contains_cstr(cgroup, "containerd") == 1) {
                env_set_is_docker(env, 1);
                detected = 1;
            }
        }
    }

    # --- Kubernetes detection ---
    if (path_exists("/var/run/secrets/kubernetes.io") == 1) {
        env_set_is_k8s(env, 1);
        detected = 1;
        # Read namespace
        var ns = sysfs_read("/var/run/secrets/kubernetes.io/serviceaccount/namespace");
        if (ns != 0) {
            env_set_k8s_namespace(env, str_cstr(ns));
        }

        # GPU count from env vars
        var nv_devs = cmd_getenv("NVIDIA_VISIBLE_DEVICES");
        if (nv_devs != 0) {
            # Count commas + 1 = device count
            var count = 1;
            var ci = 0;
            while (load8(nv_devs + ci) != 0) {
                if (load8(nv_devs + ci) == 44) { count = count + 1; }
                ci = ci + 1;
            }
            env_set_k8s_gpu_count(env, count);
            env_set_k8s_gpu_source(env, "NVIDIA_VISIBLE_DEVICES");
        }
    }

    # --- Cloud provider detection via DMI ---
    var vendor = sysfs_read("/sys/class/dmi/id/sys_vendor");
    var bios = sysfs_read("/sys/class/dmi/id/bios_vendor");
    var product = sysfs_read("/sys/class/dmi/id/product_name");

    if (vendor != 0) {
        if (str_contains_cstr(vendor, "Amazon") == 1) {
            env_set_cloud_provider(env, "aws");
            detected = 1;
        } elif (str_contains_cstr(vendor, "Google") == 1) {
            env_set_cloud_provider(env, "gcp");
            detected = 1;
        } elif (str_contains_cstr(vendor, "Microsoft") == 1) {
            env_set_cloud_provider(env, "azure");
            detected = 1;
        }
    }
    if (env_cloud_provider(env) == 0 && bios != 0) {
        if (str_contains_cstr(bios, "amazon") == 1) {
            env_set_cloud_provider(env, "aws");
            detected = 1;
        } elif (str_contains_cstr(bios, "Amazon") == 1) {
            env_set_cloud_provider(env, "aws");
            detected = 1;
        }
    }

    # Instance type from product name (AWS)
    if (product != 0) {
        if (env_cloud_provider(env) != 0) {
            if (streq(env_cloud_provider(env), "aws") == 1) {
                env_set_instance_type(env, str_cstr(product));
            }
        }
    }

    if (detected == 1) {
        sio_set_environment(sio, env);
    }
    return 0;
}

# --- windows.cyr ---

# windows.cyr — Windows-side accelerator detection (WMI / Win32_VideoController).
#
# `detect_windows` is compiled in only when the target is Win64 PE
# (CYRIUS_TARGET_WIN, predefined by cycc_win). On Linux / macOS it is
# preprocessed out, so registry_detect_with's call to it is also gated.
#
# Mechanism (2.3.7): cyrius 6.0.51 routed Win32 process creation
# (CreateProcessW; lib/process_win.cyr), so detection spawns `wmic` and
# parses its output — the same subprocess model as the Unix detectors.
#   - GPUs : `wmic path win32_VideoController get Name,AdapterRAM /format:list`
#            -> one ACCEL_WIN_GPU profile per controller (name + VRAM).
#   - RAM  : detect_system_memory() (platform.cyr) spawns
#            `wmic computersystem get TotalPhysicalMemory`.
#
# Win32_VideoController.AdapterRAM is a 32-bit field capped at 4 GiB, so
# large discrete-GPU VRAM under-reports. A native DXGI pass
# (CreateDXGIFactory1 -> EnumAdapters1 -> GetDesc1 -> DedicatedVideoMemory,
# no subprocess) reads precise, uncapped VRAM through a COM vtable via
# `callptr`, and `win_merge_vram` reconciles it with the WMI figure (max —
# precise large VRAM for discrete cards, WMI's shared figure for integrated
# GPUs that report ~0 DedicatedVideoMemory).
#
# STATUS (2.3.9): the DXGI precise-VRAM pass is ON by default for Windows PE
# builds. It was previously gated OFF behind `-D AI_HWACCEL_DXGI` because the
# callptr -> real-Win64-COM chain corrupted the caller in a non-trivial
# program (`dxgi_vram_bytes()` followed by `str_builder_add_cstr(sb, "true")`
# garbled the "true" literal on cass). Root-caused upstream as an m128
# array-padding / PE `.rdata` layout divergence (function-local arrays are
# `.rdata` globals; the &gvar prefix-sum was padded against the ELF dbase
# while _pe_layout sized the string zone unpadded, so `&desc`'s 312-B
# GetDesc1 write drifted +8 onto the "true" literal) — NOT a callptr
# register/DF bug — and fixed in cyrius 6.1.7 (GPU-confirmed on cass via that
# exact ai-hwaccel repro). Issue
# 2026-06-08-windows-com-callee-corrupts-caller-in-nontrivial-program.md
# (resolved). Default Windows builds now report precise DedicatedVideoMemory.
#
# The pure parsers `win_parse_videocontrollers` and `win_merge_vram` are
# ungated so the Linux-hosted fixture test (tests/tcyr/windows_test.tcyr)
# exercises them without a Windows host; the wmic spawn and the DXGI COM pass
# are CYRIUS_TARGET_WIN-only (callptr + syscall 0xF012 exist only on PE).

# Push an ACCEL_WIN_GPU profile (name copied to a NUL-terminated cstr).
fn win_emit_gpu(profiles, dev_id, name, ram) {
    var mem = ram;
    if (mem < 0) { mem = 0; }
    var p = profile_new(ACCEL_WIN_GPU, dev_id, mem);
    var sb = str_builder_new();
    str_builder_add(sb, name);
    profile_set_device_name(p, str_data(str_builder_build(sb)));
    vec_push(profiles, p);
}

# Parse `wmic ... win32_VideoController get Name,AdapterRAM /format:list`
# output into ACCEL_WIN_GPU profiles. Each controller is a block of
# `Key=Value` lines (AdapterRAM= and Name=, any order) separated by blank
# lines. Returns the count of GPUs pushed. Pure — no I/O.
fn win_parse_videocontrollers(out, profiles) {
    var lines = str_split(out, 10);
    var nl = vec_len(lines);
    var i = 0;
    var dev_id = 0;
    var have_name = 0;
    var cur_name = 0;
    var cur_ram = 0;
    var count = 0;
    while (i < nl) {
        var line = str_trim(vec_get(lines, i));
        var ld = str_data(line);
        var ll = str_len(line);
        if (ll == 0) {
            if (have_name == 1) {
                win_emit_gpu(profiles, dev_id, cur_name, cur_ram);
                dev_id = dev_id + 1;
                count = count + 1;
                have_name = 0;
                cur_ram = 0;
            }
        } else {
            if (ll >= 11) {
                if (memeq(ld, "AdapterRAM=", 11) == 1) {
                    cur_ram = str_to_int(str_new(ld + 11, ll - 11));
                }
            }
            if (ll >= 5) {
                if (memeq(ld, "Name=", 5) == 1) {
                    cur_name = str_new(ld + 5, ll - 5);
                    have_name = 1;
                }
            }
        }
        i = i + 1;
    }
    if (have_name == 1) {
        win_emit_gpu(profiles, dev_id, cur_name, cur_ram);
        count = count + 1;
    }
    return count;
}

# Choose the VRAM figure to report for a Windows GPU given the WMI
# AdapterRAM value (`wmi_bytes`) and the DXGI DedicatedVideoMemory value
# (`dxgi_bytes`). WMI's AdapterRAM is a uint32 capped at 4 GiB, so it
# under-reports large discrete VRAM; DXGI's DedicatedVideoMemory is precise
# and uncapped but reads ~0 / small for integrated GPUs that have no
# dedicated VRAM (they use shared system memory, which WMI surfaces).
# Taking the max keeps the most useful capacity figure in both cases:
# precise large VRAM for a discrete card, WMI's shared figure for an
# integrated one. Pure — no I/O; Linux-testable.
fn win_merge_vram(wmi_bytes, dxgi_bytes) {
    if (dxgi_bytes > wmi_bytes) { return dxgi_bytes; }
    return wmi_bytes;
}

#ifdef CYRIUS_TARGET_WIN

# --- Native DXGI precise-VRAM pass (PE only; ON by default since 2.3.9) ------
# Walks the COM vtable through `callptr` exactly as cyrius's reference
# lib/dxgi.cyr (GPU-verified on cass). Each method N lives at
# load64(vtbl + N*8). DXGI_ADAPTER_DESC1: VendorId @256, DeviceId @260,
# DedicatedVideoMemory @272 (SIZE_T) — a 320-byte buffer holds the struct.

# Fill `dst` (>=16 bytes) with IID_IDXGIFactory1
# {770aae78-f26f-4dba-a829-253c83d1b387} in COM's little-endian-Data1..3 +
# big-endian-Data4 byte order.
fn win_dxgi_iid_factory1(dst) {
    store8(dst + 0, 0x78);  store8(dst + 1, 0xAE);  store8(dst + 2, 0x0A);  store8(dst + 3, 0x77);
    store8(dst + 4, 0x6F);  store8(dst + 5, 0xF2);  store8(dst + 6, 0xBA);  store8(dst + 7, 0x4D);
    store8(dst + 8, 0xA8);  store8(dst + 9, 0x29);  store8(dst + 10, 0x25); store8(dst + 11, 0x3C);
    store8(dst + 12, 0x83); store8(dst + 13, 0xD1); store8(dst + 14, 0xB3); store8(dst + 15, 0x87);
}

# IUnknown::Release(obj) @ vtable slot 2. No-op on NULL. (callptr is an
# expression-only builtin, so its discarded refcount return is bound to a
# local.)
fn win_dxgi_release(obj) {
    if (obj == 0) { return 0; }
    var vtbl = load64(obj);
    var rc = callptr(load64(vtbl + 2 * 8), obj);
    return 0;
}

# DedicatedVideoMemory (bytes) of DXGI adapter `index`, or 0 on any failure.
# CreateDXGIFactory1 -> EnumAdapters1(index) -> GetDesc1 -> @272, releasing
# both COM objects before returning.
fn win_dxgi_adapter_vram_bytes(index) {
    var iid[16];
    win_dxgi_iid_factory1(&iid);
    var pFactory = 0;
    var hr = syscall(0xF012, &iid, &pFactory);     # CreateDXGIFactory1
    if (hr != 0) { return 0; }
    if (pFactory == 0) { return 0; }
    var fvtbl = load64(pFactory);
    var pAdapter = 0;
    # EnumAdapters1(this, index, &pAdapter) @ IDXGIFactory1 slot 12.
    var hr2 = callptr(load64(fvtbl + 12 * 8), pFactory, index, &pAdapter);
    if (hr2 != 0) {
        var r1 = win_dxgi_release(pFactory);
        return 0;
    }
    if (pAdapter == 0) {
        var r2 = win_dxgi_release(pFactory);
        return 0;
    }
    var avtbl = load64(pAdapter);
    var desc[320];                                 # DXGI_ADAPTER_DESC1
    # GetDesc1(this, &desc) @ IDXGIAdapter1 slot 10.
    var hr3 = callptr(load64(avtbl + 10 * 8), pAdapter, &desc);
    var vram = 0;
    if (hr3 == 0) { vram = load64(&desc + 272); }  # DedicatedVideoMemory
    var r3 = win_dxgi_release(pAdapter);
    var r4 = win_dxgi_release(pFactory);
    return vram;
}

# Enrich the ACCEL_WIN_GPU profiles pushed at indices [base, end) with
# precise DXGI VRAM. The WMI controllers were emitted in enumeration order
# with dev_id 0,1,2…, which is used as the DXGI EnumAdapters1 index (the two
# enumerations agree for the common single-/discrete-GPU case). Per adapter,
# the reported memory becomes max(WMI, DXGI) (see win_merge_vram).
fn win_enrich_dxgi_vram(profiles, base) {
    var n = vec_len(profiles);
    var i = base;
    while (i < n) {
        var p = vec_get(profiles, i);
        if (profile_accel_type(p) == ACCEL_WIN_GPU) {
            var idx = profile_device_id(p);
            var dxgi = win_dxgi_adapter_vram_bytes(idx);
            if (dxgi > 0) {
                var wmi = profile_memory_bytes(p);
                var merged = win_merge_vram(wmi, dxgi);
                if (merged != wmi) {
                    profile_set_memory_bytes(p, merged);
                    hwlog_debug_n("windows: dxgi precise vram override (bytes) ", merged);
                } else {
                    hwlog_debug_n("windows: dxgi vram below wmi, kept wmi (bytes) ", wmi);
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# Detect Windows-visible GPUs by spawning wmic. CreateProcessW resolves
# `wmic` from System32\wbem on PATH (no which()/PATH-env dependency,
# which is unavailable on PE — /proc/self/environ doesn't exist).
fn detect_windows(profiles, warnings) {
    var args = vec_new();
    vec_push(args, "wmic");
    vec_push(args, "path");
    vec_push(args, "win32_VideoController");
    vec_push(args, "get");
    vec_push(args, "Name,AdapterRAM");
    vec_push(args, "/format:list");
    var buf = alloc(CMD_MAX_STDOUT);
    var n = exec_capture(args, buf, CMD_MAX_STDOUT);
    if (n <= 0) {
        if (warnings != 0) {
            vec_push(warnings, warning_tool_failed("wmic", 0 - 1, "win32_VideoController query failed"));
        }
        return 0;
    }
    store8(buf + n, 0);
    # Parse WMI controllers, then override WMI's 4 GiB-capped AdapterRAM with
    # precise DXGI DedicatedVideoMemory where the native COM pass returns a
    # larger figure (discrete cards). On by default since 2.3.9 — the upstream
    # callptr->COM .rdata-corruption residual was fixed in cyrius 6.1.7.
    var base = vec_len(profiles);
    var count = win_parse_videocontrollers(str_new(buf, n), profiles);
    var enriched = win_enrich_dxgi_vram(profiles, base);
    return count;
}

#endif

# --- registry.cyr ---

# registry.cyr — accelerator registry: detect, query, plan
#
# Registry — profiles + warnings + system_io + schema_version.
# Struct named `reg` to match the `reg_*` accessor convention;
# constructor is `hw_registry_new` (renamed from `registry_new` to
# avoid the bote-core `registry_new` symbol collision — fns/enum
# members are global in Cyrius, last-def-wins; see
# docs/development/issues/2026-06-11-registry-new-collision.md).
# No `registry_new` alias: an alias by that name would reintroduce
# the exact collision. 2.1.5: hand-rolled accessors
# replaced with #derive(accessors); the internal `load64(r)` /
# `load64(r + N)` shortcuts in helpers below switched to the
# derived `reg_*` getters for consistency with the rest of the file.

#derive(accessors)
struct reg {
    profiles;
    warnings;
    system_io;
    schema;
}

var REGISTRY_SIZE = 32;

fn hw_registry_new() {
    var r = alloc(REGISTRY_SIZE);
    reg_set_profiles(r, vec_new());
    reg_set_warnings(r, vec_new());
    reg_set_system_io(r, system_io_new());
    reg_set_schema(r, SCHEMA_VERSION);
    return r;
}

fn reg_add_profile(r, p) {
    vec_push(reg_profiles(r), p);
    return 0;
}

# --- Query methods ---

fn reg_num_profiles(r) {
    return vec_len(reg_profiles(r));
}

fn reg_get_profile(r, idx) {
    return vec_get(reg_profiles(r), idx);
}

fn reg_num_warnings(r) {
    return vec_len(reg_warnings(r));
}

# Total memory across all available devices
fn reg_total_memory(r) {
    var profs = reg_profiles(r);
    var total = 0;
    var n = vec_len(profs);
    var i = 0;
    while (i < n) {
        var p = vec_get(profs, i);
        i = i + 1;
        if (profile_available(p) == 1) {
            total = total + profile_memory_bytes(p);
        }
    }
    return total;
}

# Total accelerator memory (excludes CPU)
fn reg_total_accel_memory(r) {
    var profs = reg_profiles(r);
    var total = 0;
    var n = vec_len(profs);
    var i = 0;
    while (i < n) {
        var p = vec_get(profs, i);
        i = i + 1;
        if (profile_available(p) != 1) { continue; }
        if (profile_accel_type(p) == ACCEL_CPU) { continue; }
        total = total + profile_memory_bytes(p);
    }
    return total;
}

# Whether any non-CPU accelerator is available
fn reg_has_accelerator(r) {
    var profs = reg_profiles(r);
    var n = vec_len(profs);
    var i = 0;
    while (i < n) {
        var p = vec_get(profs, i);
        i = i + 1;
        if (profile_available(p) != 1) { continue; }
        if (profile_accel_type(p) != ACCEL_CPU) { return 1; }
    }
    return 0;
}

# Best available device (highest rank)
fn reg_best_available(r) {
    var profs = reg_profiles(r);
    var n = vec_len(profs);
    var best = 0;
    var best_rank = 0;
    var i = 0;
    while (i < n) {
        var p = vec_get(profs, i);
        i = i + 1;
        if (profile_available(p) != 1) { continue; }
        var rank = profile_rank(p);
        if (rank > best_rank) {
            best_rank = rank;
            best = p;
        }
    }
    return best;
}

# Count profiles by family
fn reg_count_by_family(r, family) {
    var profs = reg_profiles(r);
    var count = 0;
    var n = vec_len(profs);
    var i = 0;
    while (i < n) {
        var p = vec_get(profs, i);
        i = i + 1;
        if (profile_available(p) != 1) { continue; }
        if (profile_family(p) == family) { count = count + 1; }
    }
    return count;
}

# Collect available profiles by family into a vec
fn reg_by_family(r, family) {
    var profs = reg_profiles(r);
    var result = vec_new();
    var n = vec_len(profs);
    var i = 0;
    while (i < n) {
        var p = vec_get(profs, i);
        i = i + 1;
        if (profile_available(p) != 1) { continue; }
        if (profile_family(p) == family) { vec_push(result, p); }
    }
    return result;
}

# Estimate memory for model_params at given quantization
fn reg_estimate_memory(model_params, quant) {
    return quant_model_bytes_with_overhead(model_params, quant);
}

# Suggest quantization level based on available hardware
fn reg_suggest_quant(r, model_params) {
    var best_tpu = 0;
    var best_gaudi = 0;
    var best_gpu = 0;
    var best_npu = 0;
    var best_cpu = 0;

    var profs = reg_profiles(r);
    var n = vec_len(profs);
    var i = 0;
    while (i < n) {
        var p = vec_get(profs, i);
        i = i + 1;
        if (profile_available(p) != 1) { continue; }
        var mem = profile_memory_bytes(p);
        var fam = profile_family(p);
        if (fam == FAMILY_TPU) { if (mem > best_tpu) { best_tpu = mem; } }
        elif (fam == FAMILY_GPU) { if (mem > best_gpu) { best_gpu = mem; } }
        elif (fam == FAMILY_NPU) { if (mem > best_npu) { best_npu = mem; } }
        elif (fam == FAMILY_CPU) { if (mem > best_cpu) { best_cpu = mem; } }
        elif (fam == FAMILY_AI_ASIC) {
            if (profile_accel_type(p) == ACCEL_GAUDI) {
                if (mem > best_gaudi) { best_gaudi = mem; }
            }
        }
    }

    var est_bf16 = reg_estimate_memory(model_params, QUANT_BF16);
    var est_fp16 = reg_estimate_memory(model_params, QUANT_FP16);
    var est_int8 = reg_estimate_memory(model_params, QUANT_INT8);
    var est_int4 = reg_estimate_memory(model_params, QUANT_INT4);

    # TPU -> BF16
    if (best_tpu > 0) {
        if (est_bf16 <= best_tpu) { return QUANT_BF16; }
        if (est_int8 <= best_tpu) { return QUANT_INT8; }
    }
    # Gaudi -> BF16
    if (best_gaudi > 0) {
        if (est_bf16 <= best_gaudi) { return QUANT_BF16; }
        if (est_int8 <= best_gaudi) { return QUANT_INT8; }
    }
    # GPU -> FP16
    if (best_gpu > 0) {
        if (est_fp16 <= best_gpu) { return QUANT_FP16; }
        if (est_int8 <= best_gpu) { return QUANT_INT8; }
        if (est_int4 <= best_gpu) { return QUANT_INT4; }
    }
    # NPU -> INT8/INT4
    if (best_npu > 0) {
        if (est_int8 <= best_npu) { return QUANT_INT8; }
        if (est_int4 <= best_npu) { return QUANT_INT4; }
    }
    # CPU fallback
    var cpu_mem = best_cpu;
    if (cpu_mem == 0) { cpu_mem = 16 * BYTES_PER_GIB; }
    if (est_fp16 <= cpu_mem) { return QUANT_FP16; }
    if (est_int8 <= cpu_mem) { return QUANT_INT8; }
    return QUANT_INT4;
}

# --- Detection builder (bitmask) ---

# All backends enabled
fn builder_all() { return (1 << BACKEND_COUNT) - 1; }

# No backends enabled
fn builder_none() { return 0; }

# Enable/disable a backend
fn builder_with(mask, backend) { return mask | (1 << backend); }
fn builder_without(mask, backend) { return mask & (~(1 << backend)); }
fn builder_is_enabled(mask, backend) { return (mask >> backend) & 1; }

# Mask of backends whose detectors are pure sysfs/syscall reads — no
# subprocess spawning. Library consumers with a no-exec contract
# (mihi's probe surface) call this then registry_detect_with(builder_no_exec()),
# or use the convenience registry_detect_no_exec() entry point.
fn builder_no_exec() {
    var mask = 0;
    var b = 0;
    while (b < BACKEND_COUNT) {
        if (backend_uses_exec(b) == 0) {
            mask = mask | (1 << b);
        }
        b = b + 1;
    }
    return mask;
}

# --- Full detection orchestration ---

fn registry_detect() {
    return registry_detect_with_opts(builder_all(), 1);
}

fn registry_detect_with(builder_mask) {
    return registry_detect_with_opts(builder_mask, 1);
}

# No-subprocess detection — masks off exec-shelling backends (defense
# in depth: even if the caller's mask had them set) and skips the only
# exec-shaped post-pass (detect_interconnects, which calls ibstat /
# nvidia-smi for fabric topology). Safe to call from contexts that
# forbid process spawning, e.g. mihi probes. See backend_uses_exec()
# in types.cyr for the per-backend classification.
fn registry_detect_no_exec() {
    return registry_detect_with_opts(builder_no_exec(), 0);
}

fn registry_detect_with_opts(builder_mask, allow_exec) {
    # When exec is forbidden, force-strip any exec backends the caller
    # may have enabled. backend_uses_exec() is the source of truth.
    if (allow_exec == 0) {
        builder_mask = builder_mask & builder_no_exec();
    }

    hwlog_span_enter("detect");
    hwlog_debug_n("detect: builder_mask=", builder_mask);

    var r = hw_registry_new();
    var profs = reg_profiles(r);
    var warns = reg_warnings(r);
    var sio = reg_system_io(r);

    # Always add CPU profile
    var sys_mem = detect_system_memory();
    if (sys_mem == 0) { sys_mem = 16 * BYTES_PER_GIB; }
    reg_add_profile(r, profile_cpu(sys_mem));

    # Run enabled detectors
    if (builder_is_enabled(builder_mask, BACKEND_CUDA) == 1) { detect_cuda(profs, warns); }
    if (builder_is_enabled(builder_mask, BACKEND_ROCM) == 1) { detect_rocm(profs, warns); }
    if (builder_is_enabled(builder_mask, BACKEND_APPLE) == 1) { detect_apple(profs, warns); }
    if (builder_is_enabled(builder_mask, BACKEND_VULKAN) == 1) { detect_vulkan(profs, warns); }
    if (builder_is_enabled(builder_mask, BACKEND_INTEL_NPU) == 1) {
        detect_intel_npu(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_AMD_XDNA) == 1) {
        detect_amd_xdna(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_TPU) == 1) { detect_tpu(profs, warns); }
    if (builder_is_enabled(builder_mask, BACKEND_GAUDI) == 1) { detect_gaudi(profs, warns); }
    if (builder_is_enabled(builder_mask, BACKEND_NEURON) == 1) { detect_neuron(profs, warns); }
    if (builder_is_enabled(builder_mask, BACKEND_INTEL_ONEAPI) == 1) {
        detect_intel_oneapi(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_QUALCOMM) == 1) {
        detect_qualcomm(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_CEREBRAS) == 1) {
        detect_cerebras(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_GRAPHCORE) == 1) {
        detect_graphcore(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_GROQ) == 1) {
        detect_groq(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_SAMSUNG_NPU) == 1) {
        detect_samsung_npu(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_MEDIATEK_APU) == 1) {
        detect_mediatek_apu(profs, warns);
    }
    #ifdef CYRIUS_TARGET_WIN
    # Windows-native GPU detection (wmic Win32_VideoController). detect_windows
    # exists only on PE builds, so both the symbol and call are gated.
    if (builder_is_enabled(builder_mask, BACKEND_WINDOWS) == 1) {
        detect_windows(profs, warns);
    }
    #endif

    # Post-passes: enrich profiles (sysfs only — always run)
    enrich_bandwidth(profs);
    enrich_pcie(profs);
    enrich_numa(profs);

    # Detect system I/O — detect_interconnects shells out to ibstat /
    # nvidia-smi topo; gate it on allow_exec.
    if (allow_exec == 1) {
        detect_interconnects(sio, profs, warns);
    }
    detect_storage(sio);
    detect_environment(sio);

    # One summary line per detection pass (info), plus a warn when a
    # detector pushed diagnostics. Counts are cheap (vec_len); the
    # messages are guarded inside hwlog_*_n so nothing builds when
    # suppressed.
    var nwarn = vec_len(warns);
    if (nwarn > 0) { hwlog_info_n("detect: warnings=", nwarn); }
    hwlog_info_n("detect: profiles=", vec_len(profs));
    hwlog_span_exit();

    return r;
}

# Build a registry from a list of profiles (for testing)
fn registry_from_profiles(profile_vec) {
    var r = hw_registry_new();
    var n = vec_len(profile_vec);
    var i = 0;
    while (i < n) {
        reg_add_profile(r, vec_get(profile_vec, i));
        i = i + 1;
    }
    return r;
}

# --- plan.cyr ---

# plan.cyr — sharding and workload planning logic
# Strategy selection: single device -> tensor parallel -> pipeline parallel

# Estimate tokens/sec for a single device
# Returns x1000 fixed-point
fn estimate_tps_x1000(accel_type, tput_x1000, model_params, quant) {
    if (model_params == 0) { return 0; }
    # base = 1B / model_params (tok/s at 1B params baseline)
    # Scale by throughput multiplier and quant speedup
    var base_x1000 = TOKENS_PER_SEC_BASE * 1000 / model_params;
    var quant_x1000 = quant_reduction_x1000(quant);
    return base_x1000 * tput_x1000 / 1000 * quant_x1000 / 1000;
}

# Generate a sharding plan for a model
fn reg_plan_sharding(r, model_params, quant) {
    var needed = reg_estimate_memory(model_params, quant);
    var sio = reg_system_io(r);
    var profs = reg_profiles(r);
    hwlog_debug_n("plan: model_params=", model_params);

    # Find best available device
    var best = reg_best_available(r);
    if (best == 0) {
        hwlog_warn("plan: no available accelerator, defaulting to data-parallel");
        return sharding_plan_new(SHARD_DATA, 0);
    }

    # Case 1: fits on single best device
    if (needed <= profile_memory_bytes(best)) {
        var sp = sharding_plan_new(SHARD_NONE, 1);
        var at = profile_accel_type(best);
        var did = profile_device_id(best);
        var ms = model_shard_new(0, 0, 0, at, did, needed);
        plan_add_shard(sp, ms);
        plan_set_total_memory(sp, needed);
        var tps = estimate_tps_x1000(
        at, profile_throughput_x1000(best), model_params, quant);
        plan_set_est_tps_x1000(sp, tps);
        return sp;
    }

    # Collect TPU and GPU/ASIC devices
    var tpu_devs = vec_new();
    var tpu_mem = 0;
    var tpu_chips = 0;
    var tpu_min_tput = 999999000;
    var gpu_devs = vec_new();
    var gpu_mem = 0;

    var n = vec_len(profs);
    var i = 0;
    while (i < n) {
        var p = vec_get(profs, i);
        i = i + 1;
        if (profile_available(p) != 1) { continue; }
        var at = profile_accel_type(p);

        if (at == ACCEL_TPU) {
            vec_push(tpu_devs, p);
            tpu_mem = tpu_mem + profile_memory_bytes(p);
            tpu_chips = tpu_chips + profile_tpu_chips(p);
            var tt = profile_throughput_x1000(p);
            if (tt < tpu_min_tput) { tpu_min_tput = tt; }
        }
        if (accel_is_gpu(at) == 1 || accel_is_ai_asic(at) == 1 || at == ACCEL_TPU) {
            vec_push(gpu_devs, p);
            gpu_mem = gpu_mem + profile_memory_bytes(p);
        }
    }

    # Case 2: TPU tensor parallel
    if (vec_len(tpu_devs) > 0 && tpu_mem >= needed) {
        if (tpu_chips < 1) { tpu_chips = 1; }
        var per_chip = needed / tpu_chips;
        if (needed > per_chip * tpu_chips) { per_chip = per_chip + 1; }

        var sp = sharding_plan_new(SHARD_TENSOR, tpu_chips);
        var ci = 0;
        while (ci < tpu_chips) {
            var tp = vec_get(tpu_devs, 0);
            var ms = model_shard_new(ci, 0, 0, ACCEL_TPU, ci, per_chip);
            plan_add_shard(sp, ms);
            ci = ci + 1;
        }
        plan_set_total_memory(sp, needed);
        var quant_x1000 = quant_reduction_x1000(quant);
        var tps = tpu_min_tput * tpu_chips * quant_x1000 / 1000 * TPU_TP_ICI_BONUS_X1000 / 1000;
        plan_set_est_tps_x1000(sp, tps);
        return sp;
    }

    # Case 3: GPU/ASIC multi-device
    if (vec_len(gpu_devs) > 0 && gpu_mem >= needed) {
        var has_nvsw = sio_has_nvswitch(sio);
        var max_bw = sio_max_ic_bw_x1000(sio);
        var num_devs = vec_len(gpu_devs);

        # Decide tensor vs pipeline parallel
        var use_tp = 0;
        var tp_bw_ok = max_bw > TP_MIN_INTERCONNECT_BW * 1000;
        var tp_devs_ok = num_devs <= TP_MAX_DEVICES_WITHOUT_NVSWITCH;
        if (has_nvsw == 1) { use_tp = 1; }
        elif (tp_bw_ok == 1 && tp_devs_ok == 1) {
            use_tp = 1;
        }

        if (use_tp == 1) {
            # Tensor parallel
            var per_dev = needed / num_devs;
            if (needed > per_dev * num_devs) { per_dev = per_dev + 1; }

            var sp = sharding_plan_new(SHARD_TENSOR, num_devs);
            var di = 0;
            while (di < num_devs) {
                var gp = vec_get(gpu_devs, di);
                var gat = profile_accel_type(gp);
                var gdid = profile_device_id(gp);
                var ms = model_shard_new(di, 0, 0, gat, gdid, per_dev);
                plan_add_shard(sp, ms);
                di = di + 1;
            }
            plan_set_total_memory(sp, needed);

            # Throughput: slowest device * num_devices * quant * IC bonus
            var slowest = 999999000;
            di = 0;
            while (di < num_devs) {
                var gt = profile_throughput_x1000(vec_get(gpu_devs, di));
                if (gt < slowest) { slowest = gt; }
                di = di + 1;
            }
            var quant_x1000 = quant_reduction_x1000(quant);
            var ic_bonus = 1000;
            if (has_nvsw == 1) { ic_bonus = NVSWITCH_TP_BONUS_X1000; }
            else {
                ic_bonus = 1000 + max_bw / TP_INTERCONNECT_BW_DIVISOR;
                var ic_max = 1000 + MAX_NON_NVSWITCH_TP_BONUS_X1000;
                if (ic_bonus > ic_max) { ic_bonus = ic_max; }
            }
            var tps = slowest * num_devs * quant_x1000 / 1000 * ic_bonus / 1000;
            plan_set_est_tps_x1000(sp, tps);
            return sp;
        }

        # Pipeline parallel
        var num_stages = num_devs;
        var per_shard = needed / num_stages;
        if (needed > per_shard * num_stages) { per_shard = per_shard + 1; }
        var est_layers = model_params / PARAMS_PER_LAYER_ESTIMATE;
        if (est_layers < 1) { est_layers = 1; }
        var layers_per = est_layers / num_stages;
        if (layers_per < 1) { layers_per = 1; }

        var sp = sharding_plan_new(SHARD_PIPELINE, num_stages);
        var si = 0;
        while (si < num_stages) {
            var gp2 = vec_get(gpu_devs, si);
            var lstart = si * layers_per;
            if (lstart >= est_layers) { lstart = est_layers - 1; }
            var lend = lstart + layers_per - 1;
            if (si == num_stages - 1) { lend = est_layers - 1; }
            if (lend >= est_layers) { lend = est_layers - 1; }
            var pat = profile_accel_type(gp2);
            var pdid = profile_device_id(gp2);
            var ms = model_shard_new(si, lstart, lend, pat, pdid, per_shard);
            plan_add_shard(sp, ms);
            si = si + 1;
        }
        plan_set_total_memory(sp, needed);

        var slowest2 = 999999000;
        si = 0;
        while (si < num_stages) {
            var st = profile_throughput_x1000(vec_get(gpu_devs, si));
            if (st < slowest2) { slowest2 = st; }
            si = si + 1;
        }
        var quant_x2 = quant_reduction_x1000(quant);
        var ic_eff = PP_PCIE_ONLY_EFFICIENCY_X1000;
        if (max_bw > 0) { ic_eff = PP_HIGH_BW_EFFICIENCY_X1000; }
        var tps2 = slowest2 * num_stages * quant_x2 / 1000 * ic_eff / 1000;
        plan_set_est_tps_x1000(sp, tps2);
        return sp;
    }

    # Case 4: CPU fallback
    var sp = sharding_plan_new(SHARD_NONE, 1);
    var ms = model_shard_new(0, 0, 0, ACCEL_CPU, 0, needed);
    plan_add_shard(sp, ms);
    plan_set_total_memory(sp, needed);
    var cpu_tps = estimate_tps_x1000(ACCEL_CPU, 1000, model_params, quant);
    plan_set_est_tps_x1000(sp, cpu_tps);
    return sp;
}

# --- training.cyr ---

# training.cyr — training method types and memory estimation
# All memory values in x1000 GB fixed-point to avoid floats.
# e.g., 14000 = 14.0 GB, 1400 = 1.4 GB

enum TrainingMethod {
    TRAIN_FULL = 0;
    TRAIN_LORA = 1;
    TRAIN_QLORA_4 = 2;
    TRAIN_QLORA_8 = 3;
    TRAIN_PREFIX = 4;
    TRAIN_DPO = 5;
    TRAIN_RLHF = 6;
    TRAIN_DISTILL = 7;
}

fn training_method_name(m) {
    if (m == TRAIN_FULL) { return "full"; }
    if (m == TRAIN_LORA) { return "lora"; }
    if (m == TRAIN_QLORA_4) { return "qlora-4bit"; }
    if (m == TRAIN_QLORA_8) { return "qlora-8bit"; }
    if (m == TRAIN_PREFIX) { return "prefix"; }
    if (m == TRAIN_DPO) { return "dpo"; }
    if (m == TRAIN_RLHF) { return "rlhf"; }
    if (m == TRAIN_DISTILL) { return "distillation"; }
    return "unknown";
}

# Parse a training method name (the --method CLI arg) to its enum.
# Returns -1 on an unrecognized name so callers can fall back.
fn training_method_from_str(s) {
    if (streq(s, "full") == 1) { return TRAIN_FULL; }
    if (streq(s, "lora") == 1) { return TRAIN_LORA; }
    if (streq(s, "qlora-4bit") == 1) { return TRAIN_QLORA_4; }
    if (streq(s, "qlora-8bit") == 1) { return TRAIN_QLORA_8; }
    if (streq(s, "prefix") == 1) { return TRAIN_PREFIX; }
    if (streq(s, "dpo") == 1) { return TRAIN_DPO; }
    if (streq(s, "rlhf") == 1) { return TRAIN_RLHF; }
    if (streq(s, "distillation") == 1) { return TRAIN_DISTILL; }
    return 0 - 1;
}

enum TrainingTarget {
    TARGET_GPU = 0;
    TARGET_TPU = 1;
    TARGET_GAUDI = 2;
    TARGET_CPU = 3;
}

# MemoryEstimate — model + optimizer + activation + computed total
# (all in GiB x1000 fixed-point). Struct name `est` matches the
# `est_*` accessor convention; constructor stays the descriptive
# `mem_est_new`. 2.1.4: hand-rolled accessors replaced with
# #derive(accessors). Param `e` is ambiguous across the codebase
# (system_io.cyr's runtime_env uses the same canonical name), so
# this struct gets the field-count bound CI check rather than the
# cross-file specific-struct guard.

#derive(accessors)
struct est {
    model_x1000;
    optimizer_x1000;
    activation_x1000;
    total_x1000;
}

var MEM_EST_SIZE = 32;

fn mem_est_new(model, optimizer, activation) {
    var e = alloc(MEM_EST_SIZE);
    est_set_model_x1000(e, model);
    est_set_optimizer_x1000(e, optimizer);
    est_set_activation_x1000(e, activation);
    est_set_total_x1000(e, model + optimizer + activation);
    return e;
}

# Estimate training memory for a model
# model_params_millions: e.g., 7000 for 7B
# Returns MemoryEstimate pointer
fn estimate_training_memory(model_params_m, method, target) {
    # base_gb = params_M * 1M * 2 bytes / GiB
    # base_gb_x1000 = params_M * 2 * 1000000 / 1073741824 * 1000
    # Simplified: base_gb_x1000 ~= params_M * 1863 / 1000
    var base_x1000 = model_params_m * 1863 / 1000;

    if (target == TARGET_TPU) { return _est_tpu(base_x1000, method); }
    if (target == TARGET_GAUDI) { return _est_gaudi(base_x1000, method); }
    return _est_gpu(base_x1000, method);
}

fn _est_gpu(base, method) {
    if (method == TRAIN_FULL) { return mem_est_new(base, base * 2, base); }
    if (method == TRAIN_LORA) { return mem_est_new(base, base / 10, base / 10); }
    if (method == TRAIN_QLORA_4) { return mem_est_new(base / 4, base / 10, base / 40); }
    if (method == TRAIN_QLORA_8) { return mem_est_new(base / 2, base / 10, base / 20); }
    if (method == TRAIN_PREFIX) { return mem_est_new(base, base / 20, base / 20); }
    if (method == TRAIN_DPO) { return mem_est_new(base * 2, base * 2, base * 3 / 2); }
    if (method == TRAIN_RLHF) { return mem_est_new(base * 2, base * 2, base * 3 / 2); }
    if (method == TRAIN_DISTILL) { return mem_est_new(base * 3 / 2, base, base * 4 / 5); }
    return mem_est_new(base, base * 2, base);
}

fn _est_tpu(base, method) {
    if (method == TRAIN_FULL) {
        return mem_est_new(base, base * 3 / 2, base * 4 / 5);
    }
    if (method == TRAIN_LORA) {
        return mem_est_new(base, base * 15 / 100, base * 12 / 100);
    }
    if (method == TRAIN_QLORA_4) {
        return mem_est_new(base * 2 / 5, base * 15 / 100, base * 12 / 250);
    }
    if (method == TRAIN_QLORA_8) {
        return mem_est_new(base * 3 / 5, base * 15 / 100, base * 12 / 167);
    }
    if (method == TRAIN_PREFIX) {
        return mem_est_new(base, base / 20, base / 20);
    }
    if (method == TRAIN_DPO) {
        return mem_est_new(base * 2, base * 3 / 2, base * 6 / 5);
    }
    if (method == TRAIN_RLHF) {
        return mem_est_new(base * 2, base * 3 / 2, base * 6 / 5);
    }
    if (method == TRAIN_DISTILL) {
        return mem_est_new(base * 3 / 2, base * 4 / 5, base * 3 / 5);
    }
    return mem_est_new(base, base * 3 / 2, base * 4 / 5);
}

fn _est_gaudi(base, method) {
    if (method == TRAIN_FULL) {
        return mem_est_new(base, base * 3 / 2, base * 9 / 10);
    }
    if (method == TRAIN_LORA) {
        return mem_est_new(base, base * 12 / 100, base * 12 / 100);
    }
    if (method == TRAIN_QLORA_4) {
        return mem_est_new(base * 35 / 100, base * 12 / 100, base * 12 / 286);
    }
    if (method == TRAIN_QLORA_8) {
        return mem_est_new(base * 55 / 100, base * 12 / 100, base * 12 / 182);
    }
    if (method == TRAIN_PREFIX) { return mem_est_new(base, base / 20, base * 6 / 100); }
    if (method == TRAIN_DPO) { return mem_est_new(base * 2, base * 3 / 2, base * 13 / 10); }
    if (method == TRAIN_RLHF) { return mem_est_new(base * 2, base * 3 / 2, base * 13 / 10); }
    if (method == TRAIN_DISTILL) { return mem_est_new(base * 3 / 2, base * 9 / 10, base * 7 / 10); }
    return mem_est_new(base, base * 3 / 2, base * 9 / 10);
}

# --- cost.cyr ---

# cost.cyr — cloud instance cost recommendation
# Reads data/cloud_pricing.json at runtime.
# Recommends cheapest instance that fits model memory requirements.

# CloudGpuInstance — pricing-driven cloud instance descriptor.
# 2.1.7: hand-rolled accessors replaced with #derive(accessors).
# Struct name `cloud_inst` matches the existing `cloud_inst_*`
# accessor convention; param `ci` is unambiguous across src/.
# Note the field-name mapping: layout had `gpu_mem_gb` and
# `total_gpu_mem_gb`; we keep those names. `price_x100` is cents
# per hour (x100 fixed-point) to avoid floats.
# Construction goes through the JSON loader in `load_cloud_instances`
# below — no public constructor, so the per-file `_parse_cloud_field_*`
# helpers (which take an offset parameter for generic dispatch)
# remain on raw `store64(ci + offset, …)`. Those stay inside the
# defining file and are accepted by the cross-file CI guard.

#derive(accessors)
struct cloud_inst {
    name;
    provider;
    gpu;
    gpu_count;
    gpu_mem_gb;
    total_mem_gb;
    vcpus;
    ram_gb;
    interconnect;
    price_x100;
}

var CLOUD_INST_SIZE = 80;

# CloudProvider enum
enum CloudProvider {
    CLOUD_AWS = 0;
    CLOUD_GCP = 1;
    CLOUD_AZURE = 2;
}

fn cloud_provider_str(p) {
    if (p == CLOUD_AWS) { return "aws"; }
    if (p == CLOUD_GCP) { return "gcp"; }
    if (p == CLOUD_AZURE) { return "azure"; }
    return "unknown";
}

# InstanceRecommendation — paired instance + computed headroom.
# 2.1.7: hand-rolled accessors replaced with #derive(accessors).
# Struct name `rec` matches the existing `rec_*` accessor convention;
# constructor stays `inst_rec_new`. Param `rec` unambiguous across src/.

#derive(accessors)
struct rec {
    instance;
    mem_required;
    headroom_x100;
}

var INST_REC_SIZE = 24;

fn inst_rec_new(inst, mem_req) {
    var rec = alloc(INST_REC_SIZE);
    rec_set_instance(rec, inst);
    rec_set_mem_required(rec, mem_req);
    var total_mem = cloud_inst_total_mem_gb(inst) * BYTES_PER_GIB;
    var headroom = 0;
    if (mem_req > 0) {
        headroom = (total_mem - mem_req) * 10000 / mem_req;
    }
    rec_set_headroom_x100(rec, headroom);
    return rec;
}

# Load cloud pricing from JSON file
# Returns vec of CloudGpuInstance pointers
fn load_cloud_instances() {
    var buf = alloc(32768);
    var n = file_read_all(data_file_path("data/cloud_pricing.json"), buf, 32768);
    if (n <= 0) { return vec_new(); }
    store8(buf + n, 0);

    var instances = vec_new();
    # Simple JSON array parsing — find each { ... } object
    var pos = 0;
    while (pos < n) {
        # Find opening brace
        if (load8(buf + pos) != 123) { pos = pos + 1; continue; }

        var ci = alloc(CLOUD_INST_SIZE);
        memset(ci, 0, CLOUD_INST_SIZE);

        # Parse key-value pairs within this object
        var obj_end = pos;
        var depth = 1;
        obj_end = obj_end + 1;
        while (obj_end < n && depth > 0) {
            if (load8(buf + obj_end) == 123) { depth = depth + 1; }
            if (load8(buf + obj_end) == 125) { depth = depth - 1; }
            obj_end = obj_end + 1;
        }

        # Extract fields using simple string scanning
        var obj = str_new(buf + pos, obj_end - pos);
        _parse_cloud_field_str(obj, "name", ci, 0);
        _parse_cloud_field_str(obj, "provider", ci, 8);
        _parse_cloud_field_str(obj, "gpu", ci, 16);
        _parse_cloud_field_int(obj, "gpu_count", ci, 24);
        _parse_cloud_field_int(obj, "gpu_memory_gb", ci, 32);
        _parse_cloud_field_int(obj, "total_gpu_memory_gb", ci, 40);
        _parse_cloud_field_int(obj, "vcpus", ci, 48);
        _parse_cloud_field_int(obj, "ram_gb", ci, 56);
        _parse_cloud_field_str(obj, "interconnect", ci, 64);
        _parse_cloud_field_price(obj, ci);

        if (cloud_inst_name(ci) != 0) {
            vec_push(instances, ci);
        }
        pos = obj_end;
    }
    return instances;
}

# Helper: extract a string value for a key from JSON object
fn _parse_cloud_field_str(obj, key, ci, offset) {
    var od = str_data(obj);
    var ol = str_len(obj);
    var klen = strlen(key);
    var pi = 0;
    while (pi < ol - klen - 4) {
        if (load8(od + pi) == 34) {
            if (memeq(od + pi + 1, key, klen) == 1) {
                if (load8(od + pi + 1 + klen) == 34) {
                    # Found key, find value string
                    var vi = pi + klen + 2;
                    while (vi < ol && load8(od + vi) != 34) { vi = vi + 1; }
                    vi = vi + 1;
                    var vstart = vi;
                    while (vi < ol && load8(od + vi) != 34) { vi = vi + 1; }
                    var vlen = vi - vstart;
                    if (vlen > 0) {
                        var val = alloc(vlen + 1);
                        memcpy(val, od + vstart, vlen);
                        store8(val + vlen, 0);
                        store64(ci + offset, val);
                    }
                    return 0;
                }
            }
        }
        pi = pi + 1;
    }
    return 0;
}

# Helper: extract an integer value for a key
fn _parse_cloud_field_int(obj, key, ci, offset) {
    var od = str_data(obj);
    var ol = str_len(obj);
    var klen = strlen(key);
    var pi = 0;
    while (pi < ol - klen - 3) {
        if (load8(od + pi) == 34) {
            if (memeq(od + pi + 1, key, klen) == 1) {
                if (load8(od + pi + 1 + klen) == 34) {
                    var vi = pi + klen + 3;
                    while (vi < ol) {
                        var c = load8(od + vi);
                        if (c >= 48 && c <= 57) { break; }
                        vi = vi + 1;
                    }
                    var num = 0;
                    while (vi < ol) {
                        var c2 = load8(od + vi);
                        if (c2 >= 48 && c2 <= 57) { num = num * 10 + c2 - 48; vi = vi + 1; }
                        else { break; }
                    }
                    store64(ci + offset, num);
                    return 0;
                }
            }
        }
        pi = pi + 1;
    }
    return 0;
}

# Parse price_per_hour as cents (x100)
fn _parse_cloud_field_price(obj, ci) {
    var od = str_data(obj);
    var ol = str_len(obj);
    var key = "price_per_hour";
    var klen = 14;
    var pi = 0;
    while (pi < ol - klen - 3) {
        if (load8(od + pi) == 34) {
            if (memeq(od + pi + 1, key, klen) == 1) {
                var vi = pi + klen + 3;
                while (vi < ol) {
                    var c = load8(od + vi);
                    if (c >= 48 && c <= 57) { break; }
                    vi = vi + 1;
                }
                # Parse dollars.cents as integer cents
                var dollars = 0;
                while (vi < ol) {
                    var c2 = load8(od + vi);
                    if (c2 >= 48 && c2 <= 57) { dollars = dollars * 10 + c2 - 48; vi = vi + 1; }
                    else { break; }
                }
                var cents = 0;
                if (vi < ol && load8(od + vi) == 46) {
                    vi = vi + 1;
                    var dec_places = 0;
                    while (vi < ol && dec_places < 2) {
                        var c3 = load8(od + vi);
                        if (c3 >= 48 && c3 <= 57) {
                            cents = cents * 10 + c3 - 48;
                            vi = vi + 1;
                            dec_places = dec_places + 1;
                        }
                        else { break; }
                    }
                    if (dec_places == 1) { cents = cents * 10; }
                }
                store64(ci + 72, dollars * 100 + cents);
                return 0;
            }
        }
        pi = pi + 1;
    }
    return 0;
}

# Recommend instances for a model, sorted by price (cheapest first)
# provider_filter: -1 for any, or CloudProvider enum value
fn recommend_instances(model_params, quant, provider_filter) {
    var instances = load_cloud_instances();
    var needed = reg_estimate_memory(model_params, quant);
    var needed_gb = needed / BYTES_PER_GIB;

    var recs = vec_new();
    var ni = vec_len(instances);
    var i = 0;
    while (i < ni) {
        var inst = vec_get(instances, i);
        i = i + 1;

        # Provider filter
        if (provider_filter >= 0) {
            var prov = cloud_inst_provider(inst);
            var target = cloud_provider_str(provider_filter);
            if (streq(prov, target) != 1) { continue; }
        }

        # Memory check
        if (cloud_inst_total_mem_gb(inst) < needed_gb) { continue; }

        vec_push(recs, inst_rec_new(inst, needed));
    }

    # Sort by price (bubble sort — small list, no vec_set needed)
    var nr = vec_len(recs);
    var si = 0;
    while (si < nr) {
        var sj = 0;
        while (sj < nr - si - 1) {
            var ra = vec_get(recs, sj);
            var rb = vec_get(recs, sj + 1);
            if (cloud_inst_price_x100(rec_instance(ra)) > cloud_inst_price_x100(rec_instance(rb))) {
                # Swap via internal vec data pointer
                var vdata = load64(recs);
                var tmp = load64(vdata + sj * 8);
                store64(vdata + sj * 8, load64(vdata + (sj + 1) * 8));
                store64(vdata + (sj + 1) * 8, tmp);
            }
            sj = sj + 1;
        }
        si = si + 1;
    }

    return recs;
}

# Serialize a cost recommendation to JSON (schema v4, 2.3.1).
# Mirrors the --cost text path in main.cyr (_handle_cost): parses the
# "<N>B" model string, computes the memory requirement, and lists the
# cheapest matching instances (capped at 5, like the text output).
fn cost_to_json(model_str, quant) {
    var num = 0;
    var pi = 0;
    while (load8(model_str + pi) != 0) {
        var c = load8(model_str + pi);
        if (c >= 48 && c <= 57) { num = num * 10 + c - 48; }
        elif (c == 66 || c == 98) { break; }
        pi = pi + 1;
    }
    var params = num * 1000000000;
    var needed = quant_model_bytes_with_overhead(params, quant);

    var sb = str_builder_new();
    str_builder_putc(sb, '{');
    _json_str(sb, "model", model_str, 0);
    _json_str(sb, "quantization", quant_name(quant), 1);
    _json_int(sb, "memory_required_bytes", needed, 1);
    str_builder_add_cstr(sb, ",\"recommendations\":[");

    var recs = recommend_instances(params, quant, 0 - 1);
    var nr = vec_len(recs);
    var limit = nr;
    if (limit > 5) { limit = 5; }
    var ri = 0;
    while (ri < limit) {
        if (ri > 0) { str_builder_putc(sb, ','); }
        var inst = rec_instance(vec_get(recs, ri));
        str_builder_putc(sb, '{');
        _json_str(sb, "instance", cloud_inst_name(inst), 0);
        _json_str(sb, "provider", cloud_inst_provider(inst), 1);
        _json_str(sb, "gpu", cloud_inst_gpu(inst), 1);
        _json_int(sb, "gpu_count", cloud_inst_gpu_count(inst), 1);
        _json_int(sb, "total_memory_gb", cloud_inst_total_mem_gb(inst), 1);
        _json_int(sb, "price_per_hour_usd_x100", cloud_inst_price_x100(inst), 1);
        str_builder_putc(sb, '}');
        ri = ri + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return str_builder_build(sb);
}

# --- model.cyr ---

# model.cyr — model compatibility database
# Reads data/models.json at runtime for model profiles.

# ModelProfile — name + family + params_billions (x1000 fixed-point,
# e.g. 70000 = 70B) + default dtype string.
# 2.1.5: hand-rolled accessors replaced with #derive(accessors). Param
# `m` is shared with the `meta` struct in model_format.cyr — both go
# through the field-count bound check in CI rather than the cross-file
# specific-struct guard.

#derive(accessors)
struct model {
    name;
    family;
    params_b_x1000;
    dtype;
}

var MODEL_PROFILE_SIZE = 32;

# Total parameter count (not billions)
fn model_param_count(m) {
    return model_params_b_x1000(m) * 1000000;
}

# Estimate memory at given quantization (bytes)
fn model_memory_bytes(m, quant) {
    return reg_estimate_memory(model_param_count(m), quant);
}

# Check if model fits in available memory
fn model_can_run(m, quant, avail_bytes) {
    return model_memory_bytes(m, quant) <= avail_bytes;
}

# Load model catalogue from JSON
fn load_models() {
    var buf = alloc(32768);
    var n = file_read_all("data/models.json", buf, 32768);
    if (n <= 0) { return vec_new(); }
    store8(buf + n, 0);

    var models = vec_new();
    var pos = 0;
    while (pos < n) {
        if (load8(buf + pos) != 123) { pos = pos + 1; continue; }

        var m = alloc(MODEL_PROFILE_SIZE);
        memset(m, 0, MODEL_PROFILE_SIZE);

        # Find object end
        var obj_end = pos + 1;
        var depth = 1;
        while (obj_end < n && depth > 0) {
            var c = load8(buf + obj_end);
            if (c == 123) { depth = depth + 1; }
            if (c == 125) { depth = depth - 1; }
            obj_end = obj_end + 1;
        }

        var obj = str_new(buf + pos, obj_end - pos);
        _parse_model_field_str(obj, "name", m, 0);
        _parse_model_field_str(obj, "family", m, 8);
        _parse_model_field_str(obj, "default_dtype", m, 24);
        _parse_model_params(obj, m);

        if (model_name(m) != 0) {
            vec_push(models, m);
        }
        pos = obj_end;
    }
    return models;
}

fn _parse_model_field_str(obj, key, m, offset) {
    var od = str_data(obj);
    var ol = str_len(obj);
    var klen = strlen(key);
    var pi = 0;
    while (pi < ol - klen - 4) {
        if (load8(od + pi) == 34) {
            if (memeq(od + pi + 1, key, klen) == 1) {
                if (load8(od + pi + 1 + klen) == 34) {
                    var vi = pi + klen + 2;
                    while (vi < ol && load8(od + vi) != 34) { vi = vi + 1; }
                    vi = vi + 1;
                    var vstart = vi;
                    while (vi < ol && load8(od + vi) != 34) { vi = vi + 1; }
                    var vlen = vi - vstart;
                    if (vlen > 0) {
                        var val = alloc(vlen + 1);
                        memcpy(val, od + vstart, vlen);
                        store8(val + vlen, 0);
                        store64(m + offset, val);
                    }
                    return 0;
                }
            }
        }
        pi = pi + 1;
    }
    return 0;
}

# Parse params_billions as x1000 integer (e.g., 70.0 -> 70000)
fn _parse_model_params(obj, m) {
    var od = str_data(obj);
    var ol = str_len(obj);
    var key = "params_billions";
    var klen = 15;
    var pi = 0;
    while (pi < ol - klen - 3) {
        if (load8(od + pi) == 34) {
            if (memeq(od + pi + 1, key, klen) == 1) {
                var vi = pi + klen + 3;
                while (vi < ol) {
                    var c = load8(od + vi);
                    if (c >= 48 && c <= 57) { break; }
                    vi = vi + 1;
                }
                var whole = 0;
                while (vi < ol) {
                    var c2 = load8(od + vi);
                    if (c2 >= 48 && c2 <= 57) { whole = whole * 10 + c2 - 48; vi = vi + 1; }
                    else { break; }
                }
                var frac = 0;
                var frac_digits = 0;
                if (vi < ol && load8(od + vi) == 46) {
                    vi = vi + 1;
                    while (vi < ol && frac_digits < 3) {
                        var c3 = load8(od + vi);
                        if (c3 >= 48 && c3 <= 57) {
                            frac = frac * 10 + c3 - 48;
                            vi = vi + 1;
                            frac_digits = frac_digits + 1;
                        }
                        else { break; }
                    }
                    while (frac_digits < 3) { frac = frac * 10; frac_digits = frac_digits + 1; }
                }
                model_set_params_b_x1000(m, whole * 1000 + frac);
                return 0;
            }
        }
        pi = pi + 1;
    }
    return 0;
}

# Find all models that fit in available memory at given quantization
fn compatible_models(models, quant, avail_bytes) {
    var result = vec_new();
    var nm = vec_len(models);
    var i = 0;
    while (i < nm) {
        var m = vec_get(models, i);
        i = i + 1;
        if (model_can_run(m, quant, avail_bytes) == 1) {
            vec_push(result, m);
        }
    }
    return result;
}

# Find a model by name (substring match)
fn find_model(models, name) {
    var nm = vec_len(models);
    var i = 0;
    while (i < nm) {
        var m = vec_get(models, i);
        i = i + 1;
        var mn = model_name(m);
        if (mn != 0) {
            var mn_str = str_from(mn);
            var name_str = str_from(name);
            if (str_contains(mn_str, name_str) == 1) { return m; }
        }
    }
    return 0;
}

# Find models by family (case-sensitive match)
fn models_by_family(models, family) {
    var result = vec_new();
    var nm = vec_len(models);
    var i = 0;
    while (i < nm) {
        var m = vec_get(models, i);
        i = i + 1;
        var mf = model_family(m);
        if (mf != 0) {
            if (streq(mf, family) == 1) {
                vec_push(result, m);
            }
        }
    }
    return result;
}

# Headroom percentage (x100 fixed-point, e.g., 2500 = 25.00%)
# Returns how much spare memory is available after loading the model
fn model_headroom_x100(m, quant, avail_bytes) {
    var needed = model_memory_bytes(m, quant);
    if (avail_bytes == 0) { return 0; }
    if (needed > avail_bytes) { return 0; }
    return (avail_bytes - needed) * 10000 / avail_bytes;
}

# Compatible models with headroom, using registry total accel memory
fn compatible_with_registry(models, r, quant) {
    var avail = reg_total_accel_memory(r);
    return compatible_models(models, quant, avail);
}

# --- model_format.cyr ---

# model_format.cyr — model file format detection
# Parses .safetensors, .gguf, .onnx, .pt file headers to extract
# model metadata without loading the full file.
# Only the first 16 KB are read.

# --- Format enum ---

enum ModelFormat {
    FMT_SAFETENSORS = 1;
    FMT_GGUF = 2;
    FMT_ONNX = 3;
    FMT_PYTORCH = 4;
}

fn format_name(f) {
    if (f == FMT_SAFETENSORS) { return "SafeTensors"; }
    if (f == FMT_GGUF) { return "GGUF"; }
    if (f == FMT_ONNX) { return "ONNX"; }
    if (f == FMT_PYTORCH) { return "PyTorch"; }
    return "Unknown";
}

# --- ModelMetadata struct ---
# Sentinel meaning: 0 = unknown for everything except `format`, which
# always carries one of the FMT_* enum values.
# 2.1.3: hand-rolled load64 accessors replaced with #derive(accessors).
# Constructor `meta_new` stays manual (derive only generates accessors).

#derive(accessors)
struct meta {
    format;
    param_count;
    dtype;
    tensor_count;
    format_version;
}

fn meta_new(fmt, params, dtype, tensors, version) {
    var m = alloc(40);
    meta_set_format(m, fmt);
    meta_set_param_count(m, params);
    meta_set_dtype(m, dtype);
    meta_set_tensor_count(m, tensors);
    meta_set_format_version(m, version);
    return m;
}

# Constants inlined where used to avoid global var limit

# --- Top-level API ---

# Detect format from file path (reads first 16 KB)
# Returns ModelMetadata ptr or 0 on failure
fn detect_model_format(path) {
    var buf = alloc(16384);
    var n = file_read_all(path, buf, 16384);
    if (n <= 0) { return 0; }
    return detect_format_from_bytes(buf, n);
}

# Detect format from raw bytes (no file I/O)
# Returns ModelMetadata ptr or 0 on failure
fn detect_format_from_bytes(buf, len) {
    var meta = _parse_safetensors(buf, len);
    if (meta != 0) { return meta; }

    meta = _parse_gguf(buf, len);
    if (meta != 0) { return meta; }

    meta = _parse_onnx(buf, len);
    if (meta != 0) { return meta; }

    if (_is_pytorch(buf, len) == 1) {
        return meta_new(FMT_PYTORCH, 0, 0, 0, 0);
    }
    return 0;
}

# --- SafeTensors parser ---
# Format: 8-byte LE header_size, then JSON metadata.
# JSON keys are tensor names with {dtype, shape, data_offsets}.

fn _parse_safetensors(buf, len) {
    if (len < 8) { return 0; }

    # Read header_size as 64-bit LE
    var header_size = load64(buf);
    # Sanity: > 0, < 100 MB
    if (header_size <= 0) { return 0; }
    if (header_size > 104857600) { return 0; }

    # Check JSON starts with '{'
    var json_start = buf + 8;
    var json_avail = len - 8;
    if (json_avail <= 0) { return 0; }

    # Skip whitespace
    var ws_i = 0;
    while (ws_i < json_avail) {
        var c = load8(json_start + ws_i);
        if (c != 32 && c != 9 && c != 10 && c != 13) { break; }
        ws_i = ws_i + 1;
    }
    if (ws_i >= json_avail) { return 0; }
    if (load8(json_start + ws_i) != 123) { return 0; }  # '{'

    # If we have the complete header, extract metadata
    if (json_avail >= header_size) {
        return _extract_safetensors_meta(json_start, header_size);
    }

    # Partial header — format identified but no metadata
    return meta_new(FMT_SAFETENSORS, 0, 0, 0, 0);
}

# Extract tensor count, dtype, and param count from SafeTensors JSON
fn _extract_safetensors_meta(json, json_len) {
    var total_params = 0;
    var tensor_count = 0;
    var dtype = 0;
    var pos = 0;

    # Scan for top-level keys (tensor names)
    # Each key maps to {dtype, shape, data_offsets}
    while (pos < json_len) {
        # Find opening quote of a key
        if (load8(json + pos) != 34) { pos = pos + 1; continue; }

        # Read key name
        var key_start = pos + 1;
        var key_end = key_start;
        while (key_end < json_len && load8(json + key_end) != 34) {
            key_end = key_end + 1;
        }
        var key_len = key_end - key_start;
        pos = key_end + 1;

        # Skip __metadata__
        if (key_len == 12) {
            if (memeq(json + key_start, "__metadata__", 12) == 1) {
                # Skip to matching closing brace
                pos = _skip_json_value(json, json_len, pos);
                continue;
            }
        }

        # Find the value object '{'
        while (pos < json_len && load8(json + pos) != 123) {
            pos = pos + 1;
        }
        if (pos >= json_len) { break; }

        # This is a tensor entry
        tensor_count = tensor_count + 1;

        # Find end of tensor object
        var obj_start = pos;
        var obj_end = _skip_json_object(json, json_len, pos);

        # Extract dtype from this tensor (first tensor wins)
        if (dtype == 0) {
            dtype = _find_json_string(json + obj_start,
            obj_end - obj_start, "dtype");
        }

        # Extract shape and multiply dimensions for param count
        var params = _extract_shape_product(json + obj_start,
        obj_end - obj_start);
        total_params = total_params + params;

        pos = obj_end;
    }

    return meta_new(FMT_SAFETENSORS, total_params,
    dtype, tensor_count, 0);
}

# Skip a JSON value (object, array, string, number, etc.)
fn _skip_json_value(json, json_len, pos) {
    while (pos < json_len && load8(json + pos) != 123) {
        if (load8(json + pos) == 44) { return pos; }  # ','
        if (load8(json + pos) == 125) { return pos; }  # '}'
        pos = pos + 1;
    }
    if (pos < json_len && load8(json + pos) == 123) {
        return _skip_json_object(json, json_len, pos);
    }
    return pos;
}

# Skip a JSON object, returns position after closing '}'
fn _skip_json_object(json, json_len, pos) {
    if (pos >= json_len) { return pos; }
    if (load8(json + pos) != 123) { return pos; }
    var depth = 1;
    pos = pos + 1;
    while (pos < json_len && depth > 0) {
        var c = load8(json + pos);
        if (c == 123) { depth = depth + 1; }
        if (c == 125) { depth = depth - 1; }
        if (c == 34) {
            # Skip quoted strings (may contain braces)
            pos = pos + 1;
            while (pos < json_len && load8(json + pos) != 34) {
                if (load8(json + pos) == 92) { pos = pos + 1; }
                pos = pos + 1;
            }
        }
        pos = pos + 1;
    }
    return pos;
}

# Find a JSON string value for a given key within a buffer
# Returns cstr ptr or 0
fn _find_json_string(buf, len, key) {
    var klen = strlen(key);
    var i = 0;
    while (i < len - klen - 4) {
        if (load8(buf + i) == 34) {
            if (memeq(buf + i + 1, key, klen) == 1) {
                if (load8(buf + i + 1 + klen) == 34) {
                    # Found key, find value string
                    var vi = i + klen + 2;
                    while (vi < len && load8(buf + vi) != 34) {
                        vi = vi + 1;
                    }
                    vi = vi + 1;
                    var vstart = vi;
                    while (vi < len && load8(buf + vi) != 34) {
                        vi = vi + 1;
                    }
                    var vlen = vi - vstart;
                    if (vlen > 0) {
                        var val = alloc(vlen + 1);
                        memcpy(val, buf + vstart, vlen);
                        store8(val + vlen, 0);
                        return val;
                    }
                    return 0;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# Extract shape array and compute product of dimensions
# Returns 0 for empty or missing shape
fn _extract_shape_product(buf, len) {
    # Find "shape" key
    var needle = "shape";
    var nlen = 5;
    var i = 0;
    while (i < len - nlen - 4) {
        if (load8(buf + i) == 34) {
            if (memeq(buf + i + 1, needle, nlen) == 1) {
                if (load8(buf + i + 1 + nlen) == 34) {
                    # Found "shape", find '['
                    var vi = i + nlen + 2;
                    while (vi < len && load8(buf + vi) != 91) {
                        vi = vi + 1;
                    }
                    if (vi >= len) { return 0; }
                    vi = vi + 1;  # skip '['

                    # Check for empty array
                    var ws = vi;
                    while (ws < len) {
                        var c = load8(buf + ws);
                        if (c != 32 && c != 10) { break; }
                        ws = ws + 1;
                    }
                    if (ws < len && load8(buf + ws) == 93) {
                        return 0;  # empty shape []
                    }

                    # Parse comma-separated integers
                    var product = 1;
                    var num = 0;
                    var has_num = 0;
                    while (vi < len) {
                        var c2 = load8(buf + vi);
                        if (c2 >= 48 && c2 <= 57) {
                            num = num * 10 + c2 - 48;
                            has_num = 1;
                        } elif (c2 == 44) {
                            if (has_num == 1) {
                                product = product * num;
                            }
                            num = 0;
                            has_num = 0;
                        } elif (c2 == 93) {
                            if (has_num == 1) {
                                product = product * num;
                            }
                            return product;
                        }
                        vi = vi + 1;
                    }
                    return product;
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

# --- GGUF parser ---
# Format: 4-byte magic "GGUF", 4-byte version, 8-byte tensor count,
# 8-byte KV count, then metadata pairs.

fn _parse_gguf(buf, len) {
    if (len < 24) { return 0; }

    # Check magic bytes "GGUF"
    if (load8(buf) != 71) { return 0; }
    if (load8(buf + 1) != 71) { return 0; }
    if (load8(buf + 2) != 85) { return 0; }
    if (load8(buf + 3) != 70) { return 0; }

    # Read version (32-bit LE) — manual LE read
    var version = load8(buf + 4);
    version = version + load8(buf + 5) * 256;
    version = version + load8(buf + 6) * 65536;
    version = version + load8(buf + 7) * 16777216;

    # Read tensor_count (64-bit LE)
    var tensor_count = load64(buf + 8);

    # Try to extract dtype from metadata
    var dtype = _extract_gguf_dtype(buf, len, 24);

    var tc = tensor_count;
    if (tc < 0) { tc = 0; }

    return meta_new(FMT_GGUF, 0, dtype, tc, version);
}

# Scan for "general.file_type" key in GGUF metadata
fn _extract_gguf_dtype(buf, len, offset) {
    var needle = "general.file_type";
    var nlen = 17;

    var i = offset;
    while (i < len - nlen) {
        if (memeq(buf + i, needle, nlen) == 1) {
            # Found key. Value type + value follow.
            var voff = i + nlen;
            if (voff + 8 > len) { return 0; }

            # Value type 4 = UINT32
            var vtype = load8(buf + voff);
            vtype = vtype + load8(buf + voff + 1) * 256;
            vtype = vtype + load8(buf + voff + 2) * 65536;
            vtype = vtype + load8(buf + voff + 3) * 16777216;
            if (vtype != 4) { return 0; }

            var ftype = load8(buf + voff + 4);
            ftype = ftype + load8(buf + voff + 5) * 256;
            ftype = ftype + load8(buf + voff + 6) * 65536;
            ftype = ftype + load8(buf + voff + 7) * 16777216;

            return _gguf_file_type_name(ftype);
        }
        i = i + 1;
    }
    return 0;
}

fn _gguf_file_type_name(ft) {
    if (ft == 0) { return "F32"; }
    if (ft == 1) { return "F16"; }
    if (ft == 2) { return "Q4_0"; }
    if (ft == 3) { return "Q4_1"; }
    if (ft == 7) { return "Q8_0"; }
    if (ft == 8) { return "Q5_0"; }
    if (ft == 9) { return "Q5_1"; }
    if (ft == 10) { return "Q2_K"; }
    if (ft == 11) { return "Q3_K_S"; }
    if (ft == 12) { return "Q3_K_M"; }
    if (ft == 13) { return "Q3_K_L"; }
    if (ft == 14) { return "Q4_K_S"; }
    if (ft == 15) { return "Q4_K_M"; }
    if (ft == 16) { return "Q5_K_S"; }
    if (ft == 17) { return "Q5_K_M"; }
    if (ft == 18) { return "Q6_K"; }
    if (ft == 19) { return "IQ2_XXS"; }
    if (ft == 20) { return "IQ2_XS"; }
    return "unknown";
}

# --- ONNX parser ---
# ONNX uses Protocol Buffers. Field 1 (ir_version) tag = 0x08.

fn _parse_onnx(buf, len) {
    if (len < 4) { return 0; }
    if (load8(buf) != 8) { return 0; }

    # Parse ir_version as varint
    var ir_ver = 0;
    var consumed = 0;
    var shift = 0;
    var vi = 1;
    while (vi < len) {
        var b = load8(buf + vi);
        ir_ver = ir_ver + (b & 127) * _pow2(shift);
        consumed = consumed + 1;
        if ((b & 128) == 0) { break; }
        shift = shift + 7;
        if (shift >= 64) { return 0; }
        vi = vi + 1;
    }
    if (consumed == 0) { return 0; }

    # Sanity: ir_version 1-20
    if (ir_ver == 0) { return 0; }
    if (ir_ver > 20) { return 0; }

    # Validate second protobuf field
    var next_off = 1 + consumed;
    if (next_off >= len) { return 0; }
    var next_tag = load8(buf + next_off);
    var wire_type = next_tag & 7;
    var field_num = next_tag / 8;
    if (wire_type > 2) { return 0; }
    if (field_num == 0) { return 0; }

    return meta_new(FMT_ONNX, 0, 0, 0, ir_ver);
}

# Simple power-of-2 for varint decoding
fn _pow2(n) {
    var r = 1;
    var i = 0;
    while (i < n) { r = r * 2; i = i + 1; }
    return r;
}

# --- PyTorch detector ---
# PyTorch files are ZIP archives: magic PK\x03\x04

fn _is_pytorch(buf, len) {
    if (len < 4) { return 0; }
    if (load8(buf) != 80) { return 0; }      # 'P'
    if (load8(buf + 1) != 75) { return 0; }   # 'K'
    if (load8(buf + 2) != 3) { return 0; }
    if (load8(buf + 3) != 4) { return 0; }
    return 1;
}

# --- JSON output for ModelMetadata ---

fn model_meta_to_json(m) {
    var sb = str_builder_new();
    str_builder_add_cstr(sb, "{\"format\":\"");
    str_builder_add_cstr(sb, format_name(meta_format(m)));
    str_builder_add_cstr(sb, "\"");

    if (meta_param_count(m) > 0) {
        str_builder_add_cstr(sb, ",\"param_count\":");
        str_builder_add_int(sb, meta_param_count(m));
    }
    if (meta_dtype(m) != 0) {
        str_builder_add_cstr(sb, ",\"dtype\":\"");
        str_builder_add_cstr(sb, meta_dtype(m));
        str_builder_add_cstr(sb, "\"");
    }
    if (meta_tensor_count(m) > 0) {
        str_builder_add_cstr(sb, ",\"tensor_count\":");
        str_builder_add_int(sb, meta_tensor_count(m));
    }
    if (meta_format_version(m) > 0) {
        str_builder_add_cstr(sb, ",\"format_version\":");
        str_builder_add_int(sb, meta_format_version(m));
    }
    str_builder_add_cstr(sb, "}");
    return str_builder_build(sb);
}

# --- requirement.cyr ---

# requirement.cyr — workload accelerator requirements
# Used for scheduling integration: "does this profile meet the requirement?"

# Requirement type enum
enum AccelRequirement {
    REQ_NONE = 0;            # CPU is sufficient
    REQ_GPU = 1;             # CUDA, ROCm, Metal, Vulkan
    REQ_TPU = 2;             # TPU (check min_chips separately)
    REQ_GAUDI = 3;           # Intel Gaudi HPU
    REQ_AWS_NEURON = 4;      # Inferentia or Trainium
    REQ_GPU_OR_TPU = 5;      # Either GPU or TPU
    REQ_ANY_ACCELERATOR = 6; # Any non-CPU accelerator
}

fn requirement_name(r) {
    if (r == REQ_NONE) { return "none"; }
    if (r == REQ_GPU) { return "gpu"; }
    if (r == REQ_TPU) { return "tpu"; }
    if (r == REQ_GAUDI) { return "gaudi"; }
    if (r == REQ_AWS_NEURON) { return "aws-neuron"; }
    if (r == REQ_GPU_OR_TPU) { return "gpu-or-tpu"; }
    if (r == REQ_ANY_ACCELERATOR) { return "any-accelerator"; }
    return "unknown";
}

# Check if a profile satisfies a requirement
# For REQ_TPU, min_chips is checked against profile_tpu_chips
fn requirement_satisfied(req, min_chips, profile) {
    if (profile_available(profile) != 1) { return 0; }
    var at = profile_accel_type(profile);

    if (req == REQ_NONE) { return 1; }

    if (req == REQ_GPU) {
        return accel_is_gpu(at);
    }

    if (req == REQ_TPU) {
        if (at != ACCEL_TPU) { return 0; }
        var chips = profile_tpu_chips(profile);
        return chips >= min_chips;
    }

    if (req == REQ_GAUDI) {
        return at == ACCEL_GAUDI;
    }

    if (req == REQ_AWS_NEURON) {
        return at == ACCEL_NEURON;
    }

    if (req == REQ_GPU_OR_TPU) {
        if (accel_is_gpu(at) == 1) { return 1; }
        return accel_is_tpu(at);
    }

    if (req == REQ_ANY_ACCELERATOR) {
        return at != ACCEL_CPU;
    }

    return 0;
}

# Find first profile in registry that satisfies requirement
fn find_satisfying_profile(req, min_chips, profiles) {
    var np = vec_len(profiles);
    var i = 0;
    while (i < np) {
        var p = vec_get(profiles, i);
        if (requirement_satisfied(req, min_chips, p) == 1) {
            return p;
        }
        i = i + 1;
    }
    return 0;
}

# Count profiles that satisfy requirement
fn count_satisfying(req, min_chips, profiles) {
    var np = vec_len(profiles);
    var count = 0;
    var i = 0;
    while (i < np) {
        var p = vec_get(profiles, i);
        if (requirement_satisfied(req, min_chips, p) == 1) {
            count = count + 1;
        }
        i = i + 1;
    }
    return count;
}

# --- async_detect.cyr ---

# async_detect.cyr — threaded concurrent hardware detection
# Runs CLI-based backends (nvidia-smi, hl-smi, vulkaninfo, etc.)
# in parallel threads, then merges results into the registry.
# Sysfs-only backends run on the main thread (fast filesystem reads).
#
# Usage:
#   var r = registry_detect_threaded();
#
# Requires: lib/thread.cyr, lib/fnptr.cyr

# Thread argument struct: { profs, warns, backend_id }
# Each thread gets its own vec for profiles and warnings,
# merged into the main registry after join.

fn _thread_arg_new(backend_id) {
    var ta = alloc(24);
    store64(ta, vec_new());     # private profs
    store64(ta + 8, vec_new()); # private warns
    store64(ta + 16, backend_id);
    return ta;
}

fn _ta_profs(ta) { return load64(ta); }
fn _ta_warns(ta) { return load64(ta + 8); }
fn _ta_backend(ta) { return load64(ta + 16); }

# Thread entry: detect a single backend into private vecs
fn _detect_thread_entry(ta) {
    var profs = _ta_profs(ta);
    var warns = _ta_warns(ta);
    var bid = _ta_backend(ta);

    if (bid == BACKEND_CUDA) { detect_cuda(profs, warns); }
    elif (bid == BACKEND_GAUDI) { detect_gaudi(profs, warns); }
    elif (bid == BACKEND_NEURON) { detect_neuron(profs, warns); }
    elif (bid == BACKEND_VULKAN) { detect_vulkan(profs, warns); }
    elif (bid == BACKEND_INTEL_ONEAPI) {
        detect_intel_oneapi(profs, warns);
    }
    elif (bid == BACKEND_APPLE) { detect_apple(profs, warns); }
    return 0;
}

# CLI-based backends that benefit from parallel execution
# (they shell out to nvidia-smi, hl-smi, neuron-ls, vulkaninfo, etc.)
fn _is_cli_backend(bid) {
    if (bid == BACKEND_CUDA) { return 1; }
    if (bid == BACKEND_GAUDI) { return 1; }
    if (bid == BACKEND_NEURON) { return 1; }
    if (bid == BACKEND_VULKAN) { return 1; }
    if (bid == BACKEND_INTEL_ONEAPI) { return 1; }
    if (bid == BACKEND_APPLE) { return 1; }
    return 0;
}

# Sysfs-only backends (fast, no subprocess — run on main thread)
fn _detect_sysfs_backends(builder_mask, profs, warns) {
    if (builder_is_enabled(builder_mask, BACKEND_ROCM) == 1) {
        detect_rocm(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_INTEL_NPU) == 1) {
        detect_intel_npu(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_AMD_XDNA) == 1) {
        detect_amd_xdna(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_TPU) == 1) {
        detect_tpu(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_QUALCOMM) == 1) {
        detect_qualcomm(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_CEREBRAS) == 1) {
        detect_cerebras(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_GRAPHCORE) == 1) {
        detect_graphcore(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_GROQ) == 1) {
        detect_groq(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_SAMSUNG_NPU) == 1) {
        detect_samsung_npu(profs, warns);
    }
    if (builder_is_enabled(builder_mask, BACKEND_MEDIATEK_APU) == 1) {
        detect_mediatek_apu(profs, warns);
    }
    return 0;
}

# Merge thread results into main registry vecs
fn _merge_results(main_profs, main_warns, ta) {
    var tp = _ta_profs(ta);
    var tw = _ta_warns(ta);
    var np = vec_len(tp);
    var nw = vec_len(tw);
    var i = 0;
    while (i < np) {
        vec_push(main_profs, vec_get(tp, i));
        i = i + 1;
    }
    i = 0;
    while (i < nw) {
        vec_push(main_warns, vec_get(tw, i));
        i = i + 1;
    }
    return 0;
}

# Threaded detection: CLI backends run in parallel threads
fn registry_detect_threaded() {
    return registry_detect_threaded_with(builder_all());
}

fn registry_detect_threaded_with(builder_mask) {
    hwlog_span_enter("detect_threaded");
    var r = hw_registry_new();
    var profs = reg_profiles(r);
    var warns = reg_warnings(r);

    # CPU profile (always)
    var sys_mem = detect_system_memory();
    if (sys_mem == 0) { sys_mem = 16 * BYTES_PER_GIB; }
    reg_add_profile(r, profile_cpu(sys_mem));

    # Spawn threads for CLI-based backends
    var threads = vec_new();
    var targs = vec_new();
    var cli_backends = vec_new();
    vec_push(cli_backends, BACKEND_CUDA);
    vec_push(cli_backends, BACKEND_GAUDI);
    vec_push(cli_backends, BACKEND_NEURON);
    vec_push(cli_backends, BACKEND_VULKAN);
    vec_push(cli_backends, BACKEND_INTEL_ONEAPI);
    vec_push(cli_backends, BACKEND_APPLE);

    var nb = vec_len(cli_backends);
    var i = 0;
    while (i < nb) {
        var bid = vec_get(cli_backends, i);
        if (builder_is_enabled(builder_mask, bid) == 1) {
            var ta = _thread_arg_new(bid);
            var t = thread_create(&_detect_thread_entry, ta);
            if (t != 0) {
                vec_push(threads, t);
                vec_push(targs, ta);
            } else {
                # Thread creation failed — run synchronously
                hwlog_warn_n("detect_threaded: thread_create failed, sync fallback for backend ", bid);
                _detect_thread_entry(ta);
                vec_push(targs, ta);
                vec_push(threads, 0);
            }
        }
        i = i + 1;
    }

    # While CLI threads run, do sysfs backends on main thread
    _detect_sysfs_backends(builder_mask, profs, warns);

    # Join all threads and merge results
    var nt = vec_len(threads);
    i = 0;
    while (i < nt) {
        var t = vec_get(threads, i);
        if (t != 0) { thread_join(t); }
        _merge_results(profs, warns, vec_get(targs, i));
        i = i + 1;
    }

    # Post-passes: enrich profiles
    enrich_bandwidth(profs);
    enrich_pcie(profs);
    enrich_numa(profs);
    detect_storage(r);
    detect_interconnects(r, reg_profiles(r), reg_warnings(r));
    detect_environment(r);

    var nwarn = vec_len(warns);
    if (nwarn > 0) { hwlog_info_n("detect_threaded: warnings=", nwarn); }
    hwlog_info_n("detect_threaded: profiles=", vec_len(profs));
    hwlog_span_exit();

    return r;
}

# --- cache.cyr ---

# cache.cyr — detection result caching with configurable TTL
# Avoids redundant hardware detection for apps that poll frequently.
#
# Usage:
#   var c = cached_registry_new(60);  # 60 second TTL
#   var r = cached_get(c);            # first call: detects
#   var r = cached_get(c);            # within TTL: returns cached
#   cached_invalidate(c);             # force re-detect on next get

# clock_gettime(CLOCK_MONOTONIC) → seconds
fn _monotonic_secs() {
    var ts[16];
    syscall(228, 1, &ts);  # SYS_CLOCK_GETTIME, CLOCK_MONOTONIC
    return load64(&ts);
}

# CachedRegistry — in-memory cache with TTL + mutex.
# 2.1.7: hand-rolled accessors replaced with #derive(accessors).
# Struct name `cached` matches the existing `cached_*` accessor
# convention; constructor stays `cached_registry_new`. Param `c`
# is unambiguous across src/.

#derive(accessors)
struct cached {
    registry;
    last_detect_secs;
    ttl_secs;
    mutex;
}

fn cached_registry_new(ttl_secs) {
    var c = alloc(32);
    cached_set_registry(c, 0);
    cached_set_last_detect_secs(c, 0);
    cached_set_ttl_secs(c, ttl_secs);
    cached_set_mutex(c, mutex_new());
    return c;
}

fn cached_get(c) {
    var mtx = cached_mutex(c);
    mutex_lock(mtx);

    var reg = cached_registry(c);
    var last = cached_last_detect_secs(c);
    var ttl = cached_ttl_secs(c);
    var now = _monotonic_secs();

    # Cache hit: registry exists and within TTL
    if (reg != 0 && now - last < ttl) {
        mutex_unlock(mtx);
        hwlog_debug("cache: hit (in-memory)");
        return reg;
    }

    mutex_unlock(mtx);

    # Cache miss: run detection (outside lock)
    hwlog_debug("cache: miss -> detecting");
    var new_reg = registry_detect();

    # Store result
    mutex_lock(mtx);
    cached_set_registry(c, new_reg);
    cached_set_last_detect_secs(c, _monotonic_secs());
    mutex_unlock(mtx);

    return new_reg;
}

fn cached_invalidate(c) {
    var mtx = cached_mutex(c);
    mutex_lock(mtx);
    cached_set_registry(c, 0);
    cached_set_last_detect_secs(c, 0);
    mutex_unlock(mtx);
    return 0;
}

fn cached_ttl(c) {
    return cached_ttl_secs(c);
}

fn cached_is_valid(c) {
    var reg = cached_registry(c);
    if (reg == 0) { return 0; }
    var last = cached_last_detect_secs(c);
    var ttl = cached_ttl_secs(c);
    var now = _monotonic_secs();
    return now - last < ttl;
}

# --- Disk-backed cache ---
# Reads/writes JSON to ~/.cache/ai-hwaccel/registry.json

fn _disk_cache_path() {
    var home = cmd_getenv("HOME");
    if (home == 0) { return "/tmp/ai-hwaccel-cache.json"; }
    var sb = str_builder_new();
    str_builder_add_cstr(sb, home);
    str_builder_add_cstr(sb, "/.cache/ai-hwaccel/registry.json");
    return str_data(str_builder_build(sb));
}

# DiskCachedRegistry — extends CachedRegistry with disk fallback.
# 2.1.7: hand-rolled accessors replaced with #derive(accessors).
# Struct name `disk_cached` matches the `disk_cached_*` accessor
# convention; constructor stays `disk_cached_new`. Param `c` is
# shared with `cached` above — both files use it (same file here),
# and the field-count bound check on each struct keeps offsets
# within the registered ranges.

#derive(accessors)
struct disk_cached {
    registry;
    last_detect_secs;
    ttl_secs;
    mutex;
    cache_path;
}

fn disk_cached_new(ttl_secs) {
    var c = alloc(40);
    disk_cached_set_registry(c, 0);
    disk_cached_set_last_detect_secs(c, 0);
    disk_cached_set_ttl_secs(c, ttl_secs);
    disk_cached_set_mutex(c, mutex_new());
    disk_cached_set_cache_path(c, _disk_cache_path());
    return c;
}

fn disk_cached_get(c) {
    var mtx = disk_cached_mutex(c);
    mutex_lock(mtx);

    var reg = disk_cached_registry(c);
    var last = disk_cached_last_detect_secs(c);
    var ttl = disk_cached_ttl_secs(c);
    var now = _monotonic_secs();

    # Memory cache hit
    if (reg != 0 && now - last < ttl) {
        mutex_unlock(mtx);
        hwlog_debug("disk_cache: hit (in-memory)");
        return reg;
    }

    # Try disk cache
    var path = disk_cached_cache_path(c);
    var dbuf = alloc(65536);
    var dn = file_read_all(path, dbuf, 65536);
    if (dn > 0) {
        # Check file age via stat
        # For simplicity, trust memory TTL — disk is fallback for cold start
        store8(dbuf + dn, 0);
        # TODO: parse JSON registry from disk (requires from_json)
        # For now, fall through to fresh detection
    }

    mutex_unlock(mtx);

    # Cache miss: detect
    hwlog_debug("disk_cache: miss -> detecting");
    var new_reg = registry_detect();

    # Write to disk (best effort)
    var json = registry_to_json(new_reg);
    var jdata = str_data(json);
    var jlen = str_len(json);
    # Ensure directory exists
    var dir_sb = str_builder_new();
    var home = cmd_getenv("HOME");
    if (home != 0) {
        str_builder_add_cstr(dir_sb, home);
        str_builder_add_cstr(dir_sb, "/.cache/ai-hwaccel");
        var dir_s = str_builder_build(dir_sb);
        # mkdir -p via syscall
        syscall(83, str_data(dir_s), 493);  # SYS_MKDIR, 0o755
    }
    if (file_write_all(path, jdata, jlen) < 0) {
        hwlog_warn("disk_cache: write failed");
    }

    # Store in memory
    mutex_lock(mtx);
    disk_cached_set_registry(c, new_reg);
    disk_cached_set_last_detect_secs(c, _monotonic_secs());
    mutex_unlock(mtx);

    return new_reg;
}

fn disk_cached_invalidate(c) {
    var mtx = disk_cached_mutex(c);
    mutex_lock(mtx);
    disk_cached_set_registry(c, 0);
    disk_cached_set_last_detect_secs(c, 0);
    mutex_unlock(mtx);
    # Remove disk cache
    var path = disk_cached_cache_path(c);
    syscall(87, path);  # SYS_UNLINK
    return 0;
}

# --- lazy.cyr ---

# lazy.cyr — lazy per-family detection
# Defers backend probing until a specific family is queried.
# Avoids spawning nvidia-smi when only TPU info is needed.
#
# Usage:
#   var lr = lazy_new();
#   var gpus = lazy_by_family(lr, FAMILY_GPU);  # probes GPU backends only
#   var all = lazy_into_registry(lr);           # probe everything

# LazyRegistry — deferred per-family detection.
# 2.1.7: hand-rolled accessors replaced with #derive(accessors).
# Struct name `lazy` matches the existing `lazy_*` accessor
# convention; constructor stays `lazy_new`. The `probed` field is
# an i64 bitmask (bit 0 = CPU probed, 1 = GPU, 2 = NPU, 3 = TPU,
# 4 = AI_ASIC) — getter returns the raw mask, bit-manipulation
# helpers below use `lazy_probed` + `lazy_set_probed` plus a small
# inline mask compute.

#derive(accessors)
struct lazy {
    profiles;
    probed;
    mutex;
}

fn lazy_new() {
    var lr = alloc(24);
    var profs = vec_new();
    # Always include CPU
    var sys_mem = detect_system_memory();
    if (sys_mem == 0) { sys_mem = 16 * BYTES_PER_GIB; }
    vec_push(profs, profile_cpu(sys_mem));
    lazy_set_profiles(lr, profs);
    lazy_set_probed(lr, 1);  # bit 0 = CPU probed
    lazy_set_mutex(lr, mutex_new());
    return lr;
}

# Check if family has been probed
fn _lazy_is_probed(lr, family) {
    var mask = lazy_probed(lr);
    var bit = 1;
    var i = 0;
    while (i < family) { bit = bit * 2; i = i + 1; }
    return (mask & bit) != 0;
}

# Mark family as probed
fn _lazy_mark_probed(lr, family) {
    var mask = lazy_probed(lr);
    var bit = 1;
    var i = 0;
    while (i < family) { bit = bit * 2; i = i + 1; }
    lazy_set_probed(lr, mask | bit);
    return 0;
}

# Build a builder mask for backends of a specific family
fn _family_builder_mask(family) {
    var mask = 0;
    if (family == FAMILY_GPU) {
        mask = builder_with(mask, BACKEND_CUDA);
        mask = builder_with(mask, BACKEND_ROCM);
        mask = builder_with(mask, BACKEND_VULKAN);
        mask = builder_with(mask, BACKEND_APPLE);
        return mask;
    }
    if (family == FAMILY_NPU) {
        mask = builder_with(mask, BACKEND_INTEL_NPU);
        mask = builder_with(mask, BACKEND_AMD_XDNA);
        mask = builder_with(mask, BACKEND_SAMSUNG_NPU);
        mask = builder_with(mask, BACKEND_MEDIATEK_APU);
        return mask;
    }
    if (family == FAMILY_TPU) {
        mask = builder_with(mask, BACKEND_TPU);
        return mask;
    }
    if (family == FAMILY_AI_ASIC) {
        mask = builder_with(mask, BACKEND_GAUDI);
        mask = builder_with(mask, BACKEND_NEURON);
        mask = builder_with(mask, BACKEND_INTEL_ONEAPI);
        mask = builder_with(mask, BACKEND_QUALCOMM);
        mask = builder_with(mask, BACKEND_CEREBRAS);
        mask = builder_with(mask, BACKEND_GRAPHCORE);
        mask = builder_with(mask, BACKEND_GROQ);
        return mask;
    }
    return mask;
}

# Ensure a family is probed, run detection if not
fn _lazy_ensure(lr, family) {
    if (family == FAMILY_CPU) { return 0; }
    if (_lazy_is_probed(lr, family) == 1) { return 0; }
    _lazy_mark_probed(lr, family);

    var mask = _family_builder_mask(family);
    var partial = registry_detect_with(mask);
    var partial_profs = reg_profiles(partial);
    var main_profs = lazy_profiles(lr);
    var np = vec_len(partial_profs);
    var i = 0;
    while (i < np) {
        var p = vec_get(partial_profs, i);
        # Skip CPU profiles from partial (we already have one)
        if (profile_accel_type(p) != ACCEL_CPU) {
            vec_push(main_profs, p);
        }
        i = i + 1;
    }
    return 0;
}

# Query profiles by family (probes on first access)
fn lazy_by_family(lr, family) {
    var mtx = lazy_mutex(lr);
    mutex_lock(mtx);
    _lazy_ensure(lr, family);
    var profs = lazy_profiles(lr);
    var result = vec_new();
    var np = vec_len(profs);
    var i = 0;
    while (i < np) {
        var p = vec_get(profs, i);
        if (profile_available(p) == 1) {
            if (accel_family(profile_accel_type(p)) == family) {
                vec_push(result, p);
            }
        }
        i = i + 1;
    }
    mutex_unlock(mtx);
    return result;
}

# Get all profiles detected so far (no new detection)
fn lazy_probed_profiles(lr) {
    var mtx = lazy_mutex(lr);
    mutex_lock(mtx);
    var profs = lazy_profiles(lr);
    mutex_unlock(mtx);
    return profs;
}

# Probe all families and return a full registry
fn lazy_into_registry(lr) {
    var mtx = lazy_mutex(lr);
    mutex_lock(mtx);
    _lazy_ensure(lr, FAMILY_GPU);
    _lazy_ensure(lr, FAMILY_NPU);
    _lazy_ensure(lr, FAMILY_TPU);
    _lazy_ensure(lr, FAMILY_AI_ASIC);
    var profs = lazy_profiles(lr);
    mutex_unlock(mtx);

    var r = hw_registry_new();
    var rp = reg_profiles(r);
    var np = vec_len(profs);
    var i = 0;
    while (i < np) {
        vec_push(rp, vec_get(profs, i));
        i = i + 1;
    }
    # Post-passes
    enrich_bandwidth(rp);
    enrich_pcie(rp);
    enrich_numa(rp);
    detect_storage(r);
    detect_interconnects(r, reg_profiles(r), reg_warnings(r));
    detect_environment(r);
    return r;
}

# --- json_out.cyr ---

# json_out.cyr — JSON serialization for registry output
# Manual JSON building via str_builder (no serde)
#
# Structural punctuation (`{`, `}`, `[`, `]`, `,`, `"`, `:`) is emitted
# with str_builder_putc — a single store8, no strlen + memcpy round-trip
# that str_builder_add_cstr pays per call. Variable-length pieces (keys,
# values, multi-byte literals like "true") stay on add_cstr. 2.3.0
# hot-path optimization; see benches/registry.bcyr json_serialize_13dev.

# Write a JSON string field: "key": "value"
fn _json_str(sb, key, val, comma) {
    if (comma == 1) { str_builder_putc(sb, ','); }
    str_builder_putc(sb, '"');
    str_builder_add_cstr(sb, key);
    str_builder_putc(sb, '"');
    str_builder_putc(sb, ':');
    str_builder_putc(sb, '"');
    if (val != 0) { str_builder_add_cstr(sb, val); }
    str_builder_putc(sb, '"');
    return 0;
}

# Write a JSON integer field: "key": value
fn _json_int(sb, key, val, comma) {
    if (comma == 1) { str_builder_putc(sb, ','); }
    str_builder_putc(sb, '"');
    str_builder_add_cstr(sb, key);
    str_builder_putc(sb, '"');
    str_builder_putc(sb, ':');
    str_builder_add_int(sb, val);
    return 0;
}

# Write a JSON bool field: "key": true/false
fn _json_bool(sb, key, val, comma) {
    if (comma == 1) { str_builder_putc(sb, ','); }
    str_builder_putc(sb, '"');
    str_builder_add_cstr(sb, key);
    str_builder_putc(sb, '"');
    str_builder_putc(sb, ':');
    if (val == 1) { str_builder_add_cstr(sb, "true"); }
    else { str_builder_add_cstr(sb, "false"); }
    return 0;
}

# Write an optional int field (skip if PROFILE_NONE)
fn _json_opt_int(sb, key, val) {
    if (val == PROFILE_NONE) { return 0; }
    _json_int(sb, key, val, 1);
    return 0;
}

# Write an optional string field (skip if 0)
fn _json_opt_str(sb, key, val) {
    if (val == 0) { return 0; }
    _json_str(sb, key, val, 1);
    return 0;
}

# Write an optional int field, skipping the "not applicable" 0 sentinel
# (tpu_chips / neuron_cores use 0, not PROFILE_NONE, for n/a).
fn _json_opt_int_nz(sb, key, val) {
    if (val == 0) { return 0; }
    _json_int(sb, key, val, 1);
    return 0;
}

# Serialize a profile to JSON.
#
# The output is LOSSLESS: `profile_from_json` reconstructs a byte-identical
# profile from it. `accelerator` (display name) and `family` (derived) are
# kept for human/binding consumers but ignored on parse; `accel_type_id`
# (raw AcceleratorType enum) is the authoritative type tag on the way back.
# Accelerator-specific and perf fields are emitted only when set, so CPU/GPU
# output is unchanged from the pre-2.3.15 shape apart from the new
# `accel_type_id` key.
fn profile_to_json(sb, p) {
    str_builder_putc(sb, '{');
    _json_str(sb, "accelerator", accel_name(profile_accel_type(p)), 0);
    _json_int(sb, "accel_type_id", profile_accel_type(p), 1);
    _json_int(sb, "device_id", profile_device_id(p), 1);
    _json_bool(sb, "available", profile_available(p), 1);
    _json_int(sb, "memory_bytes", profile_memory_bytes(p), 1);
    _json_str(sb, "family", family_name(profile_family(p)), 1);
    _json_opt_str(sb, "compute_capability", profile_compute_cap(p));
    _json_opt_str(sb, "driver_version", profile_driver_version(p));
    _json_opt_str(sb, "device_name", profile_device_name(p));
    _json_opt_int(sb, "memory_used_bytes", profile_mem_used(p));
    _json_opt_int(sb, "memory_free_bytes", profile_mem_free(p));
    _json_opt_int(sb, "numa_node", profile_numa_node(p));
    _json_opt_int(sb, "temperature_c", profile_temp_c(p));
    _json_opt_int(sb, "gpu_utilization_percent", profile_gpu_util(p));
    # Perf + accelerator-specific fields — previously dropped, so a TPU/Gaudi/
    # Neuron profile could not round-trip. Emitted only when meaningful.
    _json_opt_int(sb, "mem_bandwidth_x1000", profile_mem_bw_x1000(p));
    _json_opt_int(sb, "pcie_bandwidth_x1000", profile_pcie_bw_x1000(p));
    _json_opt_int(sb, "power_x1000", profile_power_x1000(p));
    _json_opt_int(sb, "tpu_version", profile_tpu_version(p));
    _json_opt_int_nz(sb, "tpu_chips", profile_tpu_chips(p));
    _json_opt_int(sb, "gaudi_gen", profile_gaudi_gen(p));
    _json_opt_int(sb, "neuron_chip", profile_neuron_chip(p));
    _json_opt_int_nz(sb, "neuron_cores", profile_neuron_cores(p));
    str_builder_putc(sb, '}');
    return 0;
}

# --- Profile deserialization (2.3.15) ---
#
# Inverse of profile_to_json, over the bayan JSON DOM. Added so consumers
# (e.g. samay's NodeCapacity.accel_profiles) can round-trip a profile
# through JSON — previously there was no from_json at all, and the emit was
# lossy for TPU/Gaudi/Neuron. Absent keys fall back to profile_new's
# defaults, so old-shape JSON (pre-accel_type_id) still parses, defaulting
# the type to CPU.

# Read an int field from a bayan object value, or `dflt` if absent.
fn _pj_int(v, key, dflt) {
    var el = json_v_obj_get(v, key);
    if (el == 0) { return dflt; }
    return json_v_int(el);
}

# Read a bool field (0/1), or `dflt` if absent.
fn _pj_bool(v, key, dflt) {
    var el = json_v_obj_get(v, key);
    if (el == 0) { return dflt; }
    return json_v_bool(el);
}

# Read a string field as a fresh NUL-terminated cstr (profiles store cstr),
# or 0 (the null-cstr sentinel) if the key is absent or not a string.
fn _pj_cstr(v, key) {
    var el = json_v_obj_get(v, key);
    if (el == 0) { return 0; }
    if (json_v_is_str(el) == 0) { return 0; }
    var s = json_v_str(el);
    var n = str_len(s);
    var out = alloc(n + 1);
    memcpy(out, str_data(s), n);
    store8(out + n, 0);
    return out;
}

# Reconstruct a profile from a bayan JSON object value (json_v*). Returns a
# fresh profile pointer, or 0 if `v` is not a JSON object. Rebuilds the raw
# stored state directly (not via the profile_cuda/tpu/... convenience
# constructors), so memory_bytes and every accelerator-specific field come
# straight from the document rather than being recomputed.
fn profile_from_json(v) {
    if (v == 0) { return 0; }
    if (json_v_is_obj(v) == 0) { return 0; }
    var atype = _pj_int(v, "accel_type_id", ACCEL_CPU);
    var dev_id = _pj_int(v, "device_id", 0);
    var mem = _pj_int(v, "memory_bytes", 0);
    var p = profile_new(atype, dev_id, mem);
    profile_set_available(p, _pj_bool(v, "available", 1));
    profile_set_compute_cap(p, _pj_cstr(v, "compute_capability"));
    profile_set_driver_version(p, _pj_cstr(v, "driver_version"));
    profile_set_device_name(p, _pj_cstr(v, "device_name"));
    profile_set_mem_used(p, _pj_int(v, "memory_used_bytes", PROFILE_NONE));
    profile_set_mem_free(p, _pj_int(v, "memory_free_bytes", PROFILE_NONE));
    profile_set_numa_node(p, _pj_int(v, "numa_node", PROFILE_NONE));
    profile_set_temp_c(p, _pj_int(v, "temperature_c", PROFILE_NONE));
    profile_set_gpu_util(p, _pj_int(v, "gpu_utilization_percent", PROFILE_NONE));
    profile_set_mem_bw_x1000(p, _pj_int(v, "mem_bandwidth_x1000", PROFILE_NONE));
    profile_set_pcie_bw_x1000(p, _pj_int(v, "pcie_bandwidth_x1000", PROFILE_NONE));
    profile_set_power_x1000(p, _pj_int(v, "power_x1000", PROFILE_NONE));
    profile_set_tpu_version(p, _pj_int(v, "tpu_version", PROFILE_NONE));
    profile_set_tpu_chips(p, _pj_int(v, "tpu_chips", 0));
    profile_set_gaudi_gen(p, _pj_int(v, "gaudi_gen", PROFILE_NONE));
    profile_set_neuron_chip(p, _pj_int(v, "neuron_chip", PROFILE_NONE));
    profile_set_neuron_cores(p, _pj_int(v, "neuron_cores", 0));
    return p;
}

# Convenience: parse a JSON cstr and reconstruct a profile in one step.
# Returns 0 on malformed JSON or a non-object root. Uses the explicit
# buf+len parse entry (json_v_parse_str) directly on the cstr.
fn profile_from_json_str(js_cstr) {
    var v = json_v_parse_str(js_cstr, strlen(js_cstr));
    if (v == 0) { return 0; }
    return profile_from_json(v);
}

# Serialize full registry to JSON
fn registry_to_json(r) {
    var sb = str_builder_new();
    str_builder_putc(sb, '{');
    _json_int(sb, "schema_version", reg_schema(r), 0);

    # Profiles array
    str_builder_add_cstr(sb, ",\"profiles\":[");
    var profs = reg_profiles(r);
    var np = vec_len(profs);
    var i = 0;
    while (i < np) {
        if (i > 0) { str_builder_putc(sb, ','); }
        profile_to_json(sb, vec_get(profs, i));
        i = i + 1;
    }
    str_builder_putc(sb, ']');

    # Warnings array
    var warns = reg_warnings(r);
    var nw = vec_len(warns);
    if (nw > 0) {
        str_builder_add_cstr(sb, ",\"warnings\":[");
        i = 0;
        while (i < nw) {
            if (i > 0) { str_builder_putc(sb, ','); }
            var w = vec_get(warns, i);
            str_builder_putc(sb, '"');
            str_builder_add_cstr(sb, warning_tool(w));
            str_builder_putc(sb, '"');
            i = i + 1;
        }
        str_builder_putc(sb, ']');
    }

    # System I/O topology (interconnects, storage, runtime env). Added
    # in schema v4 (2.3.1) so language bindings see the full surface.
    str_builder_add_cstr(sb, ",\"system_io\":");
    system_io_to_json(sb, reg_system_io(r));

    str_builder_putc(sb, '}');
    return str_builder_build(sb);
}

# Summary JSON (compact overview)
fn registry_to_summary_json(r) {
    var sb = str_builder_new();
    str_builder_putc(sb, '{');
    _json_int(sb, "device_count", reg_num_profiles(r), 0);
    _json_bool(sb, "has_accelerator", reg_has_accelerator(r), 1);
    _json_int(sb, "total_memory_bytes", reg_total_memory(r), 1);
    _json_int(sb, "accelerator_memory_bytes", reg_total_accel_memory(r), 1);
    _json_int(sb, "gpu_count", reg_count_by_family(r, FAMILY_GPU), 1);
    _json_int(sb, "tpu_count", reg_count_by_family(r, FAMILY_TPU), 1);
    _json_int(sb, "npu_count", reg_count_by_family(r, FAMILY_NPU), 1);
    _json_int(sb, "warnings", reg_num_warnings(r), 1);
    str_builder_putc(sb, '}');
    return str_builder_build(sb);
}

# --- System I/O topology (schema v4, 2.3.1) ---
#
# Bandwidth is exposed uniformly as bytes/sec. Internally interconnects
# store GB/s x1000 and storage stores MB/s; both convert to bytes/sec
# via x1_000_000 (GB/s x1000 -> /1000 *1e9 = x1e6; MB/s -> *1e6).

fn _ic_to_json(sb, ic) {
    str_builder_putc(sb, '{');
    _json_str(sb, "kind", ick_name(ic_kind(ic)), 0);
    _json_str(sb, "name", ic_name(ic), 1);
    _json_int(sb, "bandwidth_bytes_per_sec", ic_bw_x1000(ic) * 1000000, 1);
    _json_int(sb, "state", ic_state(ic), 1);
    str_builder_putc(sb, '}');
    return 0;
}

fn _storage_to_json(sb, sd) {
    str_builder_putc(sb, '{');
    _json_str(sb, "name", storage_name(sd), 0);
    _json_str(sb, "kind", stk_name(storage_kind(sd)), 1);
    _json_int(sb, "bandwidth_bytes_per_sec", storage_bw_x1000(sd) * 1000000, 1);
    str_builder_putc(sb, '}');
    return 0;
}

fn _env_to_json(sb, env) {
    if (env == 0) {
        str_builder_add_cstr(sb, "null");
        return 0;
    }
    str_builder_putc(sb, '{');
    _json_bool(sb, "is_docker", env_is_docker(env), 0);
    _json_bool(sb, "is_k8s", env_is_k8s(env), 1);
    _json_opt_str(sb, "k8s_namespace", env_k8s_namespace(env));
    _json_opt_str(sb, "cloud_provider", env_cloud_provider(env));
    _json_opt_str(sb, "instance_type", env_instance_type(env));
    _json_opt_str(sb, "region", env_region(env));
    _json_opt_int(sb, "k8s_gpu_count", env_k8s_gpu_count(env));
    _json_opt_str(sb, "k8s_gpu_source", env_k8s_gpu_source(env));
    str_builder_putc(sb, '}');
    return 0;
}

fn system_io_to_json(sb, sio) {
    if (sio == 0) {
        str_builder_add_cstr(sb, "null");
        return 0;
    }
    str_builder_add_cstr(sb, "{\"interconnects\":[");
    var ics = sio_interconnects(sio);
    var ni = vec_len(ics);
    var i = 0;
    while (i < ni) {
        if (i > 0) { str_builder_putc(sb, ','); }
        _ic_to_json(sb, vec_get(ics, i));
        i = i + 1;
    }
    str_builder_add_cstr(sb, "],\"storage\":[");
    var sds = sio_storage(sio);
    var ns = vec_len(sds);
    i = 0;
    while (i < ns) {
        if (i > 0) { str_builder_putc(sb, ','); }
        _storage_to_json(sb, vec_get(sds, i));
        i = i + 1;
    }
    str_builder_add_cstr(sb, "],\"environment\":");
    _env_to_json(sb, sio_environment(sio));
    str_builder_putc(sb, '}');
    return 0;
}

# --- Sharding plan (schema v4, 2.3.1) ---

fn _shard_to_json(sb, ms) {
    str_builder_putc(sb, '{');
    _json_int(sb, "id", shard_id(ms), 0);
    _json_int(sb, "layer_start", shard_layer_start(ms), 1);
    _json_int(sb, "layer_end", shard_layer_end(ms), 1);
    _json_str(sb, "device", accel_name(shard_device_type(ms)), 1);
    _json_int(sb, "device_id", shard_device_id(ms), 1);
    _json_int(sb, "memory_bytes", shard_memory_bytes(ms), 1);
    str_builder_putc(sb, '}');
    return 0;
}

fn plan_to_json(sb, sp) {
    str_builder_putc(sb, '{');
    _json_str(sb, "strategy", shard_strategy_name(plan_strategy(sp)), 0);
    _json_int(sb, "strategy_count", plan_strategy_count(sp), 1);
    _json_int(sb, "total_memory_bytes", plan_total_memory(sp), 1);
    _json_opt_int(sb, "est_tokens_per_sec_x1000", plan_est_tps_x1000(sp));
    str_builder_add_cstr(sb, ",\"shards\":[");
    var shards = plan_shards(sp);
    var n = vec_len(shards);
    var i = 0;
    while (i < n) {
        if (i > 0) { str_builder_putc(sb, ','); }
        _shard_to_json(sb, vec_get(shards, i));
        i = i + 1;
    }
    str_builder_add_cstr(sb, "]}");
    return 0;
}

# --- Training memory estimate (schema v4, 2.3.1) ---
#
# Internal values are GiB x1000 fixed-point. Emit both the byte count
# (val_x1000 * BYTES_PER_GIB / 1000) for ergonomics and the raw
# fixed-point for losslessness.

fn _est_field(sb, key_bytes, key_gib, val_x1000, comma) {
    _json_int(sb, key_bytes, val_x1000 * BYTES_PER_GIB / 1000, comma);
    _json_int(sb, key_gib, val_x1000, 1);
    return 0;
}

fn training_to_json(sb, e) {
    str_builder_putc(sb, '{');
    _est_field(sb, "model_bytes", "model_gib_x1000", est_model_x1000(e), 0);
    _est_field(sb, "optimizer_bytes", "optimizer_gib_x1000", est_optimizer_x1000(e), 1);
    _est_field(sb, "activation_bytes", "activation_gib_x1000", est_activation_x1000(e), 1);
    _est_field(sb, "total_bytes", "total_gib_x1000", est_total_x1000(e), 1);
    str_builder_putc(sb, '}');
    return 0;
}

# math.cyr — extended math functions for f64
# Usage: include "lib/math.cyr"
# Requires: (uses f64 builtins directly, no other includes)
#
# Provides: sinh, cosh, tanh, pow, clamp, min, max, lerp, hypot, sign,
#           trunc, fract, gcd, lcm, fibonacci, binomial, f64_parse
# All functions operate on f64 bit patterns.

# Constants (f64 bit patterns)
#
# Universal mathematical constants (f64 bit patterns).
# Covers the set every downstream math consumer needs.
# Literals are in hex for traceability — each byte group maps
# directly to the IEEE 754 sign/exponent/mantissa split.
var F64_ONE           = 0x3FF0_0000_0000_0000;   # 1.0
var F64_TWO           = 0x4000_0000_0000_0000;   # 2.0
var F64_HALF          = 0x3FE0_0000_0000_0000;   # 0.5
var F64_ONE_HALF      = 0x3FF8_0000_0000_0000;   # 1.5
var F64_TWO_HALF      = 0x4004_0000_0000_0000;   # 2.5
var F64_PI            = 0x4009_21FB_5444_2D18;   # π
var F64_PI_2          = 0x3FF9_21FB_5444_2D18;   # π/2
var F64_PI_4          = 0x3FE9_21FB_5444_2D18;   # π/4
var F64_PI_6          = 0x3FE0_C152_382D_7365;   # π/6 ≈ 0.5235987755982988 (atan reduction, v6.4.25)
var F64_2_PI          = 0x3FE4_5F30_6DC9_C883;   # 2/π ≈ 0.6366197723675814
var F64_TAU           = 0x4019_21FB_5444_2D18;   # 2π
var F64_E             = 0x4005_BF0A_8B14_5769;   # e
var F64_LN2           = 0x3FE6_2E42_FEFA_39EF;   # ln(2)
var F64_LN10          = 0x4002_6BB1_BBB5_5516;   # ln(10)
var F64_LOG2E         = 0x3FF7_1547_652B_82FE;   # 1/ln(2) ≈ 1.4426950408889634 (v5.8.4)
var F64_FRAC_1_SQRT2  = 0x3FE6_A09E_667F_3BCD;   # 1/√2
var F64_SQRT2         = 0x3FF6_A09E_667F_3BCD;   # √2

# Double-double (Payne-Hanek-lite) trig range-reduction constants (v6.4.25).
# For |x| ≥ F64_TRIG_BIG the single-constant reduction (r = x − k·π/2 with one
# π/2 literal) loses precision; a Dekker double-double product x·(2/π) keeps the
# reduction exact to ~1e-16 through |x| ≈ 1e15. 2/π and π/2 each carry a hi word
# plus a lo correction; the _SH/_SL pairs are the Dekker split of the hi word
# (top-26 / bottom bits) so TwoProduct can multiply exactly without FMA.
var F64_DD_SPLIT      = 0x41A0_0000_0200_0000;   # 2^27+1 (Dekker split factor)
var F64_TRIG_BIG      = 0x40C0_0000_0000_0000;   # 8192.0 — |x| threshold for the dd path
var F64_2PI_LO        = 0xBC86_B01E_C541_7056;   # 2/π low word (dd tail)
var F64_2PI_SH        = 0x3FE4_5F30_7000_0000;   # split-hi of 2/π hi word
var F64_2PI_SL        = 0xBE31_B1BB_E800_0000;   # split-lo of 2/π hi word
var F64_PI2_LO        = 0x3C91_A626_3314_5C07;   # π/2 low word (dd tail)
var F64_PI2_SH        = 0x3FF9_21FB_5800_0000;   # split-hi of π/2 hi word
var F64_PI2_SL        = 0xBE4D_DE97_4000_0000;   # split-lo of π/2 hi word

# ============================================================
# v5.7.31: aarch64 polyfills for f64_exp / f64_ln.
# ============================================================
# x86 has native x87 instructions for these (fyl2x, f2xm1, fscale);
# aarch64 has none. Pre-v5.7.31 the parser hard-rejected f64_exp /
# f64_ln on aarch64; v5.7.31 redirects them to these stdlib
# polyfills. Pure-cyrius implementations using v5.7.30's basic
# f64 ops (FADD/FSUB/FMUL/FDIV/FRINTN/FCVTZS/SCVTF). x86 builds
# don't use these — the parser keeps emitting native x87 bytes —
# but the polyfills compile fine on x86 too (no arch dependency
# in the body) and are kept here for cross-arch consistency.
#
# Accuracy target: ~1e-12 relative error for inputs in the range
# phylax / chi-squared / entropy work ([-50, 50] for exp, (0, 1e6]
# for ln). Edge cases (overflow at x > 709, underflow at x < -745)
# are out-of-spec — same behavior as the x87 path, which also
# saturates / wraps at extremes.

# exp(x) — range-reduce x = n*ln(2) + r, |r| ≤ ln(2)/2 ≈ 0.347.
# Then exp(x) = 2^n * exp(r). 2^n via integer exponent bit-pack.
# exp(r) via 7th-order Horner polynomial.
fn _f64_exp_polyfill(x): i64 {
    var LOG2E = 0x3FF71547652B82FE;     # 1/ln(2) ≈ 1.4426950408889634
    var LN2   = 0x3FE62E42FEFA39EF;     # ln(2)   ≈ 0.6931471805599453

    # Range reduction: x = n*ln(2) + r, |r| ≤ ln(2)/2 ≈ 0.347.
    var n_f = f64_round(f64_mul(x, LOG2E));         # nearest integer (as f64)
    var r   = f64_sub(x, f64_mul(n_f, LN2));         # |r| ≤ ln(2)/2

    # 11-term Taylor polynomial for exp(r) — at |r| ≤ 0.347, the
    # truncation r^11/11! ≈ 1.4e-13 absolute, which gives ~few-ulp
    # relative error post-2^n scaling. Sufficient for phylax-class
    # statistical work (chi-squared p-values, entropy). Higher
    # accuracy via Remez optimization or smaller range reduction is
    # a future polish slot if a consumer demands it.
    var c10 = 0x3E927E4FB7789F5C;       # 1/10!
    var c9  = 0x3EC71DE3A556C734;       # 1/9!
    var c8  = 0x3EFA01A01A01A01A;       # 1/8!
    var c7  = 0x3F2A01A01A01A01A;       # 1/7!
    var c6  = 0x3F56C16C16C16C17;       # 1/6! = 1/720
    var c5  = 0x3F81111111111111;       # 1/5! = 1/120
    var c4  = 0x3FA5555555555555;       # 1/4! = 1/24
    var c3  = 0x3FC5555555555555;       # 1/3! = 1/6
    var c2  = F64_HALF;                  # 1/2! = 1/2
    var c1  = F64_ONE;                   # 1/1! = 1
    var c0  = F64_ONE;                   # 1/0! = 1

    # Horner: p = c10; p = c9 + r*p; ... ; p = c0 + r*p
    # Result is 1 + r + r²/2 + ... + r^10/10!
    var p = c10;
    p = f64_add(c9, f64_mul(r, p));
    p = f64_add(c8, f64_mul(r, p));
    p = f64_add(c7, f64_mul(r, p));
    p = f64_add(c6, f64_mul(r, p));
    p = f64_add(c5, f64_mul(r, p));
    p = f64_add(c4, f64_mul(r, p));
    p = f64_add(c3, f64_mul(r, p));
    p = f64_add(c2, f64_mul(r, p));
    p = f64_add(c1, f64_mul(r, p));
    p = f64_add(c0, f64_mul(r, p));

    # 2^n via bit pattern: ((n_int + 1023) << 52) interpreted as f64.
    # n_int + 1023 is the biased exponent; mantissa = 0 → exact 2^n.
    var n_int = f64_to(n_f);
    var two_n_bits = (n_int + 1023) << 52;

    return f64_mul(two_n_bits, p);
}

# ln(x) — range-reduce via mantissa/exponent split.
#   x_bits = (sign << 63) | (e_biased << 52) | mantissa
#   e_int = e_biased - 1023; m = x / 2^e_int (in [1, 2))
# Then ln(x) = e_int * ln(2) + ln(m).
# For ln(m), use u = (m - 1) / (m + 1) and the inverse-tanh series:
#   ln((1+u)/(1-u)) = 2 * (u + u³/3 + u⁵/5 + u⁷/7 + ...)
# u is small (|u| ≤ ~0.17 since m ∈ [√(1/2), √2]), so 5 terms ≈ 1e-15.
fn _f64_ln_polyfill(x): i64 {
    # Extract biased exponent + reset to 0x3FF (= 1.0 exponent),
    # giving mantissa in [1, 2).
    var e_raw = (x >> 52) & 0x7FF;
    var e_int = e_raw - 1023;
    var m = (x & 0x800FFFFFFFFFFFFF) | 0x3FF0000000000000;

    # Normalize m to [√(1/2), √2) for tighter polynomial range.
    # If m ≥ √2 (bits 0x3FF6A09E667F3BCD), divide by 2 + bump e.
    if (m >= 0x3FF6A09E667F3BCD) {
        m = m - 0x0010000000000000;     # divide-by-2 = subtract 1<<52 from exponent field
        e_int = e_int + 1;
    }

    # u = (m - 1) / (m + 1), |u| ≤ ~0.17
    var u = f64_div(f64_sub(m, F64_ONE), f64_add(m, F64_ONE));
    var u2 = f64_mul(u, u);

    # ln(m) ≈ 2u * (1 + u²/3 + u⁴/5 + u⁶/7 + u⁸/9 + u^10/11 + u^12/13 + u^14/15)
    # 8 terms — at |u| ≤ ~0.171 (m ≤ √2), u^17/17 ≈ 4e-16 absolute,
    # well within ulp budget. 5 terms gave ~10^5 ulp at ln(e); 8
    # terms gives < 5 ulp.
    var c_3  = 0x3FD5555555555555;       # 1/3
    var c_5  = 0x3FC999999999999A;       # 1/5
    var c_7  = 0x3FC2492492492492;       # 1/7
    var c_9  = 0x3FBC71C71C71C71C;       # 1/9
    var c_11 = 0x3FB745D1745D1746;       # 1/11
    var c_13 = 0x3FB3B13B13B13B14;       # 1/13
    var c_15 = 0x3FB1111111111111;       # 1/15

    var p = c_15;
    p = f64_add(c_13, f64_mul(u2, p));
    p = f64_add(c_11, f64_mul(u2, p));
    p = f64_add(c_9,  f64_mul(u2, p));
    p = f64_add(c_7,  f64_mul(u2, p));
    p = f64_add(c_5,  f64_mul(u2, p));
    p = f64_add(c_3,  f64_mul(u2, p));
    p = f64_add(F64_ONE, f64_mul(u2, p));
    var ln_m = f64_mul(F64_TWO, f64_mul(u, p));

    # Combine: ln(x) = e_int * ln(2) + ln_m
    var e_f = f64_from(e_int);
    return f64_add(f64_mul(e_f, F64_LN2), ln_m);
}

# log2(x) — change of base: log2(x) = ln(x) / ln(2) = ln(x) * (1/ln(2)).
# v5.8.4: aarch64 polyfill (phylax #1 unblock). x86 has fyl2x for log2;
# aarch64 doesn't, so this routes through `_f64_ln_polyfill` (parse_expr
# auto-dispatches `f64_ln` on aarch64) and multiplies by F64_LOG2E. Same
# accuracy as the underlying ln polyfill (~5 ulp at typical inputs).
# Phylax's Shannon entropy + chi-squared paths use this; previously
# blocked aarch64 cross-build via the `f64_log2 is x86-only` hard-reject.
fn _f64_log2_polyfill(x): i64 {
    return f64_mul(f64_ln(x), F64_LOG2E);
}

# ============================================================
# v6.4.16: aarch64 polyfills for f64_sin / f64_cos.
# ============================================================
# x86 has native x87 fsin / fcos; aarch64 has no native trig (even
# hardware sin/cos on ARM is a library affair). Pre-v6.4.16 the
# aarch64 backend hard-rejected f64_sin / f64_cos; v6.4.16 redirects
# them to these polyfills (the v5.7.31 exp/ln pattern applied to trig).
# Consumer-filed by attn11 (hearing lane: Hann-window cos + synth sin +
# hisab num_fft twiddles) — `issues/2026-07-07-aarch64-no-trig-polyfill.md`.
#
# Range-reduce x = k·(π/2) + r with |r| ≤ π/4 and quadrant q = k mod 4;
# evaluate sin(r) and cos(r) via Horner Taylor (through 1/15! and 1/14!,
# accurate to ~1e-16 on |r| ≤ π/4) and select/sign per quadrant. Single-
# constant reduction (like _f64_exp's single ln2) — accurate for typical
# inputs; extreme-|x| (where the single π/2 subtraction loses precision)
# is out-of-spec, same posture as the exp/ln polyfills. A Payne-Hanek /
# Cody-Waite two-part reduction is a future polish slot if a consumer needs it.
# x86 builds keep emitting native fsin/fcos; these compile on x86 too but
# are only invoked on aarch64.

# sin(r)/r as a polynomial in r² (Taylor, alternating sign): the coefficients
# are (-1)^k / (2k+1)! for k = 0..7. dev-computed IEEE-754 bit patterns.
fn _f64_sin_core(r2): i64 {
    var p = 0xBD6AE7F3E733B81F;                          # s7 = -1/15!
    p = f64_add(0x3DE6124613A86D09, f64_mul(r2, p));     # s6 =  1/13!
    p = f64_add(0xBE5AE64567F544E4, f64_mul(r2, p));     # s5 = -1/11!
    p = f64_add(0x3EC71DE3A556C734, f64_mul(r2, p));     # s4 =  1/9!
    p = f64_add(0xBF2A01A01A01A01A, f64_mul(r2, p));     # s3 = -1/7!
    p = f64_add(0x3F81111111111111, f64_mul(r2, p));     # s2 =  1/5!
    p = f64_add(0xBFC5555555555555, f64_mul(r2, p));     # s1 = -1/3!
    p = f64_add(F64_ONE, f64_mul(r2, p));                # s0 =  1
    return p;
}

# cos(r) as a polynomial in r² (Taylor, alternating sign): (-1)^k / (2k)!.
fn _f64_cos_core(r2): i64 {
    var p = 0xBDA93974A8C07C9D;                          # c7 = -1/14!
    p = f64_add(0x3E21EED8EFF8D898, f64_mul(r2, p));     # c6 =  1/12!
    p = f64_add(0xBE927E4FB7789F5C, f64_mul(r2, p));     # c5 = -1/10!
    p = f64_add(0x3EFA01A01A01A01A, f64_mul(r2, p));     # c4 =  1/8!
    p = f64_add(0xBF56C16C16C16C17, f64_mul(r2, p));     # c3 = -1/6!
    p = f64_add(0x3FA5555555555555, f64_mul(r2, p));     # c2 =  1/4!
    p = f64_add(0xBFE0000000000000, f64_mul(r2, p));     # c1 = -1/2!
    p = f64_add(F64_ONE, f64_mul(r2, p));                # c0 =  1
    return p;
}

# Double-double range reduction for |x| ≥ F64_TRIG_BIG (v6.4.25, Payne-Hanek-
# lite). Recomputes k_f and r in extended precision so the reduction stays exact
# to ~1e-16 through |x| ≈ 1e15 — where the single-constant `x − k·π/2` above
# suffers catastrophic cancellation. Dekker TwoProduct (split via F64_DD_SPLIT,
# no FMA) forms x·(2/π) and frac·(π/2) with hi+lo words. The dd k_f (not a naive
# f64_round(x·2/π), which is off-by-one for large x) is what feeds the quadrant,
# so this block writes k_f directly. Duplicated verbatim in sin/cos (as the
# small-path reduction already is); factoring is blocked by no multi-return.
fn _f64_sin_polyfill(x): i64 {
    var k_f = f64_round(f64_mul(x, F64_2_PI));           # nearest multiple of π/2
    var r   = f64_sub(x, f64_mul(k_f, F64_PI_2));         # r ∈ [−π/4, π/4]
    var ax  = x & 0x7FFFFFFFFFFFFFFF;                     # |x| (clear sign bit)
    if (f64_gt(ax, F64_TRIG_BIG) == 1) {
        var xc  = f64_mul(x, F64_DD_SPLIT);
        var xhi = f64_sub(xc, f64_sub(xc, x));
        var xlo = f64_sub(x, xhi);
        var ph  = f64_mul(x, F64_2_PI);
        var pe  = f64_sub(f64_mul(xhi, F64_2PI_SH), ph);   # TwoProduct error term (Dekker)
        pe = f64_add(pe, f64_mul(xhi, F64_2PI_SL));
        pe = f64_add(pe, f64_mul(xlo, F64_2PI_SH));
        pe = f64_add(pe, f64_mul(xlo, F64_2PI_SL));
        var plo = f64_add(pe, f64_mul(x, F64_2PI_LO));
        k_f = f64_round(f64_add(ph, plo));
        var frac = f64_add(f64_sub(ph, k_f), plo);
        var fc  = f64_mul(frac, F64_DD_SPLIT);
        var fhi = f64_sub(fc, f64_sub(fc, frac));
        var flo = f64_sub(frac, fhi);
        var rh  = f64_mul(frac, F64_PI_2);
        var re  = f64_sub(f64_mul(fhi, F64_PI2_SH), rh);   # TwoProduct error term (Dekker)
        re = f64_add(re, f64_mul(fhi, F64_PI2_SL));
        re = f64_add(re, f64_mul(flo, F64_PI2_SH));
        re = f64_add(re, f64_mul(flo, F64_PI2_SL));
        r = f64_add(rh, f64_add(re, f64_mul(frac, F64_PI2_LO)));
    }
    var q   = f64_to(k_f) & 3;                            # quadrant (two's-comp mask handles k<0)
    var r2  = f64_mul(r, r);
    var sinr = f64_mul(r, _f64_sin_core(r2));
    var cosr = _f64_cos_core(r2);
    # sin(x) = [sinr, cosr, -sinr, -cosr][q]
    if (q == 0) { return sinr; }
    if (q == 1) { return cosr; }
    if (q == 2) { return f64_neg(sinr); }
    return f64_neg(cosr);
}

fn _f64_cos_polyfill(x): i64 {
    var k_f = f64_round(f64_mul(x, F64_2_PI));
    var r   = f64_sub(x, f64_mul(k_f, F64_PI_2));
    var ax  = x & 0x7FFFFFFFFFFFFFFF;
    if (f64_gt(ax, F64_TRIG_BIG) == 1) {
        var xc  = f64_mul(x, F64_DD_SPLIT);
        var xhi = f64_sub(xc, f64_sub(xc, x));
        var xlo = f64_sub(x, xhi);
        var ph  = f64_mul(x, F64_2_PI);
        var pe  = f64_sub(f64_mul(xhi, F64_2PI_SH), ph);   # TwoProduct error term (Dekker)
        pe = f64_add(pe, f64_mul(xhi, F64_2PI_SL));
        pe = f64_add(pe, f64_mul(xlo, F64_2PI_SH));
        pe = f64_add(pe, f64_mul(xlo, F64_2PI_SL));
        var plo = f64_add(pe, f64_mul(x, F64_2PI_LO));
        k_f = f64_round(f64_add(ph, plo));
        var frac = f64_add(f64_sub(ph, k_f), plo);
        var fc  = f64_mul(frac, F64_DD_SPLIT);
        var fhi = f64_sub(fc, f64_sub(fc, frac));
        var flo = f64_sub(frac, fhi);
        var rh  = f64_mul(frac, F64_PI_2);
        var re  = f64_sub(f64_mul(fhi, F64_PI2_SH), rh);   # TwoProduct error term (Dekker)
        re = f64_add(re, f64_mul(fhi, F64_PI2_SL));
        re = f64_add(re, f64_mul(flo, F64_PI2_SH));
        re = f64_add(re, f64_mul(flo, F64_PI2_SL));
        r = f64_add(rh, f64_add(re, f64_mul(frac, F64_PI2_LO)));
    }
    var q   = f64_to(k_f) & 3;
    var r2  = f64_mul(r, r);
    var sinr = f64_mul(r, _f64_sin_core(r2));
    var cosr = _f64_cos_core(r2);
    # cos(x) = [cosr, -sinr, -cosr, sinr][q]
    if (q == 0) { return cosr; }
    if (q == 1) { return f64_neg(sinr); }
    if (q == 2) { return f64_neg(cosr); }
    return sinr;
}

# ============================================================
# v6.4.25: aarch64 polyfills for f64_exp2 / f64_atan.
# ============================================================
# x86 has native x87 for these (f2xm1/fscale for exp2, fpatan for atan);
# aarch64 has none. Pre-v6.4.25 the aarch64 backend hard-rejected f64_exp2 /
# f64_atan; v6.4.25 redirects them to these polyfills — the last two of the
# transcendentals the v5.7.31 / v6.4.16 waves left as "separate unfiled aarch64
# gaps" (issues/2026-07-07-aarch64-f64-exp2-atan-hard-error.md). x86 builds keep
# emitting native x87; these compile on x86 too but are only invoked on aarch64.
# f64_tan needs no backend op — compose sin/cos at the call site.

# exp2(x) = 2^x — range-reduce x = n + f, n = round(x), |f| ≤ 0.5; then
# 2^x = 2^n · 2^f with 2^f = exp(f·ln2). r = f·ln2, |r| ≤ ln2/2 ≈ 0.347, so
# the same 11-term Taylor as _f64_exp_polyfill applies; 2^n via exponent
# bit-pack. Accuracy matches the exp polyfill (~3e-13 worst-case over [-50,50]).
fn _f64_exp2_polyfill(x): i64 {
    var LN2 = 0x3FE62E42FEFA39EF;                 # ln(2) ≈ 0.6931471805599453

    # Range reduction: n = round(x), f = x − n, r = f·ln2 (|r| ≤ ln2/2).
    var n_f = f64_round(x);
    var f   = f64_sub(x, n_f);
    var r   = f64_mul(f, LN2);

    # exp(r) — 11-term Taylor (coeffs shared with _f64_exp_polyfill).
    var c10 = 0x3E927E4FB7789F5C;                 # 1/10!
    var c9  = 0x3EC71DE3A556C734;                 # 1/9!
    var c8  = 0x3EFA01A01A01A01A;                 # 1/8!
    var c7  = 0x3F2A01A01A01A01A;                 # 1/7!
    var c6  = 0x3F56C16C16C16C17;                 # 1/6!
    var c5  = 0x3F81111111111111;                 # 1/5!
    var c4  = 0x3FA5555555555555;                 # 1/4!
    var c3  = 0x3FC5555555555555;                 # 1/3!
    var c2  = F64_HALF;                            # 1/2!
    var c1  = F64_ONE;                             # 1/1!
    var c0  = F64_ONE;                             # 1/0!
    var p = c10;
    p = f64_add(c9, f64_mul(r, p));
    p = f64_add(c8, f64_mul(r, p));
    p = f64_add(c7, f64_mul(r, p));
    p = f64_add(c6, f64_mul(r, p));
    p = f64_add(c5, f64_mul(r, p));
    p = f64_add(c4, f64_mul(r, p));
    p = f64_add(c3, f64_mul(r, p));
    p = f64_add(c2, f64_mul(r, p));
    p = f64_add(c1, f64_mul(r, p));
    p = f64_add(c0, f64_mul(r, p));

    # 2^n via bit pattern: ((n + 1023) << 52) as f64 (mantissa 0 → exact 2^n).
    var n_int = f64_to(n_f);
    var two_n_bits = (n_int + 1023) << 52;
    return f64_mul(two_n_bits, p);
}

# atan(x) → (−π/2, π/2). Two-stage argument reduction keeps the Taylor
# argument small: (1) atan(−x) = −atan(x), so work on |x|; (2) atan(ax) =
# π/2 − atan(1/ax) folds |x| > 1 into [0, 1]; (3) atan(ax) = π/6 +
# atan((ax − 1/√3)/(1 + ax/√3)) folds ax > 2−√3 into |t| ≤ tan(π/12) ≈ 0.268.
# On that range an 11-term Taylor (through t^21) gives ~1e-14. Accuracy
# ~1e-14 worst-case (validated vs reference over ±1e8).
fn _f64_atan_polyfill(x): i64 {
    var TAN30 = 0x3FE279A74590331C;               # tan(π/6) = 1/√3 ≈ 0.5773502691896257
    var T2MS3 = 0x3FD126145E9ECD58;               # 2 − √3 ≈ 0.2679491924311227

    # (1) sign fold: work on |x|, restore at the end.
    var neg = 0;
    var ax  = x;
    if ((x & 0x8000000000000000) != 0) { neg = 1; ax = x & 0x7FFFFFFFFFFFFFFF; }

    # (2) reciprocal fold: |x| > 1 → atan = π/2 − atan(1/ax).
    var inv = 0;
    if (f64_gt(ax, F64_ONE) == 1) { inv = 1; ax = f64_div(F64_ONE, ax); }

    # (3) π/6 fold: ax > 2−√3 → subtract π/6 offset, map to |t| ≤ tan(π/12).
    var addpi6 = 0;
    if (f64_gt(ax, T2MS3) == 1) {
        addpi6 = 1;
        ax = f64_div(f64_sub(ax, TAN30), f64_add(F64_ONE, f64_mul(ax, TAN30)));
    }

    # atan(t) = t·P(t²), P(u) = 1 − u/3 + u²/5 − u³/7 + … + u^10/21 (Horner).
    var t2 = f64_mul(ax, ax);
    var p = 0x3FA8618618618618;                    # +1/21
    p = f64_add(0xBFAAF286BCA1AF28, f64_mul(t2, p)); # −1/19
    p = f64_add(0x3FAE1E1E1E1E1E1E, f64_mul(t2, p)); # +1/17
    p = f64_add(0xBFB1111111111111, f64_mul(t2, p)); # −1/15
    p = f64_add(0x3FB3B13B13B13B14, f64_mul(t2, p)); # +1/13
    p = f64_add(0xBFB745D1745D1746, f64_mul(t2, p)); # −1/11
    p = f64_add(0x3FBC71C71C71C71C, f64_mul(t2, p)); # +1/9
    p = f64_add(0xBFC2492492492492, f64_mul(t2, p)); # −1/7
    p = f64_add(0x3FC999999999999A, f64_mul(t2, p)); # +1/5
    p = f64_add(0xBFD5555555555555, f64_mul(t2, p)); # −1/3
    p = f64_add(F64_ONE, f64_mul(t2, p));            # +1
    var res = f64_mul(ax, p);

    if (addpi6 == 1) { res = f64_add(res, F64_PI_6); }
    if (inv == 1)    { res = f64_sub(F64_PI_2, res); }
    if (neg == 1)    { res = f64_neg(res); }
    return res;
}

# clamp(x, lo, hi) — clamp x to [lo, hi]
fn f64_clamp(x, lo, hi): i64 {
    if (f64_lt(x, lo) == 1) { return lo; }
    if (f64_gt(x, hi) == 1) { return hi; }
    return x;
}

# min/max for f64
fn f64_min(a, b): i64 {
    if (f64_lt(a, b) == 1) { return a; }
    return b;
}
# Return the larger of two f64 values
fn f64_max(a, b): i64 {
    if (f64_gt(a, b) == 1) { return a; }
    return b;
}

# Inclusive comparisons (v6.0.x — avatara proposal 2026-06-02). The
# compiler ships f64_lt/f64_gt/f64_eq builtins but no <= / >=, so every
# consumer doing an inclusive range/threshold check (0.0 <= x <= 1.0)
# rolled its own. NaN-correct by construction: for any NaN operand
# f64_lt/f64_gt/f64_eq all return 0 (IEEE-754 unordered), so these
# return 0 too. NOTE: that invariant only became *true* at v6.2.41 — the
# x86 backend previously read CF/ZF without the parity flag, so f64_lt /
# f64_eq returned 1 on NaN and these helpers silently passed NaN through
# a `<=` / `>=` bound (issue 2026-06-24-f64-le-nan-comparison). Do not
# revert these to operator `<=` / `>=`; the builtin route is the tested one.
fn f64_le(a, b): i64 {
    if (f64_lt(a, b) == 1) { return 1; }
    return f64_eq(a, b);
}
# f64 a >= b : 1 if true, else 0.
fn f64_ge(a, b): i64 {
    if (f64_gt(a, b) == 1) { return 1; }
    return f64_eq(a, b);
}

var _F64_ZERO = 0;

# ================================================================
# f64 UTILITIES
# ================================================================
# Extracted from abaco/dsp.cyr — foundational primitives that belong
# in stdlib, not application code.

# Linear interpolation: lerp(a, b, 0) = a, lerp(a, b, 1) = b
fn f64_lerp(a, b, t): i64 {
    return f64_add(a, f64_mul(t, f64_sub(b, a)));
}

# Sign: -1.0 if x < 0, +1.0 if x > 0, 0.0 if x == 0
fn f64_sign(x): i64 {
    var zero = f64_from(0);
    if (f64_lt(x, zero) == 1) { return f64_neg(f64_from(1)); }
    if (f64_gt(x, zero) == 1) { return f64_from(1); }
    return zero;
}

# Truncate toward zero: trunc(3.7) = 3.0, trunc(-3.7) = -3.0
fn f64_trunc(x): i64 {
    var zero = f64_from(0);
    if (f64_lt(x, zero) == 1) { return f64_ceil(x); }
    return f64_floor(x);
}

# Fractional part: fract(3.7) = 0.7
fn f64_fract(x): i64 {
    return f64_sub(x, f64_floor(x));
}

# ================================================================
# INTEGER UTILITIES
# ================================================================

# Greatest common divisor (Euclidean algorithm). Handles negatives.
fn gcd(a, b): i64 {
    if (a < 0) { a = 0 - a; }
    if (b < 0) { b = 0 - b; }
    while (b != 0) {
        var t = b;
        b = a % b;
        a = t;
    }
    return a;
}

# Least common multiple.
fn lcm(a, b): i64 {
    if (a == 0 || b == 0) { return 0; }
    var g = gcd(a, b);
    var result = (a / g) * b;
    if (result < 0) { result = 0 - result; }
    return result;
}

# ================================================================
# f64 PARSING
# ================================================================
# Parse a null-terminated string to an f64 bit pattern.
# Returns the f64 bit pattern, or 0 on failure.
# Handles: optional sign, integer part, optional fraction,
# optional e/E exponent with optional sign, NaN, Inf, -Inf.
#
# Parse a null-terminated cstring to an f64 bit pattern (0 on failure)
fn f64_parse(s): i64 {
    var i = 0;
    var neg = 0;

    # Skip leading whitespace
    while (load8(s + i) == 32 || load8(s + i) == 9) { i = i + 1; }

    # Sign
    if (load8(s + i) == 45) { neg = 1; i = i + 1; }
    elif (load8(s + i) == 43) { i = i + 1; }

    # NaN
    if (load8(s + i) == 78 || load8(s + i) == 110) {
        if ((load8(s+i+1) == 97 || load8(s+i+1) == 65) && (load8(s+i+2) == 78 || load8(s+i+2) == 110)) {
            return 0x7FF8000000000000;
        }
    }
    # Inf
    if (load8(s + i) == 73 || load8(s + i) == 105) {
        if ((load8(s+i+1) == 110 || load8(s+i+1) == 78) && (load8(s+i+2) == 102 || load8(s+i+2) == 70)) {
            if (neg == 1) { return 0xFFF0000000000000; }
            return 0x7FF0000000000000;
        }
    }

    # Integer part
    var has_digits = 0;
    var result = f64_from(0);
    var ten = f64_from(10);
    while (load8(s + i) >= 48 && load8(s + i) <= 57) {
        result = f64_add(f64_mul(result, ten), f64_from(load8(s + i) - 48));
        has_digits = 1;
        i = i + 1;
    }

    # Fractional part
    if (load8(s + i) == 46) {
        i = i + 1;
        var frac_scale = f64_from(1);
        while (load8(s + i) >= 48 && load8(s + i) <= 57) {
            frac_scale = f64_div(frac_scale, ten);
            result = f64_add(result, f64_mul(f64_from(load8(s + i) - 48), frac_scale));
            has_digits = 1;
            i = i + 1;
        }
    }

    if (has_digits == 0) { return 0; }

    # Exponent
    if (load8(s + i) == 101 || load8(s + i) == 69) {
        i = i + 1;
        var exp_neg = 0;
        if (load8(s + i) == 45) { exp_neg = 1; i = i + 1; }
        elif (load8(s + i) == 43) { i = i + 1; }
        var exp_val = 0;
        while (load8(s + i) >= 48 && load8(s + i) <= 57) {
            exp_val = exp_val * 10 + (load8(s + i) - 48);
            i = i + 1;
        }
        # Apply exponent: result * 10^exp
        var exp_scale = f64_from(1);
        var ei = 0;
        while (ei < exp_val) {
            exp_scale = f64_mul(exp_scale, ten);
            ei = ei + 1;
        }
        if (exp_neg == 1) {
            result = f64_div(result, exp_scale);
        } else {
            result = f64_mul(result, exp_scale);
        }
    }

    if (neg == 1) { result = f64_neg(result); }
    return result;
}

# Parse with success flag. Writes f64 result to *out, returns 1 on
# success, 0 on failure (out unchanged on failure).
fn f64_parse_ok(s, out): i64 {
    var i = 0;
    while (load8(s + i) == 32 || load8(s + i) == 9) { i = i + 1; }
    # Reject empty / whitespace-only
    if (load8(s + i) == 0) { return 0; }
    # Check for at least one digit or NaN/Inf after sign
    var ci = i;
    if (load8(s + ci) == 45 || load8(s + ci) == 43) { ci = ci + 1; }
    var c = load8(s + ci);
    if (c < 48 || c > 57) {
        # Allow NaN/Inf
        if (c != 78 && c != 110 && c != 73 && c != 105 && c != 46) { return 0; }
    }
    var val = f64_parse(s);
    store64(out, val);
    return 1;
}

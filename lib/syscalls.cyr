# syscalls.cyr — Linux syscall wrappers (arch-dispatched)
# Usage: include "lib/syscalls.cyr"
#
# This file is the public include point for Linux syscalls. It
# delegates to the per-arch peer based on the compile-time arch
# macro that cycc sets via PP_PREDEFINE in main.cyr / main_aarch64.cyr.
# Consumers see a single file; the right syscall numbers, struct
# layouts, and at-family wrappers come along automatically.
#
# Per-arch peers (do NOT include them directly — go through here):
#   lib/syscalls_x86_64_linux.cyr   — x86_64 syscall numbers,
#                                     bare stat(2)/open(2)/etc.,
#                                     `arch/x86/include/uapi/asm/stat.h`
#                                     struct layout (st_mode @ 24).
#   lib/syscalls_aarch64_linux.cyr  — aarch64 generic-table numbers,
#                                     at-family wrappers
#                                     (openat / newfstatat / mkdirat /
#                                     unlinkat / pipe2 / clone(SIGCHLD)),
#                                     `include/uapi/asm-generic/stat.h`
#                                     struct layout (st_mode @ 16).
#
# Splitting from the v5.4.10 monolith fixes the yukti aarch64
# regression filed 2026-04-19 (yukti/docs/development/issues/
# 2026-04-19-aarch64-syscall-portability.md): cross-built aarch64
# binaries were inheriting x86_64 syscall numbers verbatim, so
# `syscall(SYS_STAT, ...)` invoked `pivot_root` on aarch64 instead
# of `stat`. Per-arch peers eliminate the silent number drift.
#
# `#ifplat` directive available (v5.4.19) but call sites stay on
# `#ifdef` until codegen regression diagnosed; new consumers may use.
#
# cycc / cycc_aarch64 predefine CYRIUS_TARGET_LINUX; cycc_win predefines
# CYRIUS_TARGET_WIN. Mutually exclusive per compile; no #else needed.
# See CHANGELOG [5.4.11], [5.4.19], [5.5.0].
#ifdef CYRIUS_TARGET_WIN
include "lib/syscalls_windows.cyr"
#endif
#ifdef CYRIUS_TARGET_LINUX
#ifdef CYRIUS_ARCH_X86
include "lib/syscalls_x86_64_linux.cyr"
#endif
#ifdef CYRIUS_ARCH_AARCH64
include "lib/syscalls_aarch64_linux.cyr"
#endif
#endif
# macOS (Mach-O). x86_64 uses the BSD-numbered syscalls_macos.cyr.
# arm64 uses the Linux aarch64 numbers for now (tools build but their
# file I/O does not yet work on macOS — see below). Mirrors the
# CYRIUS_TARGET_MACOS dispatch in lib/alloc.cyr.
#
# KNOWN-INCOMPLETE (v6.0.33): full macOS tool/wrapper support is a
# separate backend task. The macho-arm ESYSXLAT (src/backend/aarch64/
# emit.cyr) translates ONLY the 9-syscall whitelist (0,1,2,3,9,10,11,
# 60,228) from x86_64-Linux numbers to BSD. To make the tools work:
#   (a) the stdlib here must feed x86_64-Linux numbers (read=0/open=2/
#       …), not aarch64 (read=63/openat=56) — but switching to
#       syscalls_x86_64_linux.cyr collides (duplicate `enum`); and
#   (b) ESYSXLAT's whitelist must grow to cover the syscalls the tools
#       use (stat/lseek/fork/execve/dup2/pipe → BSD equivalents +
#       reroutes for the non-trivial ones).
# Tracked as the macОS tool-surface follow-up. `cycc` itself is
# UNAFFECTED — it uses its own x86-numbered `enum Sys`
# (src/main_aarch64_macho.cyr) and self-hosts byte-identical (v6.0.33).
#ifdef CYRIUS_TARGET_MACOS
#ifdef CYRIUS_ARCH_X86
include "lib/syscalls_macos.cyr"
#endif
#ifdef CYRIUS_ARCH_AARCH64
include "lib/syscalls_aarch64_linux.cyr"
#endif
#endif
# AGNOS ring-3 userspace (x86_64). Agnos syscall numbers + AO_* open flags
# + the a4=r10 4-arg convention. Selected when cycc predefines
# CYRIUS_TARGET_AGNOS (a CYRIUS_TARGET_AGNOS=1 build). Standalone peer —
# see its header + agnos/docs/development/agnos-userland-abi.md.
#ifdef CYRIUS_TARGET_AGNOS
include "lib/syscalls_x86_64_agnos.cyr"
#endif

# ── signal_ignore (v6.4.51) ──
# Set a signal's disposition to SIG_IGN (ignore). Primary use: SIGPIPE — so a
# write to a peer that closed mid-response returns EPIPE instead of TERMINATING
# the process. Without it, any server built on `sock_send` (a flagsless
# `sys_write`) is one disconnected client away from an unauthenticated SIGPIPE
# DoS. See issue 2026-07-11-sandhi-signal-ignore-stdlib-gap.md.
# Portable: Linux rt_sigaction (x86 #13 / aarch64 #134), macOS BSD sigaction
# (the Mach-O ESYSXLAT renumbers 13/134 → BSD 46), Windows/agnos no-op (no
# SIGPIPE there). The 32-byte {sa_handler=SIG_IGN, 0,0,0} struct is valid for
# BOTH the Linux rt_sigaction and BSD sigaction ABIs (macOS reads sa_handler
# from the first 8 bytes; Linux's trailing sigsetsize arg is ignored on BSD).
# Returns the syscall result (0 on success).
enum Signal { SIGINT = 2; SIGQUIT = 3; SIGKILL = 9; SIGPIPE = 13; SIGTERM = 15; }
# ONE definition; exactly one target branch survives the preprocessor per compile
# (Win/agnos have no SIGPIPE → no-op; Linux uses the 4-arg rt_sigaction incl.
# sigsetsize=8; macOS uses the 3-arg BSD sigaction, the Mach-O ESYSXLAT renumbering
# 13/134 → 46). Kept as a single fn so the #ifdef-blind static checker doesn't read
# it as a duplicate definition.
fn signal_ignore(signum): i64 {
    #ifdef CYRIUS_TARGET_LINUX
    var act[32];
    var ap = &act;
    var i = 0;
    while (i < 32) { store8(ap + i, 0); i += 1; }
    store64(ap, 1);   # sa_handler = SIG_IGN (1)
    #ifdef CYRIUS_ARCH_X86
    return syscall(13, signum, ap, 0, 8);    # rt_sigaction(sig, act, oldact=0, sigsetsize=8)
    #endif
    #ifdef CYRIUS_ARCH_AARCH64
    return syscall(134, signum, ap, 0, 8);   # rt_sigaction (aarch64 #134)
    #endif
    #endif
    #ifdef CYRIUS_TARGET_MACOS
    var mact[32];
    var mp = &mact;
    var mi = 0;
    while (mi < 32) { store8(mp + mi, 0); mi += 1; }
    store64(mp, 1);   # sa_handler = SIG_IGN (1)
    #ifdef CYRIUS_ARCH_X86
    return syscall(13, signum, mp, 0);       # ESYSXLAT 13  → BSD sigaction 46 (3-arg)
    #endif
    #ifdef CYRIUS_ARCH_AARCH64
    return syscall(134, signum, mp, 0);      # ESYSXLAT 134 → BSD sigaction 46 (3-arg)
    #endif
    #endif
    #ifdef CYRIUS_TARGET_WIN
    return 0;   # Windows has no SIGPIPE
    #endif
    #ifdef CYRIUS_TARGET_AGNOS
    return 0;   # agnos ring-3: no signal delivery yet
    #endif
}
